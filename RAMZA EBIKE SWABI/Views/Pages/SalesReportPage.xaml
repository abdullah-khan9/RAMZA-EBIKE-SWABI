<Page x:Class="Ramza_EBike_Swabi.Views.Pages.SalesReportPage"
      xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
      xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
      Background="#F4F5F7">

    <Page.Resources>

        <!-- ═══ CARD ═══ -->
        <Style x:Key="MetricCard" TargetType="Border">
            <Setter Property="Background" Value="White"/>
            <Setter Property="CornerRadius" Value="10"/>
            <Setter Property="Margin" Value="5"/>
            <Setter Property="Padding" Value="16 14"/>
            <Setter Property="BorderBrush" Value="#E8E8E8"/>
            <Setter Property="BorderThickness" Value="1"/>
        </Style>

        <!-- ═══ SECTION HEADING ═══ -->
        <Style x:Key="SectionHeading" TargetType="TextBlock">
            <Setter Property="FontSize" Value="12"/>
            <Setter Property="FontWeight" Value="SemiBold"/>
            <Setter Property="Foreground" Value="#6B7280"/>
            <Setter Property="Margin" Value="6 20 0 8"/>
        </Style>

        <!-- ═══ CARD LABEL ═══ -->
        <Style x:Key="CardLabel" TargetType="TextBlock">
            <Setter Property="FontSize" Value="12"/>
            <Setter Property="Foreground" Value="#9CA3AF"/>
            <Setter Property="FontWeight" Value="Normal"/>
            <Setter Property="Margin" Value="0 0 0 4"/>
        </Style>

        <!-- ═══ CARD VALUE ═══ -->
        <Style x:Key="CardValue" TargetType="TextBlock">
            <Setter Property="FontSize" Value="20"/>
            <Setter Property="FontWeight" Value="SemiBold"/>
            <Setter Property="Margin" Value="0 2 0 2"/>
        </Style>

        <!-- ═══ CARD SUB ═══ -->
        <Style x:Key="CardSub" TargetType="TextBlock">
            <Setter Property="FontSize" Value="11"/>
            <Setter Property="Foreground" Value="#D1D5DB"/>
        </Style>

        <!-- ═══ ACCENT BAR ═══ -->
        <Style x:Key="AccentBar" TargetType="Border">
            <Setter Property="Width" Value="3"/>
            <Setter Property="CornerRadius" Value="2"/>
            <Setter Property="Margin" Value="0 0 10 0"/>
        </Style>

        <!-- ═══ SECTION DIVIDER ═══ -->
        <Style x:Key="Divider" TargetType="Border">
            <Setter Property="BorderBrush" Value="#F0F0F0"/>
            <Setter Property="BorderThickness" Value="0 0 0 1"/>
            <Setter Property="Margin" Value="6 10 6 0"/>
        </Style>

    </Page.Resources>

    <ScrollViewer VerticalScrollBarVisibility="Auto" HorizontalScrollBarVisibility="Disabled">
        <StackPanel Margin="20 18 20 30">

            <!-- ═══ HEADER ═══ -->
            <Grid Margin="0 0 0 18">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="Auto"/>
                    <ColumnDefinition Width="*"/>
                </Grid.ColumnDefinitions>

                <Button Content="← Back" Width="90" Height="34"
                        Background="#2B579A" Foreground="White"
                        FontSize="13" BorderThickness="0"
                        Cursor="Hand"
                        Click="Back_Click">
                    <Button.Template>
                        <ControlTemplate TargetType="Button">
                            <Border Background="{TemplateBinding Background}"
                                    CornerRadius="7" Padding="0">
                                <ContentPresenter HorizontalAlignment="Center"
                                                  VerticalAlignment="Center"/>
                            </Border>
                        </ControlTemplate>
                    </Button.Template>
                </Button>

                <TextBlock Grid.Column="1" Text="Sales Report"
                           FontSize="22" FontWeight="Bold"
                           Foreground="#111827"
                           HorizontalAlignment="Center"
                           VerticalAlignment="Center"/>
            </Grid>

            <!-- ═══ FILTER BAR ═══ -->
            <Border Background="White" CornerRadius="10"
                    BorderBrush="#E8E8E8" BorderThickness="1"
                    Padding="14 10" Margin="0 0 0 4">
                <StackPanel Orientation="Horizontal">

                    <TextBlock Text="From" VerticalAlignment="Center"
                               FontSize="13" Foreground="#6B7280" Margin="0 0 7 0"/>
                    <DatePicker x:Name="dpFrom" Width="135" Height="32"
                                FontSize="13" Margin="0 0 14 0"
                                VerticalContentAlignment="Center"/>

                    <TextBlock Text="To" VerticalAlignment="Center"
                               FontSize="13" Foreground="#6B7280" Margin="0 0 7 0"/>
                    <DatePicker x:Name="dpTo" Width="135" Height="32"
                                FontSize="13" Margin="0 0 14 0"
                                VerticalContentAlignment="Center"/>

                    <!-- Search -->
                    <Button Content="Search" Width="90" Height="32"
                            Background="#28A745" Foreground="White"
                            FontSize="13" BorderThickness="0" Cursor="Hand"
                            Click="Search_Click">
                        <Button.Template>
                            <ControlTemplate TargetType="Button">
                                <Border Background="{TemplateBinding Background}"
                                        CornerRadius="7">
                                    <ContentPresenter HorizontalAlignment="Center"
                                                      VerticalAlignment="Center"/>
                                </Border>
                            </ControlTemplate>
                        </Button.Template>
                    </Button>

                    <!-- Reset -->
                    <Button Content="Reset" Width="72" Height="32"
                            Background="#F3F4F6" Foreground="#6B7280"
                            FontSize="13" BorderThickness="0" Margin="8 0 0 0"
                            Cursor="Hand" Click="Reset_Click">
                        <Button.Template>
                            <ControlTemplate TargetType="Button">
                                <Border Background="{TemplateBinding Background}"
                                        CornerRadius="7"
                                        BorderBrush="#E5E7EB" BorderThickness="1">
                                    <ContentPresenter HorizontalAlignment="Center"
                                                      VerticalAlignment="Center"/>
                                </Border>
                            </ControlTemplate>
                        </Button.Template>
                    </Button>

                    <TextBlock x:Name="txtFilterLabel"
                               VerticalAlignment="Center"
                               Margin="16 0 0 0"
                               FontSize="12" FontStyle="Italic"
                               Foreground="#9CA3AF"/>
                </StackPanel>
            </Border>

            <!-- ══════════════════════════════════════ -->
            <!-- SECTION 1 — OVERVIEW                  -->
            <!-- ══════════════════════════════════════ -->
            <StackPanel Orientation="Horizontal" Margin="6 20 0 8">
                <Border Width="3" CornerRadius="2" Background="#7F77DD" Margin="0 0 8 0"/>
                <TextBlock Text="OVERVIEW" FontSize="12" FontWeight="SemiBold"
                           Foreground="#6B7280"
                           VerticalAlignment="Center"/>
            </StackPanel>

            <!-- Row 1 — 4 cards -->
            <UniformGrid Columns="4">

                <!-- Total Profit -->
                <Border Style="{StaticResource MetricCard}">
                    <StackPanel>
                        <StackPanel Orientation="Horizontal" Margin="0 0 0 6">
                            <Border Width="3" CornerRadius="2" Background="#7F77DD" Margin="0 0 8 0"/>
                            <TextBlock Text="Total Profit" Style="{StaticResource CardLabel}"
                                       VerticalAlignment="Center"/>
                        </StackPanel>
                        <TextBlock x:Name="txtTotalProfit" Style="{StaticResource CardValue}"
                                   Foreground="#534AB7"/>
                        <TextBlock Text="net after all costs" Style="{StaticResource CardSub}"/>
                    </StackPanel>
                </Border>

                <!-- Cash Balance -->
                <Border Style="{StaticResource MetricCard}">
                    <StackPanel>
                        <StackPanel Orientation="Horizontal" Margin="0 0 0 6">
                            <Border Width="3" CornerRadius="2" Background="#1D9E75" Margin="0 0 8 0"/>
                            <TextBlock Text="Cash Balance" Style="{StaticResource CardLabel}"
                                       VerticalAlignment="Center"/>
                        </StackPanel>
                        <TextBlock x:Name="txtCashBalance" Style="{StaticResource CardValue}"
                                   Foreground="#0F6E56"/>
                        <TextBlock Text="current cash on hand" Style="{StaticResource CardSub}"/>
                    </StackPanel>
                </Border>

                <!-- Account Balance -->
                <Border Style="{StaticResource MetricCard}">
                    <StackPanel>
                        <StackPanel Orientation="Horizontal" Margin="0 0 0 6">
                            <Border Width="3" CornerRadius="2" Background="#378ADD" Margin="0 0 8 0"/>
                            <TextBlock Text="Account Balance" Style="{StaticResource CardLabel}"
                                       VerticalAlignment="Center"/>
                        </StackPanel>
                        <TextBlock x:Name="txtBankBalance" Style="{StaticResource CardValue}"
                                   Foreground="#185FA5"/>
                        <TextBlock Text="current bank balance" Style="{StaticResource CardSub}"/>
                    </StackPanel>
                </Border>

                <!-- Total Balance -->
                <Border Style="{StaticResource MetricCard}">
                    <StackPanel>
                        <StackPanel Orientation="Horizontal" Margin="0 0 0 6">
                            <Border Width="3" CornerRadius="2" Background="#EF9F27" Margin="0 0 8 0"/>
                            <TextBlock Text="Total Balance" Style="{StaticResource CardLabel}"
                                       VerticalAlignment="Center"/>
                        </StackPanel>
                        <TextBlock x:Name="txtTotalBalance" Style="{StaticResource CardValue}"
                                   Foreground="#854F0B"/>
                        <TextBlock Text="cash + bank + vendor cash" Style="{StaticResource CardSub}"/>
                    </StackPanel>
                </Border>

            </UniformGrid>

            <!-- Row 2 — 3 cards -->
            <UniformGrid Columns="3" Margin="0 0 0 4">

                <!-- Vendor Cash -->
                <Border Style="{StaticResource MetricCard}">
                    <StackPanel>
                        <StackPanel Orientation="Horizontal" Margin="0 0 0 6">
                            <Border Width="3" CornerRadius="2" Background="#D85A30" Margin="0 0 8 0"/>
                            <TextBlock Text="Vendor Cash" Style="{StaticResource CardLabel}"
                                       VerticalAlignment="Center"/>
                        </StackPanel>
                        <TextBlock x:Name="txtVendorCash" Style="{StaticResource CardValue}"
                                   Foreground="#993C1D"/>
                        <TextBlock Text="advance held for vendors" Style="{StaticResource CardSub}"/>
                    </StackPanel>
                </Border>

                <!-- Bikes Sold -->
                <Border Style="{StaticResource MetricCard}">
                    <StackPanel>
                        <StackPanel Orientation="Horizontal" Margin="0 0 0 6">
                            <Border Width="3" CornerRadius="2" Background="#534AB7" Margin="0 0 8 0"/>
                            <TextBlock Text="Bikes Sold" Style="{StaticResource CardLabel}"
                                       VerticalAlignment="Center"/>
                        </StackPanel>
                        <TextBlock x:Name="txtBikesSold" Style="{StaticResource CardValue}"
                                   Foreground="#3C3489"/>
                        <TextBlock Text="units sold to customers" Style="{StaticResource CardSub}"/>
                    </StackPanel>
                </Border>

                <!-- Bikes Purchased -->
                <Border Style="{StaticResource MetricCard}">
                    <StackPanel>
                        <StackPanel Orientation="Horizontal" Margin="0 0 0 6">
                            <Border Width="3" CornerRadius="2" Background="#1D9E75" Margin="0 0 8 0"/>
                            <TextBlock Text="Bikes Purchased" Style="{StaticResource CardLabel}"
                                       VerticalAlignment="Center"/>
                        </StackPanel>
                        <TextBlock x:Name="txtBikesPurchased" Style="{StaticResource CardValue}"
                                   Foreground="#085041"/>
                        <TextBlock Text="units from vendors" Style="{StaticResource CardSub}"/>
                    </StackPanel>
                </Border>

            </UniformGrid>

            <!-- DIVIDER -->
            <Border Style="{StaticResource Divider}"/>

            <!-- ══════════════════════════════════════ -->
            <!-- SECTION 2 — INVENTORY                 -->
            <!-- ══════════════════════════════════════ -->
            <StackPanel Orientation="Horizontal" Margin="6 16 0 8">
                <Border Width="3" CornerRadius="2" Background="#1D9E75" Margin="0 0 8 0"/>
                <TextBlock Text="CURRENT INVENTORY" FontSize="12" FontWeight="SemiBold"
                           Foreground="#6B7280"
                           VerticalAlignment="Center"/>
            </StackPanel>

            <UniformGrid Columns="2" Margin="0 0 0 4">

                <!-- Available Bikes -->
                <Border Style="{StaticResource MetricCard}">
                    <StackPanel>
                        <StackPanel Orientation="Horizontal" Margin="0 0 0 6">
                            <Border Width="3" CornerRadius="2" Background="#D4537E" Margin="0 0 8 0"/>
                            <TextBlock Text="Available Bikes" Style="{StaticResource CardLabel}"
                                       VerticalAlignment="Center"/>
                        </StackPanel>
                        <TextBlock x:Name="txtAvailableBikes" Style="{StaticResource CardValue}"
                                   Foreground="#880E4F"/>
                        <TextBlock Text="bikes currently in stock" Style="{StaticResource CardSub}"/>
                    </StackPanel>
                </Border>

                <!-- Inventory Worth -->
                <Border Style="{StaticResource MetricCard}">
                    <StackPanel>
                        <StackPanel Orientation="Horizontal" Margin="0 0 0 6">
                            <Border Width="3" CornerRadius="2" Background="#639922" Margin="0 0 8 0"/>
                            <TextBlock Text="Inventory Worth" Style="{StaticResource CardLabel}"
                                       VerticalAlignment="Center"/>
                        </StackPanel>
                        <TextBlock x:Name="txtInventoryWorth" Style="{StaticResource CardValue}"
                                   Foreground="#3B6D11"/>
                        <TextBlock Text="total value of bikes in stock" Style="{StaticResource CardSub}"/>
                    </StackPanel>
                </Border>

            </UniformGrid>

            <!-- DIVIDER -->
            <Border Style="{StaticResource Divider}"/>

            <!-- ══════════════════════════════════════ -->
            <!-- SECTION 3 — CUSTOMER SALES            -->
            <!-- ══════════════════════════════════════ -->
            <StackPanel Orientation="Horizontal" Margin="6 16 0 8">
                <Border Width="3" CornerRadius="2" Background="#0F6E56" Margin="0 0 8 0"/>
                <TextBlock Text="CUSTOMER SALES" FontSize="12" FontWeight="SemiBold"
                           Foreground="#6B7280"
                           VerticalAlignment="Center"/>
            </StackPanel>

            <UniformGrid Columns="3" Margin="0 0 0 4">

                <Border Style="{StaticResource MetricCard}">
                    <StackPanel>
                        <StackPanel Orientation="Horizontal" Margin="0 0 0 6">
                            <Border Width="3" CornerRadius="2" Background="#378ADD" Margin="0 0 8 0"/>
                            <TextBlock Text="Total Sales" Style="{StaticResource CardLabel}"
                                       VerticalAlignment="Center"/>
                        </StackPanel>
                        <TextBlock x:Name="txtCustomerSales" Style="{StaticResource CardValue}"
                                   Foreground="#185FA5"/>
                        <TextBlock Text="net bill amount" Style="{StaticResource CardSub}"/>
                    </StackPanel>
                </Border>

                <Border Style="{StaticResource MetricCard}">
                    <StackPanel>
                        <StackPanel Orientation="Horizontal" Margin="0 0 0 6">
                            <Border Width="3" CornerRadius="2" Background="#1D9E75" Margin="0 0 8 0"/>
                            <TextBlock Text="Total Paid" Style="{StaticResource CardLabel}"
                                       VerticalAlignment="Center"/>
                        </StackPanel>
                        <TextBlock x:Name="txtCustomerPaid" Style="{StaticResource CardValue}"
                                   Foreground="#0F6E56"/>
                        <TextBlock Text="received from customers" Style="{StaticResource CardSub}"/>
                    </StackPanel>
                </Border>

                <Border Style="{StaticResource MetricCard}">
                    <StackPanel>
                        <StackPanel Orientation="Horizontal" Margin="0 0 0 6">
                            <Border Width="3" CornerRadius="2" Background="#D4537E" Margin="0 0 8 0"/>
                            <TextBlock Text="Remaining Balance" Style="{StaticResource CardLabel}"
                                       VerticalAlignment="Center"/>
                        </StackPanel>
                        <TextBlock x:Name="txtCustomerRemaining" Style="{StaticResource CardValue}"
                                   Foreground="#993556"/>
                        <TextBlock Text="still owed by customers" Style="{StaticResource CardSub}"/>
                    </StackPanel>
                </Border>

            </UniformGrid>

            <!-- DIVIDER -->
            <Border Style="{StaticResource Divider}"/>

            <!-- ══════════════════════════════════════ -->
            <!-- SECTION 4 — VENDOR PURCHASES          -->
            <!-- ══════════════════════════════════════ -->
            <StackPanel Orientation="Horizontal" Margin="6 16 0 8">
                <Border Width="3" CornerRadius="2" Background="#D85A30" Margin="0 0 8 0"/>
                <TextBlock Text="VENDOR PURCHASES" FontSize="12" FontWeight="SemiBold"
                           Foreground="#6B7280"
                           VerticalAlignment="Center"/>
            </StackPanel>

            <UniformGrid Columns="3" Margin="0 0 0 4">

                <Border Style="{StaticResource MetricCard}">
                    <StackPanel>
                        <StackPanel Orientation="Horizontal" Margin="0 0 0 6">
                            <Border Width="3" CornerRadius="2" Background="#378ADD" Margin="0 0 8 0"/>
                            <TextBlock Text="Total Purchase" Style="{StaticResource CardLabel}"
                                       VerticalAlignment="Center"/>
                        </StackPanel>
                        <TextBlock x:Name="txtVendorPurchase" Style="{StaticResource CardValue}"
                                   Foreground="#185FA5"/>
                        <TextBlock Text="total billed by vendors" Style="{StaticResource CardSub}"/>
                    </StackPanel>
                </Border>

                <Border Style="{StaticResource MetricCard}">
                    <StackPanel>
                        <StackPanel Orientation="Horizontal" Margin="0 0 0 6">
                            <Border Width="3" CornerRadius="2" Background="#1D9E75" Margin="0 0 8 0"/>
                            <TextBlock Text="Amount Paid" Style="{StaticResource CardLabel}"
                                       VerticalAlignment="Center"/>
                        </StackPanel>
                        <TextBlock x:Name="txtVendorPaid" Style="{StaticResource CardValue}"
                                   Foreground="#0F6E56"/>
                        <TextBlock Text="paid to vendors" Style="{StaticResource CardSub}"/>
                    </StackPanel>
                </Border>

                <Border Style="{StaticResource MetricCard}">
                    <StackPanel>
                        <StackPanel Orientation="Horizontal" Margin="0 0 0 6">
                            <Border Width="3" CornerRadius="2" Background="#D4537E" Margin="0 0 8 0"/>
                            <TextBlock Text="Remaining Balance" Style="{StaticResource CardLabel}"
                                       VerticalAlignment="Center"/>
                        </StackPanel>
                        <TextBlock x:Name="txtVendorRemaining" Style="{StaticResource CardValue}"
                                   Foreground="#993556"/>
                        <TextBlock Text="still owed to vendors" Style="{StaticResource CardSub}"/>
                    </StackPanel>
                </Border>

            </UniformGrid>

            <!-- DIVIDER -->
            <Border Style="{StaticResource Divider}"/>

            <!-- SECTION 5 — ZAKAT CALCULATION -->
            <StackPanel Orientation="Horizontal" Margin="6 16 0 8">
                <Border Width="3" CornerRadius="2" Background="#7F77DD" Margin="0 0 8 0"/>
                <TextBlock Text="ZAKAT CALCULATION" FontSize="12" FontWeight="SemiBold"
                           Foreground="#6B7280" VerticalAlignment="Center"/>
                <TextBlock Text="  — 2.5% on net zakatable wealth"
                           FontSize="11" Foreground="#9CA3AF" VerticalAlignment="Center"/>
            </StackPanel>

            <!-- Editable Inputs -->
            <Border Background="White" CornerRadius="10"
                    BorderBrush="#E8E8E8" BorderThickness="1"
                    Padding="16 14" Margin="5 0 5 6">
                <Grid>
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="*"/>
                    </Grid.ColumnDefinitions>
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="Auto"/>
                    </Grid.RowDefinitions>

                    <TextBlock Grid.Row="0" Grid.ColumnSpan="2"
                               Text="Editable inputs — auto-filled from report, adjust if needed"
                               FontSize="11" Foreground="#9CA3AF" Margin="0 0 0 10"/>

                    <StackPanel Grid.Row="1" Grid.Column="0" Margin="0 4 8 4">
                        <TextBlock Text="Cash on hand" FontSize="11" Foreground="#6B7280" Margin="0 0 0 3"/>
                        <TextBox x:Name="txtZakatCash" FontSize="13" Height="32"
                                 Padding="8 0" VerticalContentAlignment="Center"
                                 BorderBrush="#E0E0E0" BorderThickness="1"/>
                    </StackPanel>
                    <StackPanel Grid.Row="1" Grid.Column="1" Margin="8 4 0 4">
                        <TextBlock Text="Bank / account balance" FontSize="11" Foreground="#6B7280" Margin="0 0 0 3"/>
                        <TextBox x:Name="txtZakatBank" FontSize="13" Height="32"
                                 Padding="8 0" VerticalContentAlignment="Center"
                                 BorderBrush="#E0E0E0" BorderThickness="1"/>
                    </StackPanel>

                    <StackPanel Grid.Row="2" Grid.Column="0" Margin="0 4 8 4">
                        <TextBlock Text="Inventory worth (trade stock)" FontSize="11" Foreground="#6B7280" Margin="0 0 0 3"/>
                        <TextBox x:Name="txtZakatInventory" FontSize="13" Height="32"
                                 Padding="8 0" VerticalContentAlignment="Center"
                                 BorderBrush="#E0E0E0" BorderThickness="1"/>
                    </StackPanel>
                    <StackPanel Grid.Row="2" Grid.Column="1" Margin="8 4 0 4">
                        <TextBlock Text="Customer receivables (collectable)" FontSize="11" Foreground="#6B7280" Margin="0 0 0 3"/>
                        <TextBox x:Name="txtZakatReceivable" FontSize="13" Height="32"
                                 Padding="8 0" VerticalContentAlignment="Center"
                                 BorderBrush="#E0E0E0" BorderThickness="1"/>
                    </StackPanel>

                    <StackPanel Grid.Row="3" Grid.Column="0" Margin="0 4 8 4">
                        <TextBlock Text="Less: amount owed to vendors" FontSize="11" Foreground="#EF4444" Margin="0 0 0 3"/>
                        <TextBox x:Name="txtZakatVendorDue" FontSize="13" Height="32"
                                 Padding="8 0" VerticalContentAlignment="Center"
                                 BorderBrush="#FECACA" BorderThickness="1"/>
                    </StackPanel>
                    <StackPanel Grid.Row="3" Grid.Column="1" Margin="8 4 0 4">
                        <TextBlock Text="Nisab threshold (85g gold in ₨)" FontSize="11" Foreground="#6B7280" Margin="0 0 0 3"/>
                        <TextBox x:Name="txtZakatNisab" FontSize="13" Height="32"
                                 Padding="8 0" VerticalContentAlignment="Center"
                                 BorderBrush="#E0E0E0" BorderThickness="1"
                                 Text="170000"/>
                    </StackPanel>

                    <Button Grid.Row="4" Grid.ColumnSpan="2"
                            Content="Calculate Zakat"
                            HorizontalAlignment="Left"
                            Width="150" Height="34"
                            Margin="0 12 0 0"
                            Background="#534AB7" Foreground="White"
                            FontSize="13" BorderThickness="0"
                            Cursor="Hand"
                            Click="CalculateZakat_Click">
                        <Button.Template>
                            <ControlTemplate TargetType="Button">
                                <Border Background="{TemplateBinding Background}" CornerRadius="7">
                                    <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                                </Border>
                            </ControlTemplate>
                        </Button.Template>
                    </Button>

                </Grid>
            </Border>

            <!-- Breakdown -->
            <Border Background="White" CornerRadius="10"
                    BorderBrush="#E8E8E8" BorderThickness="1"
                    Padding="16 14" Margin="5 0 5 6">
                <StackPanel>

                    <TextBlock Text="Breakdown" FontSize="12" FontWeight="SemiBold"
                               Foreground="#6B7280" Margin="0 0 0 10"/>

                    <Grid Margin="0 0 0 5">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="Auto"/>
                        </Grid.ColumnDefinitions>
                        <TextBlock Text="Cash on hand" FontSize="13" Foreground="#374151"/>
                        <TextBlock x:Name="txtZkCash" Grid.Column="1" FontSize="13" FontWeight="SemiBold" Foreground="#0F6E56"/>
                    </Grid>

                    <Grid Margin="0 0 0 5">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="Auto"/>
                        </Grid.ColumnDefinitions>
                        <TextBlock Text="Bank / account balance" FontSize="13" Foreground="#374151"/>
                        <TextBlock x:Name="txtZkBank" Grid.Column="1" FontSize="13" FontWeight="SemiBold" Foreground="#0F6E56"/>
                    </Grid>

                    <Grid Margin="0 0 0 5">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="Auto"/>
                        </Grid.ColumnDefinitions>
                        <TextBlock Text="Inventory worth" FontSize="13" Foreground="#374151"/>
                        <TextBlock x:Name="txtZkInventory" Grid.Column="1" FontSize="13" FontWeight="SemiBold" Foreground="#0F6E56"/>
                    </Grid>

                    <Grid Margin="0 0 0 5">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="Auto"/>
                        </Grid.ColumnDefinitions>
                        <TextBlock Text="Customer receivables" FontSize="13" Foreground="#374151"/>
                        <TextBlock x:Name="txtZkReceivable" Grid.Column="1" FontSize="13" FontWeight="SemiBold" Foreground="#0F6E56"/>
                    </Grid>

                    <Border Background="#FEF2F2" CornerRadius="6" Padding="10 7" Margin="0 4 0 6">
                        <Grid>
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*"/>
                                <ColumnDefinition Width="Auto"/>
                            </Grid.ColumnDefinitions>
                            <StackPanel>
                                <TextBlock Text="Less: amount owed to vendors" FontSize="13" Foreground="#374151"/>
                                <TextBlock Text="liability deducted from zakatable wealth" FontSize="10" Foreground="#9CA3AF"/>
                            </StackPanel>
                            <TextBlock x:Name="txtZkVendorDue" Grid.Column="1" FontSize="13" FontWeight="SemiBold" Foreground="#A32D2D"/>
                        </Grid>
                    </Border>

                    <Border BorderBrush="#F0F0F0" BorderThickness="0 0 0 1" Margin="0 4 0 8"/>

                    <Grid Margin="0 0 0 5">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="Auto"/>
                        </Grid.ColumnDefinitions>
                        <TextBlock Text="Net zakatable wealth" FontSize="13" FontWeight="SemiBold" Foreground="#374151"/>
                        <TextBlock x:Name="txtZkTotal" Grid.Column="1" FontSize="14" FontWeight="SemiBold" Foreground="#374151"/>
                    </Grid>

                    <Grid Margin="0 0 0 5">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="Auto"/>
                        </Grid.ColumnDefinitions>
                        <TextBlock Text="Nisab threshold" FontSize="13" Foreground="#6B7280"/>
                        <TextBlock x:Name="txtZkNisabDisplay" Grid.Column="1" FontSize="13" Foreground="#6B7280"/>
                    </Grid>

                    <Grid>
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="Auto"/>
                        </Grid.ColumnDefinitions>
                        <TextBlock Text="Zakat applicable?" FontSize="13" Foreground="#6B7280"/>
                        <TextBlock x:Name="txtZkApplicable" Grid.Column="1" FontSize="13" FontWeight="SemiBold"/>
                    </Grid>

                </StackPanel>
            </Border>

            <!-- Zakat Due Highlight -->
            <Border CornerRadius="10" Background="#EEEDFE"
                    BorderBrush="#AFA9EC" BorderThickness="1"
                    Padding="18 14" Margin="5 0 5 6">
                <Grid>
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="Auto"/>
                    </Grid.ColumnDefinitions>
                    <StackPanel>
                        <TextBlock Text="Zakat Due (2.5%)"
                                   FontSize="14" FontWeight="SemiBold" Foreground="#534AB7"/>
                        <TextBlock Text="payable once per lunar year (hawl)"
                                   FontSize="11" Foreground="#7F77DD" Margin="0 2 0 0"/>
                    </StackPanel>
                    <TextBlock x:Name="txtZakatDue" Grid.Column="1"
                               FontSize="26" FontWeight="Bold"
                               Foreground="#3C3489" VerticalAlignment="Center"/>
                </Grid>
            </Border>

            <!-- Info Note -->
            <Border Background="#F8F9FA" CornerRadius="8"
                    BorderBrush="#E8E8E8" BorderThickness="1"
                    Padding="14 10" Margin="5 0 5 10">
                <TextBlock FontSize="11" Foreground="#6B7280"
                           TextWrapping="Wrap" LineHeight="18">
                    <Run FontWeight="SemiBold" Foreground="#374151">How this is calculated: </Run>
                    <Run>Zakat = (Cash + Bank + Inventory + Receivables − Vendor Dues) × 2.5%, provided the total exceeds the nisab. Nisab is based on 85g of gold — update the nisab field to today's gold price in PKR. Vendor cash advance is excluded as it is a liability owed to others. Zakat is due once per lunar year on wealth held above nisab for a full year (hawl).</Run>
                </TextBlock>
            </Border>

