<Page x:Class="Ramza_EBike_Swabi.Views.Pages.VendorPaymentHistoryPage"
      xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
      xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
      Background="#F4F6F9">

    <Grid Margin="20">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
        </Grid.RowDefinitions>

        <!-- TOP BAR -->
        <StackPanel Grid.Row="0" Orientation="Horizontal"
                    VerticalAlignment="Center" Margin="0 0 0 16">
            <Button Content="Back" Width="100" Height="35" FontWeight="Bold"
                    Background="#FF2B579A" Foreground="White"
                    BorderThickness="0" Cursor="Hand" Click="Back_Click"/>
            <TextBlock x:Name="PageTitle"
                       FontSize="24" FontWeight="Bold" Margin="15 0"/>
        </StackPanel>

        <!-- DATE RANGE & EXPORT -->
        <StackPanel Grid.Row="1" Orientation="Horizontal"
                    HorizontalAlignment="Right" Margin="0,0,0,12">
            <TextBlock Text="From:" VerticalAlignment="Center" Margin="0,0,8,0" FontWeight="SemiBold"/>
            <DatePicker x:Name="FromDatePicker" Width="140" Height="30" Margin="0,0,12,0"/>

            <TextBlock Text="To:" VerticalAlignment="Center" Margin="0,0,8,0" FontWeight="SemiBold"/>
            <DatePicker x:Name="ToDatePicker" Width="140" Height="30" Margin="0,0,12,0"/>

            <Button Content="Filter" Width="80" Height="30"
                    Background="#2B579A" Foreground="White"
                    Click="Filter_Click" Margin="0,0,8,0"/>

            <Button Content="Clear Filter" Width="90" Height="30"
                    Background="#6C757D" Foreground="White"
                    Click="ClearFilter_Click" Margin="0,0,8,0"/>

            <Button Content="Export to Excel" Width="120" Height="30"
                    Background="#28A745" Foreground="White"
                    Click="ExportToExcel_Click"/>
        </StackPanel>

        <!-- SUMMARY CARD -->
        <Border Grid.Row="2" Background="White" CornerRadius="8"
                Padding="16 14" Margin="0 0 0 16"
                BorderBrush="#E0E0E0" BorderThickness="1">
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="*"/>
                </Grid.ColumnDefinitions>

                <StackPanel Grid.Column="0">
                    <TextBlock Text="Total Paid to Vendor" FontSize="11" Foreground="#777"/>
                    <TextBlock x:Name="TotalPaidText"
                               FontSize="20" FontWeight="Bold" Foreground="#1B4079"/>
                </StackPanel>

                <StackPanel Grid.Column="1">
                    <TextBlock Text="Number of Payments" FontSize="11" Foreground="#777"/>
                    <TextBlock x:Name="PaymentCountText"
                               FontSize="20" FontWeight="Bold" Foreground="#555"/>
                </StackPanel>

                <StackPanel Grid.Column="2">
                    <TextBlock Text="Last Payment" FontSize="11" Foreground="#777"/>
                    <TextBlock x:Name="LastPaymentText"
                               FontSize="14" FontWeight="SemiBold" Foreground="#333"/>
                </StackPanel>

                <StackPanel Grid.Column="3">
                    <TextBlock Text="Current Remaining Balance" FontSize="11" Foreground="#777"/>
                    <TextBlock x:Name="CurrentRemainingText"
                               FontSize="20" FontWeight="Bold" Foreground="#B00020"/>
                </StackPanel>
            </Grid>
        </Border>

        <!-- PAYMENT HISTORY GRID -->
        <DataGrid x:Name="PaymentsGrid" Grid.Row="3"
                  AutoGenerateColumns="False" HeadersVisibility="Column"
                  SelectionMode="Single" CanUserAddRows="False"
                  IsReadOnly="True"
                  AlternatingRowBackground="#F9F9F9" RowHeight="36">
            <DataGrid.Columns>
                <DataGridTextColumn Header="#"
                                    Binding="{Binding Id}"
                                    Width="55"/>
                <DataGridTextColumn Header="Payment Date"
                                    Binding="{Binding PaymentDate, StringFormat={}{0:dd-MMM-yyyy hh:mm tt}}"
                                    Width="175"/>
                <DataGridTextColumn Header="Amount Paid (PKR)"
                                    Binding="{Binding AmountPaid, StringFormat=N2}"
                                    Width="145" FontWeight="Bold"/>
                <DataGridTextColumn Header="Balance Before"
                                    Binding="{Binding BalanceBefore, StringFormat=N2}"
                                    Width="130"/>
                <DataGridTextColumn Header="Balance After"
                                    Binding="{Binding BalanceAfter, StringFormat=N2}"
                                    Width="130"/>
                <DataGridTextColumn Header="Source"
                                    Binding="{Binding PaymentSource}"
                                    Width="100"/>
                <DataGridTextColumn Header="Paid To"
                                    Binding="{Binding PaidTo}"
                                    Width="130"/>
                <DataGridTextColumn Header="Remarks"
                                    Binding="{Binding Remarks}"
                                    Width="*"/>

                <!-- ACTIONS COLUMN -->
                <DataGridTemplateColumn Header="Actions" Width="160">
                    <DataGridTemplateColumn.CellTemplate>
                        <DataTemplate>
                            <StackPanel Orientation="Horizontal" HorizontalAlignment="Center"
                                        VerticalAlignment="Center">
                                <Button Content="Edit"
                                        Width="65" Height="26" Margin="0 0 6 0"
                                        Background="#FF1E88E5" Foreground="White"
                                        FontSize="12" FontWeight="SemiBold"
                                        BorderThickness="0" Cursor="Hand"
                                        Tag="{Binding}"
                                        Click="EditPayment_Click"/>
                                <Button Content="Delete"
                                        Width="65" Height="26"
                                        Background="#FFC62828" Foreground="White"
                                        FontSize="12" FontWeight="SemiBold"
                                        BorderThickness="0" Cursor="Hand"
                                        Tag="{Binding}"
                                        Click="DeletePayment_Click"/>
                            </StackPanel>
                        </DataTemplate>
                    </DataGridTemplateColumn.CellTemplate>
                </DataGridTemplateColumn>

            </DataGrid.Columns>
        </DataGrid>
    </Grid>
</Page>
