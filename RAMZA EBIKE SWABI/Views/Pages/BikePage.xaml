<Page x:Class="Ramza_EBike_Swabi.Views.Pages.BikePage"
      xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
      xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
      Title="BikePage" Background="#FFF4F6F8">

    <Grid Margin="18">

        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
        </Grid.RowDefinitions>

        <!-- Header + Back -->
        <Grid Margin="0 0 0 15" VerticalAlignment="Center">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="Auto"/>
                <ColumnDefinition Width="*"/>
                <ColumnDefinition Width="Auto"/>
            </Grid.ColumnDefinitions>

            <Button Grid.Column="0"
                    Content="← Back"
                    Width="100" Height="35"
                    FontWeight="Bold"
                    Background="#FF2B579A" Foreground="White"
                    BorderThickness="0" Cursor="Hand"
                    Click="Back_Click"/>

            <TextBlock Grid.Column="1"
                       Text="Bikes"
                       FontSize="26" FontWeight="Bold"
                       HorizontalAlignment="Center"
                       VerticalAlignment="Center"/>
        </Grid>

        <!-- Search + Print -->
        <StackPanel Grid.Row="1" Orientation="Horizontal"
                    HorizontalAlignment="Right" Margin="0,0,0,12">
            <TextBox x:Name="SearchBox" Width="280" Height="30"
                     Margin="0,0,8,0" TextChanged="SearchBox_TextChanged"/>
            <Button Content="Search" Width="90" Height="30"
                    Background="#2B579A" Foreground="White"
                    Click="Search_Click"/>
            <Button Content="Print List" Width="100" Height="30"
                    Margin="8,0,0,0" Background="#6F42C1" Foreground="White"
                    Click="PrintList_Click"/>
        </StackPanel>

        <!-- DataGrid -->
        <DataGrid x:Name="BikesGrid"
                  Grid.Row="2"
                  AutoGenerateColumns="False"
                  IsReadOnly="True"
                  AlternatingRowBackground="#E9EEF7"
                  CanUserAddRows="False"
                  RowHeight="40"
                  SelectionMode="Single"
                  HorizontalAlignment="Stretch"
                  VerticalAlignment="Stretch"
                  ColumnWidth="*">

            <DataGrid.Columns>
                <DataGridTextColumn Header="ID" Binding="{Binding BikeId}" Width="50">
                    <DataGridTextColumn.ElementStyle>
                        <Style TargetType="TextBlock">
                            <Setter Property="HorizontalAlignment" Value="Center"/>
                        </Style>
                    </DataGridTextColumn.ElementStyle>
                </DataGridTextColumn>

                <DataGridTextColumn Header="Model"       Binding="{Binding Model}"/>
                <DataGridTextColumn Header="Brand"       Binding="{Binding Brand}"/>
                <DataGridTextColumn Header="Motor Power" Binding="{Binding MotorPower}"/>
                <DataGridTextColumn Header="Motor No."   Binding="{Binding MotorNumber}"/>
                <DataGridTextColumn Header="Chassis No." Binding="{Binding ChassisNumber}"/>
                <DataGridTextColumn Header="Battery"     Binding="{Binding BatteryCapacity}"/>
                <DataGridTextColumn Header="Color"       Binding="{Binding Color}"/>

                <DataGridTextColumn Header="Warranty" Binding="{Binding Warranty}" Width="80">
                    <DataGridTextColumn.ElementStyle>
                        <Style TargetType="TextBlock">
                            <Setter Property="HorizontalAlignment" Value="Center"/>
                        </Style>
                    </DataGridTextColumn.ElementStyle>
                </DataGridTextColumn>

                <DataGridTextColumn Header="Qty" Binding="{Binding Quantity}" Width="50">
                    <DataGridTextColumn.ElementStyle>
                        <Style TargetType="TextBlock">
                            <Setter Property="HorizontalAlignment" Value="Center"/>
                        </Style>
                    </DataGridTextColumn.ElementStyle>
                </DataGridTextColumn>

                <DataGridTextColumn Header="Price (PKR)"
                                    Binding="{Binding Price, StringFormat=PKR {0:N2}}"/>
                <DataGridTextColumn Header="Vendor" Binding="{Binding VendorName}"/>

                <!-- Only Show QR remains -->
                <DataGridTemplateColumn Header="Actions" Width="160">
                    <DataGridTemplateColumn.CellTemplate>
                        <DataTemplate>
                            <StackPanel Orientation="Horizontal" HorizontalAlignment="Center">
                                <Button Content="Show QR" Width="70" Margin="2"
                        Background="#2B579A" Foreground="White"
                        Click="QR_Click"/>

                                <Button Content="Delete" Width="70" Margin="2"
                        Background="#DC3545" Foreground="White"
                        Click="Delete_Click"/>
                            </StackPanel>
                        </DataTemplate>
                    </DataGridTemplateColumn.CellTemplate>
                </DataGridTemplateColumn>

            </DataGrid.Columns>
        </DataGrid>

    </Grid>
</Page>