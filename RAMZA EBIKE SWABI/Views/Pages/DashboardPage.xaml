<Page x:Class="Ramza_EBike_Swabi.Views.Pages.DashboardPage"
      xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
      xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
      Background="#F5F6FA">

    <Page.Resources>
        <Style x:Key="CardBtn" TargetType="Button">
            <Setter Property="Width" Value="168"/>
            <Setter Property="Height" Value="120"/>
            <Setter Property="Margin" Value="10"/>
            <Setter Property="Background" Value="White"/>
            <Setter Property="BorderThickness" Value="0"/>
            <Setter Property="Cursor" Value="Hand"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border x:Name="bd" CornerRadius="12"
                                Background="{TemplateBinding Background}">
                            <Border.Effect>
                                <DropShadowEffect BlurRadius="10" ShadowDepth="2" Opacity="0.18"/>
                            </Border.Effect>
                            <ContentPresenter HorizontalAlignment="Center"
                                              VerticalAlignment="Center"/>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="bd" Property="Background" Value="#EEF2FF"/>
                            </Trigger>
                            <Trigger Property="IsPressed" Value="True">
                                <Setter TargetName="bd" Property="RenderTransform">
                                    <Setter.Value>
                                        <ScaleTransform ScaleX="0.97" ScaleY="0.97"/>
                                    </Setter.Value>
                                </Setter>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>
        <Style x:Key="CardLabel" TargetType="TextBlock">
            <Setter Property="FontSize" Value="13"/>
            <Setter Property="FontWeight" Value="SemiBold"/>
            <Setter Property="Foreground" Value="#1F2937"/>
            <Setter Property="Margin" Value="0 7 0 0"/>
            <Setter Property="TextAlignment" Value="Center"/>
        </Style>
    </Page.Resources>

    <Grid>
        <StackPanel HorizontalAlignment="Center" VerticalAlignment="Center">

            <TextBlock Text="Dashboard"
                       FontSize="28" FontWeight="Bold"
                       Foreground="#111827"
                       HorizontalAlignment="Center"
                       Margin="0 0 0 22"/>

            <!-- Row 1 -->
            <StackPanel Orientation="Horizontal" HorizontalAlignment="Center">

                <Button Style="{StaticResource CardBtn}" Click="Bikes_Click">
                    <StackPanel>
                        <TextBlock Text="🚲" FontSize="36" HorizontalAlignment="Center" Margin="0,8,0,4"/>
                        <TextBlock Text="Bikes" Style="{StaticResource CardLabel}"/>
                    </StackPanel>
                </Button>

                <Button Style="{StaticResource CardBtn}" Click="Vendors_Click">
                    <StackPanel>
                        <TextBlock Text="🏪" FontSize="36" HorizontalAlignment="Center" Margin="0,8,0,4"/>
                        <TextBlock Text="Vendors" Style="{StaticResource CardLabel}"/>
                    </StackPanel>
                </Button>

                <Button Style="{StaticResource CardBtn}" Click="Invoice_Click">
                    <StackPanel>
                        <TextBlock Text="📄" FontSize="36" HorizontalAlignment="Center" Margin="0,8,0,4"/>
                        <TextBlock Text="Generate Invoice" Style="{StaticResource CardLabel}"/>
                    </StackPanel>
                </Button>

                <Button Style="{StaticResource CardBtn}" Click="Account_Click">
                    <StackPanel>
                        <TextBlock Text="🏦" FontSize="36" HorizontalAlignment="Center" Margin="0,8,0,4"/>
                        <TextBlock Text="Bank Account" Style="{StaticResource CardLabel}"/>
                    </StackPanel>
                </Button>

                <Button Style="{StaticResource CardBtn}" Click="SearchInvoice_Click">
                    <StackPanel>
                        <TextBlock Text="🔍" FontSize="36" HorizontalAlignment="Center" Margin="0,8,0,4"/>
                        <TextBlock Text="Search Invoice" Style="{StaticResource CardLabel}"/>
                    </StackPanel>
                </Button>

            </StackPanel>

            <!-- Row 2 -->
            <StackPanel Orientation="Horizontal" HorizontalAlignment="Center">

                <Button Style="{StaticResource CardBtn}" Click="Dues_Click">
                    <StackPanel>
                        <TextBlock Text="💰" FontSize="36" HorizontalAlignment="Center" Margin="0,8,0,4"/>
                        <TextBlock Text="Customer Dues" Style="{StaticResource CardLabel}"/>
                    </StackPanel>
                </Button>

                <Button Style="{StaticResource CardBtn}" Click="Report_Click">
                    <StackPanel>
                        <TextBlock Text="📊" FontSize="36" HorizontalAlignment="Center" Margin="0,8,0,4"/>
                        <TextBlock Text="Sales Report" Style="{StaticResource CardLabel}"/>
                    </StackPanel>
                </Button>

                <!-- Add Cash -->
                <Button Style="{StaticResource CardBtn}" Click="AddCash_Click">
                    <StackPanel>
                        <TextBlock Text="💵" FontSize="36" HorizontalAlignment="Center" Margin="0,8,0,4"
                                   Foreground="#1B4079"/>
                        <TextBlock Text="Add Cash to Vendor"
                                   Style="{StaticResource CardLabel}"
                                   Foreground="#1B4079"/>
                    </StackPanel>
                </Button>

                <!-- Vendor Incentives -->
                <Button Style="{StaticResource CardBtn}" Click="Incentives_Click">
                    <StackPanel>
                        <TextBlock Text="🎁" FontSize="36" HorizontalAlignment="Center" Margin="0,8,0,4"
                                   Foreground="#6A1B9A"/>
                        <TextBlock Text="Vendor Incentives"
                                   Style="{StaticResource CardLabel}"
                                   Foreground="#6A1B9A"/>
                    </StackPanel>
                </Button>
                <Button Style="{StaticResource CardBtn}" Click="Tracking_Click">
                    <StackPanel>
                        <TextBlock Text="📋" FontSize="36" HorizontalAlignment="Center" Margin="0,8,0,4"/>
                        <TextBlock Text="Document Tracking" Style="{StaticResource CardLabel}"/>
                    </StackPanel>
                </Button>
                <Button Style="{StaticResource CardBtn}" Click="Zakat_Click">
                    <StackPanel>
                        <TextBlock Text="☪" FontSize="36" HorizontalAlignment="Center" Margin="0,8,0,4"
                   Foreground="#534AB7"/>
                        <TextBlock Text="Zakat" Style="{StaticResource CardLabel}"
                   Foreground="#534AB7"/>
                    </StackPanel>
                </Button>
            </StackPanel>

        </StackPanel>
    </Grid>
</Page>