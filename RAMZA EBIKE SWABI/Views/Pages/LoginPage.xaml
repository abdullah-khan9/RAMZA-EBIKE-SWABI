<Page x:Class="Ramza_EBike_Swabi.Views.Pages.LoginPage"
      xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
      xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
      Title="Login">

    <Grid Background="#F5F6FA">

        <Border Width="420"
                Padding="30"
                Background="White"
                CornerRadius="12"
                HorizontalAlignment="Center"
                VerticalAlignment="Center">

            <Border.Effect>
                <DropShadowEffect BlurRadius="20"
                                  ShadowDepth="2"
                                  Opacity="0.25"/>
            </Border.Effect>

            <StackPanel>

                <!-- ✅ TOP IMAGE -->

                <!-- TITLE -->
                <!-- ✅ TOP IMAGE -->
                <Image Source="/Resources/logo.png"
                       Height="131"
                       Width="180"
                       />

                <!-- TITLE -->
                <TextBlock Text="Swabi Enterprises"
                           FontSize="24"
                           FontWeight="Bold"
                           HorizontalAlignment="Center"
                           Margin="0,5"/>

                <TextBlock Text="Sign in to continue"
                           FontSize="13"
                           Foreground="Gray"
                           HorizontalAlignment="Center"
                           Margin="0,0,0,20"/>

                <!-- USERNAME -->
                <TextBlock Text="Username"
                           Margin="0,5,0,2"/>

                <TextBox x:Name="UsernameBox"
                         Height="36"
                         Padding="8"
                         Background="#F1F2F6"
                         BorderThickness="0"
                         Margin="0,0,0,10"/>

                <!-- PASSWORD -->
                <TextBlock Text="Password"
                           Margin="0,5,0,2"/>

                <PasswordBox x:Name="PasswordBox"
                             Height="36"
                             Padding="8"
                             Background="#F1F2F6"
                             BorderThickness="0"
                             Margin="0,0,0,5"/>

                <!-- STATUS -->
                <TextBlock x:Name="StatusText"
                           Foreground="#E84118"
                           FontSize="12"
                           Margin="0,5"/>

                <!-- BUTTONS -->
                <StackPanel Orientation="Horizontal"
                            HorizontalAlignment="Center"
                            Margin="0,15,0,0">

                    <Button Content="Login"
                            Width="140"
                            Height="38"
                            Margin="0,0,10,0"
                            Background="#008000"
                            Foreground="White"
                            BorderThickness="0"
                            FontWeight="SemiBold"
                            Click="Login_Click"/>

                    <Button Content="Register"
                            Width="140"
                            Height="38"
                            Background="#00A8FF"
                            Foreground="White"
                            BorderThickness="0"
                            FontWeight="SemiBold"
                            Click="Register_Click"/>

                </StackPanel>

            </StackPanel>
        </Border>
    </Grid>
</Page>
