<Page x:Class="Ramza_EBike_Swabi.Views.Pages.RegisterPage"
      xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
      xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
      Title="Register">

    <Grid Background="#F5F6FA">

        <Border Width="420"
                Padding="30"
                Background="White"
                CornerRadius="12"
                HorizontalAlignment="Center"
                VerticalAlignment="Center">

            <Border.Effect>
                <DropShadowEffect BlurRadius="20"
                                  ShadowDepth="2"
                                  Opacity="0.25"/>
            </Border.Effect>

            <StackPanel>

                <!-- TITLE -->
                <TextBlock Text="Create Account"
                           FontSize="24"
                           FontWeight="Bold"
                           HorizontalAlignment="Center"
                           Margin="0,5"/>

                <TextBlock Text="Register a new user"
                           FontSize="13"
                           Foreground="Gray"
                           HorizontalAlignment="Center"
                           Margin="0,0,0,20"/>

                <!-- FULL NAME -->
                <TextBlock Text="Full Name"
                           Margin="0,5,0,2"/>

                <TextBox x:Name="FullNameBox"
                         Height="36"
                         Padding="8"
                         Background="#F1F2F6"
                         BorderThickness="0"
                         Margin="0,0,0,10"/>

                <!-- USERNAME -->
                <TextBlock Text="Username"
                           Margin="0,5,0,2"/>

                <TextBox x:Name="UsernameBox"
                         Height="36"
                         Padding="8"
                         Background="#F1F2F6"
                         BorderThickness="0"
                         Margin="0,0,0,10"/>

                <!-- PASSWORD -->
                <TextBlock Text="Password"
                           Margin="0,5,0,2"/>

                <PasswordBox x:Name="PasswordBox"
                             Height="36"
                             Padding="8"
                             Background="#F1F2F6"
                             BorderThickness="0"
                             Margin="0,0,0,10"/>

                <!-- CONFIRM PASSWORD -->
                <TextBlock Text="Confirm Password"
                           Margin="0,5,0,2"/>

                <PasswordBox x:Name="ConfirmPasswordBox"
                             Height="36"
                             Padding="8"
                             Background="#F1F2F6"
                             BorderThickness="0"
                             Margin="0,0,0,10"/>

                <!-- ROLE -->
                <TextBlock Text="Role"
                           Margin="0,5,0,2"/>

                <ComboBox x:Name="RoleBox"
                          Height="36"
                          Background="#F1F2F6"
                          BorderThickness="0"
                          Margin="0,0,0,5"
                          SelectedIndex="0">

                    <ComboBoxItem Content="Admin"/>
                    <ComboBoxItem Content="SalesPerson"/>

                </ComboBox>

                <!-- STATUS -->
                <TextBlock x:Name="StatusText"
                           Foreground="#E84118"
                           FontSize="12"
                           Margin="0,5"
                           TextWrapping="Wrap"/>

                <!-- BUTTONS -->
                <StackPanel Orientation="Horizontal"
                            HorizontalAlignment="Center"
                            Margin="0,15,0,0">

                    <Button Content="Create"
                            Width="140"
                            Height="38"
                            Margin="0,0,10,0"
                            Background="#008000"
                            Foreground="White"
                            BorderThickness="0"
                            FontWeight="SemiBold"
                            Click="Create_Click"/>

                    <Button Content="Back to Login"
                            Width="140"
                            Height="38"
                            Background="#00A8FF"
                            Foreground="White"
                            BorderThickness="0"
                            FontWeight="SemiBold"
                            Click="Back_Click"/>

                </StackPanel>

            </StackPanel>
        </Border>
    </Grid>
</Page>
