<Window x:Class="Ramza_EBike_Swabi.Views.Pages.QRCodeWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Bike QR Code" Height="550" Width="400"
        WindowStartupLocation="CenterOwner"
        ResizeMode="NoResize">
    <Grid Margin="12">
        <StackPanel HorizontalAlignment="Center">

            <!-- Title -->
            <TextBlock x:Name="TitleText" FontSize="18" FontWeight="Bold" 
                       Margin="0,0,0,12" TextAlignment="Center"/>

            <!-- QR Code Image -->
            <Border BorderBrush="Gray" BorderThickness="1" Padding="5">
                <Image x:Name="QrImage" Width="300" Height="300"/>
            </Border>

            <!-- Print and Close Buttons -->
            <StackPanel Orientation="Horizontal" HorizontalAlignment="Center" Margin="0,12,0,0">
                <Button Content="Print" Width="100" Margin="6" Click="Print_Click" Background="#28A745" Foreground="White"/>
                <Button Content="Close" Width="100" Margin="6" Click="Close_Click"/>
            </StackPanel>

            <!-- Page Size Selection -->
            <StackPanel Orientation="Horizontal" HorizontalAlignment="Center" Margin="0,12,0,0">
                <TextBlock Text="Page Size:" VerticalAlignment="Center" Margin="0,0,6,0"/>
                <ComboBox x:Name="PageSizeCombo" Width="120">
                    <ComboBoxItem Content="A4" IsSelected="True"/>
                    <ComboBoxItem Content="A5"/>
                </ComboBox>
            </StackPanel>

            <!-- Rows x Columns -->
            <StackPanel Orientation="Horizontal" HorizontalAlignment="Center" Margin="0,6,0,0">
                <TextBlock Text="Copies (rows x cols):" VerticalAlignment="Center" Margin="0,0,6,0"/>
                <TextBox x:Name="RowsBox" Width="30" Text="2"/>
                <TextBlock Text="x" VerticalAlignment="Center" Margin="4,0"/>
                <TextBox x:Name="ColsBox" Width="30" Text="3"/>
            </StackPanel>

        </StackPanel>
    </Grid>
</Window>
