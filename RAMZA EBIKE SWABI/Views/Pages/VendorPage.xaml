<Page x:Class="Ramza_EBike_Swabi.Views.Pages.VendorPage"
      xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
      xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml">

    <Grid Margin="20">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <!-- Header -->
            <RowDefinition Height="Auto"/>
            <!-- Search -->
            <RowDefinition Height="*"/>
            <!-- Grid -->
        </Grid.RowDefinitions>

        <!-- HEADER -->
        <Grid Grid.Row="0" Margin="0 0 0 15" VerticalAlignment="Center">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="Auto"/>
                <ColumnDefinition Width="*"/>
                <ColumnDefinition Width="Auto"/>
            </Grid.ColumnDefinitions>

            <Button Grid.Column="0"
                    Content="← Back"
                    Width="100"
                    Height="35"
                    FontWeight="Bold"
                    Background="#FF2B579A"
                    Foreground="White"
                    BorderThickness="0"
                    Cursor="Hand"
                    Click="Back_Click"/>

            <TextBlock Grid.Column="1"
                       Text="Vendors"
                       FontSize="26"
                       FontWeight="Bold"
                       HorizontalAlignment="Center"
                       VerticalAlignment="Center"/>
        </Grid>

        <!-- SEARCH + ADD -->
        <Border Grid.Row="1"
                Background="White"
                CornerRadius="8"
                Padding="10"
                Margin="0 0 0 15">

            <StackPanel Orientation="Horizontal" HorizontalAlignment="Right">

                <!-- Search Box -->
                <TextBox x:Name="SearchBox"
                         Width="260"
                         Height="35"
                         Margin="0 0 10 0"
                         Padding="10,5"
                         BorderBrush="#FFB0B0B0"
                         BorderThickness="1"
                         TextChanged="SearchBox_TextChanged"
                         VerticalContentAlignment="Center"/>

                <Button Content="Search"
                        Width="100"
                        Height="35"
                        Background="#FF2B579A"
                        Foreground="White"
                        BorderThickness="0"
                        Cursor="Hand"
                        Click="Search_Click"/>

                <Button Content="Add Vendor"
                        Width="130"
                        Height="35"
                        Background="#FF1B4079"
                        Foreground="White"
                        FontWeight="Bold"
                        Margin="10 0 0 0"
                        BorderThickness="0"
                        Cursor="Hand"
                        Click="AddVendor_Click"/>
            </StackPanel>
        </Border>

        <!-- VENDOR GRID -->
        <DataGrid x:Name="VendorGrid"
                  Grid.Row="2"
                  AutoGenerateColumns="False"
                  SelectionMode="Single"
                  HeadersVisibility="Column"
                  IsReadOnly="True">

            <DataGrid.Columns>
                <DataGridTextColumn Header="ID" Binding="{Binding Id}" Width="50"/>
                <DataGridTextColumn Header="Vendor Name" Binding="{Binding VendorName}" Width="150"/>
                <DataGridTextColumn Header="Phone" Binding="{Binding Phone}" Width="120"/>
                <DataGridTextColumn Header="Address" Binding="{Binding Address}" Width="200"/>
                <DataGridTextColumn Header="Created Date"
                                    Binding="{Binding CreatedDate, StringFormat=\{0:dd MMM yyyy\}}"
                                    Width="150"/>

                <DataGridTemplateColumn Header="Actions" Width="240">
                    <DataGridTemplateColumn.CellTemplate>
                        <DataTemplate>
                            <StackPanel Orientation="Horizontal" HorizontalAlignment="Center">
                                <Button Content="Purchases"
                                        Width="75"
                                        Height="28"
                                        Margin="0 0 5 0"
                                        Background="#FF00695C"
                                        Foreground="White"
                                        BorderThickness="0"
                                        Click="ViewPurchases_Click"/>

                                <Button Content="Edit"
                                        Width="60"
                                        Height="28"
                                        Margin="0 0 5 0"
                                        Background="#FF2B579A"
                                        Foreground="White"
                                        BorderThickness="0"
                                        Click="EditVendor_Click"/>

                                <Button Content="Delete"
                                        Width="60"
                                        Height="28"
                                        Background="#FFB00020"
                                        Foreground="White"
                                        BorderThickness="0"
                                        Click="DeleteVendor_Click"/>
                            </StackPanel>
                        </DataTemplate>
                    </DataGridTemplateColumn.CellTemplate>
                </DataGridTemplateColumn>
            </DataGrid.Columns>
        </DataGrid>

    </Grid>
</Page>
