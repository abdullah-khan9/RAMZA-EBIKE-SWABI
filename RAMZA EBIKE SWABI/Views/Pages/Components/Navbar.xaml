<UserControl x:Class="Ramza_EBike_Swabi.Views.Pages.Components.Navbar"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             Height="75">

	<Border Background="Green" Padding="10" SnapsToDevicePixels="True">
		<Grid>
			<Grid.ColumnDefinitions>
				<ColumnDefinition Width="300"/>
				<ColumnDefinition Width="*"/>
				<ColumnDefinition Width="350"/>
			</Grid.ColumnDefinitions>

			<!-- LEFT: Logo + Shop Name -->
			<StackPanel Orientation="Horizontal" VerticalAlignment="Center" Grid.Column="0">
				<Image Source="/Resources/logo.png" Width="79" Height="76"/>
				<TextBlock Text="Swabi Enterprises"
                           Foreground="White"
                           FontSize="18"
                           FontWeight="Bold"
                           VerticalAlignment="Center"
                           Margin="8,0"/>
			</StackPanel>

			<!-- CENTER: Welcome Text -->
			<TextBlock x:Name="WelcomeText"
                       Text="Welcome: User"
                       Foreground="White"
                       FontWeight="SemiBold"
                       FontSize="18"
                       VerticalAlignment="Center"
                       HorizontalAlignment="Center"
                       Grid.Column="1"/>

			<!-- RIGHT: Time + Logout -->
			<StackPanel Orientation="Horizontal"
                        VerticalAlignment="Center"
                        Grid.Column="2"
                        HorizontalAlignment="Right">

				<TextBlock x:Name="TimeText"
                           Foreground="White"
                           FontSize="14"
                           Margin="0,0,16,0"
                           VerticalAlignment="Center"/>
				<Button Width="136"
						Height="43"
						Background="#E74C3C"
						BorderThickness="0"
						Cursor="Hand"
						Click="Logout_Click">

					<Button.Template>
						<ControlTemplate TargetType="Button">
							<Border x:Name="MainBorder"
									Background="{TemplateBinding Background}"
									CornerRadius="24"
									Padding="12,6">

								<StackPanel Orientation="Horizontal" VerticalAlignment="Center" Height="48" Margin="0,0,23,0">

									<!-- Icon Circle -->
									<Border Width="28"
											Height="28"
											CornerRadius="16"
											BorderBrush="White"
											BorderThickness="2"
											VerticalAlignment="Center"
											Margin="0,0,10,0">

										<!-- Logout Arrow Icon -->
										<Path Data="M10,6 L6,10 L10,14 M6,10 L18,10"
											  Stroke="White"
											  StrokeThickness="2"
											  StrokeLineJoin="Round"
											  StrokeStartLineCap="Round"
											  StrokeEndLineCap="Round"
											  VerticalAlignment="Top" Margin="0,2,0,0"/>
									</Border>
									<TextBlock Text="Logout"
											   Foreground="White"
											   FontSize="16"
											   FontWeight="SemiBold"
											   Height="29" Width="69"/>

									<!-- Text -->
								</StackPanel>
							</Border>

							<!-- Hover + Press Effects -->
							<ControlTemplate.Triggers>
								<Trigger Property="IsMouseOver" Value="True">
									<Setter TargetName="MainBorder" Property="Background" Value="#FF5A4F"/>
								</Trigger>
								<Trigger Property="IsPressed" Value="True">
									<Setter TargetName="MainBorder" Property="Background" Value="#C0392B"/>
								</Trigger>
							</ControlTemplate.Triggers>

						</ControlTemplate>
					</Button.Template>
				</Button>
			</StackPanel>
		</Grid>
	</Border>
</UserControl>
