<!-- DocumentHistoryWindow.xaml -->
<Window x:Class="Ramza_EBike_Swabi.Views.Pages.DocumentHistoryWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Document Issuance History"
        Width="700" Height="520"
        WindowStartupLocation="CenterOwner"
        Background="#F4F6F9">

    <Grid Margin="20">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <!-- Header -->
        <StackPanel Grid.Row="0" Margin="0 0 0 14">
            <TextBlock x:Name="lblTitle"
                       FontSize="18" FontWeight="Bold" Foreground="#111827"/>
            <TextBlock x:Name="lblSubtitle"
                       FontSize="12" Foreground="#6B7280" Margin="0 4 0 0"/>
        </StackPanel>

        <!-- History DataGrid -->
        <Border Grid.Row="1" Background="White" CornerRadius="10" Padding="10">
            <DataGrid x:Name="dgHistory"
                      AutoGenerateColumns="False"
                      CanUserAddRows="False" CanUserDeleteRows="False"
                      IsReadOnly="True"
                      RowHeight="38"
                      GridLinesVisibility="Horizontal"
                      AlternatingRowBackground="#F9FAFB"
                      BorderThickness="0"
                      ScrollViewer.VerticalScrollBarVisibility="Auto">
                <DataGrid.Columns>
                    <DataGridTextColumn Header="Date &amp; Time"
                                        Binding="{Binding IssuanceDateDisplay}"
                                        Width="150"/>
                    <DataGridTextColumn Header="Warranty Card"
                                        Binding="{Binding WarrantyDisplay}"
                                        Width="110"/>
                    <DataGridTextColumn Header="Voucher (Cust.)"
                                        Binding="{Binding VoucherCustDisplay}"
                                        Width="120"/>
                    <DataGridTextColumn Header="Voucher (Comp.)"
                                        Binding="{Binding VoucherCompDisplay}"
                                        Width="120"/>
                    <DataGridTextColumn Header="Issued By"
                                        Binding="{Binding IssuedBy}"
                                        Width="120"/>
                    <DataGridTextColumn Header="Received By"
                                        Binding="{Binding ReceivedBy}"
                                        Width="120"/>
                    <DataGridTextColumn Header="Notes"
                                        Binding="{Binding Notes}"
                                        Width="*"/>
                </DataGrid.Columns>
            </DataGrid>
        </Border>

        <!-- Empty state -->
        <Border x:Name="pnlEmpty" Grid.Row="1"
                Background="White" CornerRadius="10"
                Padding="40" Visibility="Collapsed">
            <StackPanel HorizontalAlignment="Center" VerticalAlignment="Center">
                <TextBlock Text="📭" FontSize="40" HorizontalAlignment="Center"/>
                <TextBlock Text="No issuance history recorded yet."
                           FontSize="13" Foreground="#9CA3AF"
                           HorizontalAlignment="Center" Margin="0 8 0 0"/>
            </StackPanel>
        </Border>

        <!-- Close button -->
        <Button Grid.Row="2" Content="Close" Width="100" Height="36"
                HorizontalAlignment="Right" Margin="0 14 0 0"
                Background="#6B7280" Foreground="White"
                BorderThickness="0" FontWeight="SemiBold"
                Click="BtnClose_Click"/>
    </Grid>
</Window>
