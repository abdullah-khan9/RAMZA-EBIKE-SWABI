<!-- IssueDocumentWindow.xaml -->
<Window x:Class="Ramza_EBike_Swabi.Views.Pages.IssueDocumentWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Issue Document"
        Width="480" SizeToContent="Height"
        WindowStartupLocation="CenterOwner"
        ResizeMode="NoResize"
        Background="#F4F6F9">
    <Border Padding="24">
        <StackPanel>
            <TextBlock x:Name="lblTitle"
                       FontSize="18" FontWeight="Bold"
                       Foreground="#111827" Margin="0 0 0 4"/>
            <TextBlock x:Name="lblSubtitle"
                       FontSize="12" Foreground="#6B7280" Margin="0 0 0 20"/>

            <!-- Document Type -->
            <TextBlock Text="Documents to Issue *" FontWeight="SemiBold" Margin="0 0 0 6"/>
            <Border Background="White" CornerRadius="8" Padding="12" Margin="0 0 0 14">
                <StackPanel>
                    <CheckBox x:Name="chkWarranty"
                              Content="🛡️  Warranty Card" FontSize="13"
                              Margin="0 0 0 8"/>
                    <CheckBox x:Name="chkVoucherCust"
                              Content="🎫  Voucher (Customer Copy)" FontSize="13"
                              Margin="0 0 0 8"/>
                    <CheckBox x:Name="chkVoucherComp"
                              Content="🏷️  Voucher (Company Copy)" FontSize="13"/>
                </StackPanel>
            </Border>

            <!-- Issued By -->
            <TextBlock Text="Issued By (Staff Name) *" FontWeight="SemiBold" Margin="0 0 0 6"/>
            <TextBox x:Name="txtIssuedBy" Height="36"
                     VerticalContentAlignment="Center" Padding="10 0"
                     Margin="0 0 0 14"/>

            <!-- Received By -->
            <TextBlock Text="Received By (Customer / Rep Name) *" FontWeight="SemiBold" Margin="0 0 0 6"/>
            <TextBox x:Name="txtReceivedBy" Height="36"
                     VerticalContentAlignment="Center" Padding="10 0"
                     Margin="0 0 0 14"/>

            <!-- Date & Time (auto-filled, editable) -->
            <TextBlock Text="Date &amp; Time" FontWeight="SemiBold" Margin="0 0 0 6"/>
            <TextBox x:Name="txtDateTime" Height="36"
                     VerticalContentAlignment="Center" Padding="10 0"
                     Margin="0 0 0 14" IsReadOnly="True" Background="#F9FAFB"/>

            <!-- Notes -->
            <TextBlock Text="Notes (optional)" FontWeight="SemiBold" Margin="0 0 0 6"/>
            <TextBox x:Name="txtNotes" Height="60"
                     AcceptsReturn="True" TextWrapping="Wrap"
                     VerticalScrollBarVisibility="Auto"
                     Padding="10 6"
                     Margin="0 0 0 14"/>

            <!-- ✅ NEW: Apply to PDF Checkbox -->
            <Border Background="#FFF3CD" BorderBrush="#FFC107" BorderThickness="1" 
                    CornerRadius="6" Padding="12" Margin="0 0 0 20">
                <StackPanel>
                    <CheckBox x:Name="chkApplyToPdf"
                              Content="📄  Update Invoice PDF with Document History"
                              FontSize="13" FontWeight="SemiBold"
                              IsChecked="True"
                              Margin="0 0 0 6"/>
                    <TextBlock Text="When checked, the invoice PDF will be regenerated to include this document issuance record in the history section."
                               FontSize="10" Foreground="#856404" TextWrapping="Wrap"/>
                </StackPanel>
            </Border>

            <!-- Buttons -->
            <StackPanel Orientation="Horizontal" HorizontalAlignment="Right">
                <Button Content="Cancel" Width="90" Height="38"
                        Background="#E5E7EB" Foreground="#374151"
                        BorderThickness="0" Margin="0 0 10 0"
                        Click="BtnCancel_Click"/>
                <Button Content="Submit Issuance" Width="160" Height="38"
                        Background="#0D6EFD" Foreground="White"
                        BorderThickness="0" FontWeight="Bold"
                        Click="BtnSubmit_Click"/>
            </StackPanel>
        </StackPanel>
    </Border>
</Window>
