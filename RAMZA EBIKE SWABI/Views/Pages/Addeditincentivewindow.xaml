<Window x:Class="Ramza_EBike_Swabi.Views.Pages.AddEditIncentiveWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Add Vendor Incentive"
        Height="620" Width="520"
        WindowStartupLocation="CenterOwner"
        ResizeMode="NoResize"
        Background="#F4F6F9">

    <ScrollViewer VerticalScrollBarVisibility="Auto"
                  HorizontalScrollBarVisibility="Disabled">
        <StackPanel Margin="28 20 28 28">

            <TextBlock x:Name="FormTitle"
                       Text="Add Vendor Incentive"
                       FontSize="20" FontWeight="Bold"
                       Foreground="#1B4079" Margin="0 0 0 20"/>

            <!-- Vendor -->
            <TextBlock Text="Vendor *" FontWeight="Bold" FontSize="13" Margin="0 0 0 5"/>
            <ComboBox x:Name="cmbVendor"
                      Height="34" FontSize="13"
                      DisplayMemberPath="VendorName"
                      Margin="0 0 0 14"
                      SelectionChanged="CmbVendor_SelectionChanged"/>

            <!-- Incentive Name -->
            <TextBlock Text="Incentive Name *" FontWeight="Bold" FontSize="13" Margin="0 0 0 5"/>
            <TextBox x:Name="txtIncentiveName"
                     Height="34" FontSize="13"
                     VerticalContentAlignment="Center"
                     Padding="8 0" Margin="0 0 0 14"/>

            <!-- Amount -->
            <TextBlock Text="Amount (PKR) *" FontWeight="Bold" FontSize="13" Margin="0 0 0 5"/>
            <TextBox x:Name="txtAmount"
                     Height="34" FontSize="13"
                     VerticalContentAlignment="Center"
                     Padding="8 0" Margin="0 0 0 14"/>

            <!-- Destination -->
            <TextBlock Text="Add Amount To *" FontWeight="Bold" FontSize="13" Margin="0 0 0 8"/>

            <!-- ✅ FIX: Removed Checked="Destination_Changed" from all radio buttons.
                 Events are wired in code-behind AFTER InitializeComponent() so that
                 controls like pnlVendorCashInfo and txtDestHint are guaranteed to exist. -->
            <StackPanel Orientation="Horizontal" Margin="0 0 0 4">
                <RadioButton x:Name="rbCash"
                             Content="Cash Balance"
                             GroupName="Dest" IsChecked="True"
                             FontSize="13" Margin="0 0 20 0"/>
                <RadioButton x:Name="rbAccount"
                             Content="Account Balance"
                             GroupName="Dest" FontSize="13"
                             Margin="0 0 20 0"/>
            </StackPanel>
            <StackPanel Orientation="Horizontal" Margin="0 0 0 6">
                <RadioButton x:Name="rbVendorCash"
                             Content="Vendor Cash"
                             GroupName="Dest" FontSize="13"
                             Margin="0 0 20 0"/>
                <RadioButton x:Name="rbGift"
                             Content="Gift (no financial record)"
                             GroupName="Dest" FontSize="13"/>
            </StackPanel>

            <!-- Description of selected destination -->
            <Border x:Name="pnlDestHint"
                    Background="#E3F2FD" CornerRadius="5"
                    Padding="10 7" Margin="0 0 0 14">
                <TextBlock x:Name="txtDestHint"
                           FontSize="11" Foreground="#1B4079"
                           TextWrapping="Wrap"/>
            </Border>

            <!-- Vendor Cash hint -->
            <Border x:Name="pnlVendorCashInfo"
                    Visibility="Collapsed"
                    Background="#FFF8E1" CornerRadius="5"
                    Padding="10 7" Margin="0 0 0 14">
                <StackPanel Orientation="Horizontal">
                    <TextBlock Text="Current Vendor Cash Balance: "
                               FontSize="12" FontWeight="Bold"/>
                    <TextBlock x:Name="txtVendorCashBalance"
                               FontSize="12" Foreground="#1B8A3D" FontWeight="Bold"/>
                </StackPanel>
            </Border>

            <!-- Date + Time -->
            <TextBlock Text="Date and Time" FontWeight="Bold" FontSize="13" Margin="0 0 0 5"/>
            <StackPanel Orientation="Horizontal" Margin="0 0 0 14">
                <DatePicker x:Name="dpDate" Width="160" Height="34"/>
                <TextBox x:Name="txtTime"
                         Width="90" Height="34"
                         Margin="10 0 0 0"
                         VerticalContentAlignment="Center"
                         Padding="8 0" FontSize="13"/>
                <TextBlock Text="(HH:mm)" VerticalAlignment="Center"
                           Foreground="#888888" Margin="8 0 0 0"/>
            </StackPanel>

            <!-- Remarks -->
            <TextBlock Text="Remarks" FontWeight="Bold" FontSize="13" Margin="0 0 0 5"/>
            <TextBox x:Name="txtRemarks"
                     Height="60" AcceptsReturn="True"
                     TextWrapping="Wrap"
                     VerticalScrollBarVisibility="Auto"
                     Padding="8 6" FontSize="13"
                     Margin="0 0 0 24"/>

            <!-- Buttons -->
            <StackPanel Orientation="Horizontal" HorizontalAlignment="Right">
                <Button Content="Cancel" Width="110" Height="40"
                        FontSize="13" Margin="0 0 10 0"
                        Click="Cancel_Click"/>
                <Button x:Name="btnSave"
                        Content="Add Incentive"
                        Width="150" Height="40"
                        Background="#FF1B4079" Foreground="White"
                        FontWeight="Bold" FontSize="13"
                        BorderThickness="0"
                        Click="Save_Click"/>
            </StackPanel>

        </StackPanel>
    </ScrollViewer>
</Window>
