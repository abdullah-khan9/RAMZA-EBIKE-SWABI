<Window x:Class="Ramza_EBike_Swabi.Views.Pages.EditIssuanceWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Edit Issuance Record"
        Width="480" SizeToContent="Height"
        WindowStartupLocation="CenterOwner"
        ResizeMode="NoResize"
        Background="#F4F6F9">

    <Border Padding="24">
        <StackPanel>

            <TextBlock Text="Edit Issuance Record"
                       FontSize="18" FontWeight="Bold"
                       Foreground="#111827" Margin="0 0 0 4"/>
            <TextBlock x:Name="lblSubtitle"
                       FontSize="12" Foreground="#6B7280" Margin="0 0 0 20"/>

            <TextBlock Text="Documents Issued *"
                       FontWeight="SemiBold" Margin="0 0 0 6"/>
            <Border Background="White" CornerRadius="8" Padding="14 12" Margin="0 0 0 4">
                <StackPanel>
                    <CheckBox x:Name="chkWarranty"
                              Content="Warranty Card"
                              FontSize="13" Margin="0 0 0 8"/>
                    <CheckBox x:Name="chkVoucherCust"
                              Content="Voucher (Customer Copy)"
                              FontSize="13" Margin="0 0 0 8"/>
                    <CheckBox x:Name="chkVoucherComp"
                              Content="Voucher (Company Copy)"
                              FontSize="13"/>
                </StackPanel>
            </Border>
            <TextBlock Text="Uncheck any document that was not actually given."
                       FontSize="11" Foreground="#6B7280" FontStyle="Italic"
                       Margin="0 0 0 14"/>

            <TextBlock Text="Issued By (Staff Name) *"
                       FontWeight="SemiBold" Margin="0 0 0 6"/>
            <TextBox x:Name="txtIssuedBy" Height="36"
                     VerticalContentAlignment="Center" Padding="10 0"
                     Margin="0 0 0 14"/>

            <TextBlock Text="Received By *"
                       FontWeight="SemiBold" Margin="0 0 0 6"/>
            <TextBox x:Name="txtReceivedBy" Height="36"
                     VerticalContentAlignment="Center" Padding="10 0"
                     Margin="0 0 0 14"/>

            <TextBlock Text="Date and Time *"
                       FontWeight="SemiBold" Margin="0 0 0 6"/>
            <Grid Margin="0 0 0 14">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="8"/>
                    <ColumnDefinition Width="140"/>
                </Grid.ColumnDefinitions>
                <DatePicker x:Name="dpDate" Height="36"
                            VerticalContentAlignment="Center"/>
                <TextBox x:Name="txtTime" Grid.Column="2" Height="36"
                         VerticalContentAlignment="Center" Padding="10 0"
                         ToolTip="Format: 02:30 PM or 14:30"/>
            </Grid>

            <TextBlock Text="Notes (optional)"
                       FontWeight="SemiBold" Margin="0 0 0 6"/>
            <TextBox x:Name="txtNotes" Height="60"
                     AcceptsReturn="True" TextWrapping="Wrap"
                     VerticalScrollBarVisibility="Auto"
                     Padding="10 6" Margin="0 0 0 20"/>

            <StackPanel Orientation="Horizontal" HorizontalAlignment="Right">
                <Button Content="Cancel" Width="90" Height="38"
                        Background="#E5E7EB" Foreground="#374151"
                        BorderThickness="0" Margin="0 0 10 0"
                        Click="BtnCancel_Click"/>
                <Button Content="Save Changes" Width="140" Height="38"
                        Background="#6366F1" Foreground="White"
                        BorderThickness="0" FontWeight="Bold"
                        Click="BtnSave_Click"/>
            </StackPanel>

        </StackPanel>
    </Border>
</Window>
