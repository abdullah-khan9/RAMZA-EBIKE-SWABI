<Page x:Class="Ramza_EBike_Swabi.Views.Pages.VendorBillDetailPage"
      xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
      xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml">

    <Grid Margin="20">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
        </Grid.RowDefinitions>

        <!-- ================= SCREEN BUTTONS (hidden on print/PDF) ================= -->
        <StackPanel x:Name="TopButtonsPanel" Orientation="Horizontal" Margin="0 0 0 10">
            <Button Content="← Back"
                    Width="100" Height="35"
                    Background="#FF2B579A" Foreground="White"
                    BorderThickness="0" Click="Back_Click"/>
            <Button Content="Save as PDF"
                    Width="140" Height="35" Margin="10 0 0 0"
                    Background="#FF1B4079" Foreground="White"
                    BorderThickness="0" Click="Print_Click"/>
        </StackPanel>

        <ScrollViewer x:Name="MainScrollViewer"
                      Grid.Row="1"
                      VerticalScrollBarVisibility="Auto"
                      HorizontalScrollBarVisibility="Auto">

            <!-- ================= PRINT / PDF AREA ================= -->
            <Border x:Name="PrintArea"
                    Background="White"
                    Padding="30"
                    BorderBrush="#CCCCCC"
                    BorderThickness="1"
                    Width="900">

                <StackPanel>

                    <!-- ══════════════════════════════════════════
                         COMPANY HEADER
                    ══════════════════════════════════════════ -->
                    <Border BorderBrush="#1B4079" BorderThickness="0 0 0 3" Margin="0 0 0 0">
                        <Grid Margin="0 0 0 12">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*"/>
                                <ColumnDefinition Width="Auto"/>
                            </Grid.ColumnDefinitions>

                            <!-- Left: Company Info -->
                            <StackPanel Grid.Column="0">
                                <TextBlock Text="Swabi Enterprises"
                                           FontSize="28" FontWeight="Bold"
                                           Foreground="#1B4079"/>
                                <TextBlock Text="NTN: I039290"
                                           FontSize="12" Foreground="#444"
                                           Margin="0 2 0 0"/>
                                <TextBlock Text="Main Jahangira Road Near Sadaat CNG, Swabi"
                                           FontSize="12" Foreground="#444"/>
                                <TextBlock Text="Phone: +92 345 9996397"
                                           FontSize="12" Foreground="#444"/>
                            </StackPanel>

                            <!-- Right: Bill Title + Bill #  -->
                            <StackPanel Grid.Column="1" HorizontalAlignment="Right">
                                <TextBlock Text="VENDOR PURCHASE BILL"
                                           FontSize="20" FontWeight="Bold"
                                           Foreground="#1B4079"
                                           HorizontalAlignment="Right"/>
                                <StackPanel Orientation="Horizontal" HorizontalAlignment="Right" Margin="0 4 0 0">
                                    <TextBlock Text="Bill #: " FontWeight="Bold" FontSize="13" Foreground="#444"/>
                                    <TextBlock x:Name="BillIdText" FontSize="13" Foreground="#1B4079" FontWeight="Bold"/>
                                </StackPanel>
                                <StackPanel Orientation="Horizontal" HorizontalAlignment="Right">
                                    <TextBlock Text="Printed: " FontSize="11" Foreground="#777"/>
                                    <TextBlock x:Name="PrintDateText" FontSize="11" Foreground="#777"/>
                                </StackPanel>
                            </StackPanel>
                        </Grid>
                    </Border>

                    <!-- ══════════════════════════════════════════
                         BILL INFO ROW
                    ══════════════════════════════════════════ -->
                    <Border Background="#F0F4FA" CornerRadius="6"
                            Padding="14 10" Margin="0 14 0 0">
                        <Grid>
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*"/>
                                <ColumnDefinition Width="*"/>
                                <ColumnDefinition Width="*"/>
                                <ColumnDefinition Width="Auto"/>
                            </Grid.ColumnDefinitions>

                            <!-- Vendor -->
                            <StackPanel Grid.Column="0">
                                <TextBlock Text="Vendor" FontSize="10" Foreground="#888" FontWeight="Bold"/>
                                <TextBlock x:Name="VendorName" FontSize="15" FontWeight="Bold" Foreground="#1B4079"/>
                                <TextBlock x:Name="VendorId" FontSize="11" Foreground="#666" Margin="0 2 0 0"/>
                            </StackPanel>

                            <!-- Bill Date + Doc# -->
                            <StackPanel Grid.Column="1">
                                <TextBlock Text="Bill Date" FontSize="10" Foreground="#888" FontWeight="Bold"/>
                                <TextBlock x:Name="BillDate" FontSize="14" Foreground="#222"/>
                                <TextBlock Text="Document #" FontSize="10" Foreground="#888" FontWeight="Bold" Margin="0 6 0 0"/>
                                <TextBlock x:Name="DocumentNumberText" FontSize="13" Foreground="#222"/>
                            </StackPanel>

                            <!-- Balances -->
                            <StackPanel Grid.Column="2">
                                <TextBlock Text="Previous Balance" FontSize="10" Foreground="#888" FontWeight="Bold"/>
                                <TextBlock x:Name="PreviousBalance" FontSize="14" Foreground="#222"/>
                                <TextBlock Text="Amount Paid" FontSize="10" Foreground="#888" FontWeight="Bold" Margin="0 6 0 0"/>
                                <TextBlock x:Name="AmountPaid" FontSize="14" FontWeight="Bold" Foreground="#1B8A3D"/>
                            </StackPanel>

                            <!-- Status + Payment Method badge -->
                            <StackPanel Grid.Column="3" HorizontalAlignment="Right" VerticalAlignment="Center">
                                <!-- Bill Status -->
                                <Border x:Name="StatusBadge"
                                        CornerRadius="5" Padding="12 5" Margin="0 0 0 6"
                                        HorizontalAlignment="Right">
                                    <TextBlock x:Name="StatusText"
                                               FontSize="13" FontWeight="Bold"
                                               Foreground="White" HorizontalAlignment="Center"/>
                                </Border>
                                <!-- Payment Method -->
                                <Border Background="#E3F2FD" CornerRadius="5"
                                        Padding="10 4" HorizontalAlignment="Right">
                                    <StackPanel Orientation="Horizontal">
                                        <TextBlock Text="Paid via: " FontSize="11" Foreground="#555"/>
                                        <TextBlock x:Name="PaymentMethodText"
                                                   FontSize="11" FontWeight="Bold" Foreground="#1565C0"/>
                                    </StackPanel>
                                </Border>
                            </StackPanel>
                        </Grid>
                    </Border>

                    <!-- ══════════════════════════════════════════
                         ITEMS TABLE
                    ══════════════════════════════════════════ -->
                    <TextBlock Text="Bill Items" FontSize="13" FontWeight="Bold"
                               Foreground="#1B4079" Margin="0 18 0 6"/>

                    <DataGrid x:Name="ItemsGrid"
                              AutoGenerateColumns="False"
                              HeadersVisibility="Column"
                              IsReadOnly="True"
                              CanUserAddRows="False"
                              Foreground="Black"
                              Background="White"
                              GridLinesVisibility="All"
                              BorderBrush="#CCCCCC"
                              BorderThickness="1"
                              RowHeight="32"
                              ScrollViewer.HorizontalScrollBarVisibility="Auto"
                              ScrollViewer.VerticalScrollBarVisibility="Disabled">

                        <DataGrid.ColumnHeaderStyle>
                            <Style TargetType="DataGridColumnHeader">
                                <Setter Property="FontWeight" Value="Bold"/>
                                <Setter Property="Foreground" Value="White"/>
                                <Setter Property="Background" Value="#1B4079"/>
                                <Setter Property="Padding" Value="6 4"/>
                                <Setter Property="BorderBrush" Value="#2B579A"/>
                                <Setter Property="BorderThickness" Value="0 0 1 0"/>
                            </Style>
                        </DataGrid.ColumnHeaderStyle>

                        <DataGrid.CellStyle>
                            <Style TargetType="DataGridCell">
                                <Setter Property="Foreground" Value="Black"/>
                                <Setter Property="Padding" Value="5 3"/>
                                <Setter Property="BorderThickness" Value="0"/>
                            </Style>
                        </DataGrid.CellStyle>

                        <DataGrid.RowStyle>
                            <Style TargetType="DataGridRow">
                                <Style.Triggers>
                                    <Trigger Property="AlternationIndex" Value="1">
                                        <Setter Property="Background" Value="#F5F8FF"/>
                                    </Trigger>
                                </Style.Triggers>
                            </Style>
                        </DataGrid.RowStyle>

                        <DataGrid.Columns>
                            <DataGridTextColumn Header="Model"         Binding="{Binding Model}"           Width="110"/>
                            <DataGridTextColumn Header="Brand"         Binding="{Binding Brand}"           Width="90"/>
                            <DataGridTextColumn Header="Motor Power"   Binding="{Binding MotorPower}"      Width="95"/>
                            <DataGridTextColumn Header="Battery"       Binding="{Binding BatteryCapacity}" Width="80"/>
                            <DataGridTextColumn Header="Motor No."     Binding="{Binding MotorNumber}"     Width="100"/>
                            <DataGridTextColumn Header="Chassis No."   Binding="{Binding ChassisNumber}"   Width="110"/>
                            <DataGridTextColumn Header="Color"         Binding="{Binding Color}"           Width="70"/>
                            <DataGridTextColumn Header="Warranty"      Binding="{Binding Warranty}"        Width="75"/>
                            <DataGridTextColumn Header="Qty"           Binding="{Binding Qty}"             Width="45"/>
                            <DataGridTextColumn Header="Bill Rate"     Binding="{Binding BillRate, StringFormat=N2}"              Width="85"/>
                            <DataGridTextColumn Header="Comm %"        Binding="{Binding CommissionPercent}"                      Width="60"/>
                            <DataGridTextColumn Header="Tax %"         Binding="{Binding TaxOnCommissionPercent}"                 Width="50"/>
                            <DataGridTextColumn Header="Extra %"       Binding="{Binding ExtraDiscountPercent}"                   Width="55"/>
                            <DataGridTextColumn Header="Commission"    Binding="{Binding CommissionAmount, StringFormat=N2}"      Width="90"/>
                            <DataGridTextColumn Header="Extra"         Binding="{Binding ExtraCommissionAmount, StringFormat=N2}" Width="75"/>
                            <DataGridTextColumn Header="Tax"           Binding="{Binding TaxOnCommissionAmount, StringFormat=N2}" Width="75"/>
                            <DataGridTextColumn Header="Total Comm."   Binding="{Binding TotalCommissionAmount, StringFormat=N2}" Width="95"/>
                            <DataGridTextColumn Header="Total Price"   Binding="{Binding TotalWholesalePrice, StringFormat=N2}"  Width="95"/>
                        </DataGrid.Columns>
                    </DataGrid>

                    <!-- ══════════════════════════════════════════
                         TOTALS SUMMARY
                    ══════════════════════════════════════════ -->
                    <Border Background="#F0F4FA" CornerRadius="6"
                            Padding="14 10" Margin="0 14 0 0">
                        <Grid>
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*"/>
                                <ColumnDefinition Width="Auto"/>
                            </Grid.ColumnDefinitions>

                            <!-- Left: Commission + Tax -->
                            <StackPanel Grid.Column="0" Orientation="Horizontal">
                                <StackPanel Margin="0 0 40 0">
                                    <TextBlock Text="Total Commission" FontSize="11" Foreground="#666"/>
                                    <TextBlock x:Name="TotalCommissionText" FontSize="15" FontWeight="Bold" Foreground="#444"/>
                                </StackPanel>
                                <StackPanel>
                                    <TextBlock Text="Total Tax Paid" FontSize="11" Foreground="#666"/>
                                    <TextBlock x:Name="TotalTaxText" FontSize="15" FontWeight="Bold" Foreground="#444"/>
                                </StackPanel>
                            </StackPanel>

                            <!-- Right: Full financial breakdown -->
                            <StackPanel Grid.Column="1" HorizontalAlignment="Right">
                                <Grid>
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="200"/>
                                        <ColumnDefinition Width="140"/>
                                    </Grid.ColumnDefinitions>
                                    <Grid.RowDefinitions>
                                        <RowDefinition/>
                                        <RowDefinition/>
                                        <RowDefinition/>
                                        <RowDefinition/>
                                        <RowDefinition/>
                                        <RowDefinition/>
                                        <RowDefinition/>
                                        <RowDefinition/>
                                    </Grid.RowDefinitions>

                                    <!-- Previous Balance -->
                                    <TextBlock Grid.Row="0" Grid.Column="0"
                                               Text="Previous Balance:"
                                               FontWeight="Bold" Foreground="#666"
                                               Margin="0 0 0 5"/>
                                    <TextBlock Grid.Row="0" Grid.Column="1"
                                               x:Name="PreviousBalanceSummary"
                                               HorizontalAlignment="Right"
                                               Foreground="#666" Margin="0 0 0 5"/>

                                    <!-- Total Amount (this bill items) -->
                                    <TextBlock Grid.Row="1" Grid.Column="0"
                                               Text="Total Amount (this bill):"
                                               FontWeight="Bold" Foreground="#333"
                                               Margin="0 0 0 5"/>
                                    <TextBlock Grid.Row="1" Grid.Column="1"
                                               x:Name="TotalAmount"
                                               HorizontalAlignment="Right"
                                               FontWeight="Bold" Foreground="#333"
                                               Margin="0 0 0 5"/>

                                    <!-- Net Bill -->
                                    <TextBlock Grid.Row="2" Grid.Column="0"
                                               Text="Net Bill (Prev + Total):"
                                               FontWeight="Bold" Foreground="#1B4079"
                                               Margin="0 0 0 5"/>
                                    <TextBlock Grid.Row="2" Grid.Column="1"
                                               x:Name="NetBillText"
                                               HorizontalAlignment="Right"
                                               FontWeight="Bold" Foreground="#1B4079"
                                               Margin="0 0 0 5"/>

                                    <!-- Amount Paid -->
                                    <TextBlock Grid.Row="3" Grid.Column="0"
                                               Text="Amount Paid:"
                                               FontWeight="Bold" Foreground="#1B8A3D"
                                               Margin="0 0 0 5"/>
                                    <TextBlock Grid.Row="3" Grid.Column="1"
                                               x:Name="AmountPaidSummary"
                                               HorizontalAlignment="Right"
                                               FontWeight="Bold" Foreground="#1B8A3D"
                                               Margin="0 0 0 5"/>

                                    <!-- Paid Via -->
                                    <TextBlock Grid.Row="4" Grid.Column="0"
                                               Text="Paid Via:"
                                               FontWeight="Bold" Foreground="#555"
                                               Margin="0 0 0 5"/>
                                    <TextBlock Grid.Row="4" Grid.Column="1"
                                               x:Name="PaidViaSummary"
                                               HorizontalAlignment="Right"
                                               Foreground="#555" Margin="0 0 0 5"/>

                                    <!-- Divider -->
                                    <Rectangle Grid.Row="5" Grid.ColumnSpan="2"
                                               Height="2" Fill="#1B4079" Margin="0 4"/>

                                    <!-- Remaining Balance -->
                                    <TextBlock Grid.Row="6" Grid.Column="0"
                                               Text="Remaining Balance:"
                                               FontWeight="Bold" FontSize="14"
                                               Foreground="#B00020" Margin="0 4 0 0"/>
                                    <TextBlock Grid.Row="6" Grid.Column="1"
                                               x:Name="RemainingBalance"
                                               HorizontalAlignment="Right"
                                               FontWeight="Bold" FontSize="14"
                                               Foreground="#B00020" Margin="0 4 0 0"/>
                                </Grid>
                            </StackPanel>
                        </Grid>
                    </Border>

                    <!-- ══════════════════════════════════════════
                         REMARKS
                    ══════════════════════════════════════════ -->
                    <Border x:Name="RemarksBorder"
                            Visibility="Collapsed"
                            Background="#FFFDE7" CornerRadius="5"
                            BorderBrush="#F9A825" BorderThickness="1"
                            Padding="12 8" Margin="0 14 0 0">
                        <StackPanel>
                            <TextBlock Text="Remarks" FontWeight="Bold" FontSize="12"
                                       Foreground="#E65100" Margin="0 0 0 4"/>
                            <TextBlock x:Name="RemarksText"
                                       FontSize="12" Foreground="#333"
                                       TextWrapping="Wrap"/>
                        </StackPanel>
                    </Border>

                    <!-- ══════════════════════════════════════════
                         FOOTER — Authorized Signature
                    ══════════════════════════════════════════ -->
                    <Grid Margin="0 40 0 10">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="*"/>
                        </Grid.ColumnDefinitions>

                        <!-- Vendor signature -->
                        <StackPanel Grid.Column="0" HorizontalAlignment="Center">
                            <Border BorderBrush="#999" BorderThickness="0 0 0 1"
                                    Width="180" Height="40"/>
                            <TextBlock Text="Vendor Signature"
                                       FontSize="11" Foreground="#555"
                                       HorizontalAlignment="Center" Margin="0 4 0 0"/>
                        </StackPanel>

                        <!-- Swabi Enterprises stamp area -->
                        <StackPanel Grid.Column="1" HorizontalAlignment="Center">
                            <Border BorderBrush="#999" BorderThickness="0 0 0 1"
                                    Width="180" Height="40"/>
                            <TextBlock Text="Authorized Signature"
                                       FontSize="11" Foreground="#555"
                                       HorizontalAlignment="Center" Margin="0 4 0 0"/>
                            <TextBlock Text="Swabi Enterprises"
                                       FontSize="10" Foreground="#888"
                                       HorizontalAlignment="Center"/>
                        </StackPanel>

                        <!-- Received by -->
                        <StackPanel Grid.Column="2" HorizontalAlignment="Center">
                            <Border BorderBrush="#999" BorderThickness="0 0 0 1"
                                    Width="180" Height="40"/>
                            <TextBlock Text="Received By"
                                       FontSize="11" Foreground="#555"
                                       HorizontalAlignment="Center" Margin="0 4 0 0"/>
                        </StackPanel>
                    </Grid>

                    <!-- Bottom note -->
                    <TextBlock Text="This is a computer-generated document. Swabi Enterprises — NTN: I039290"
                               FontSize="9" Foreground="#AAAAAA"
                               HorizontalAlignment="Center" Margin="0 6 0 0"/>

                </StackPanel>
            </Border>
        </ScrollViewer>
    </Grid>
</Page>
