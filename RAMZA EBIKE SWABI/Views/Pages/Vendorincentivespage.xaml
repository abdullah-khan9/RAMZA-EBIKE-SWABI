<Page x:Class="Ramza_EBike_Swabi.Views.Pages.VendorIncentivesPage"
      xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
      xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
      Background="#F4F6F9">

    <Grid Margin="20">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
        </Grid.RowDefinitions>

        <!-- TOP BAR -->
        <Grid Grid.Row="0" Margin="0 0 0 16">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="Auto"/>
                <ColumnDefinition Width="*"/>
                <ColumnDefinition Width="Auto"/>
            </Grid.ColumnDefinitions>

            <Button Grid.Column="0" Content="Back"
                    Width="100" Height="35" FontWeight="Bold"
                    Background="#FF2B579A" Foreground="White"
                    BorderThickness="0" Click="Back_Click"/>

            <TextBlock Grid.Column="1" Text="Vendor Incentives"
                       FontSize="26" FontWeight="Bold"
                       HorizontalAlignment="Center" VerticalAlignment="Center"/>

            <Button Grid.Column="2" Content="+ Add Incentive"
                    Width="150" Height="35"
                    Background="#FF1B4079" Foreground="White"
                    FontWeight="Bold" BorderThickness="0"
                    Click="AddIncentive_Click"/>
        </Grid>

        <!-- SUMMARY CARDS -->
        <UniformGrid Grid.Row="1" Columns="4" Margin="0 0 0 16">

            <Border Background="#E8F5E9" CornerRadius="8" Padding="12" Margin="0 0 6 0">
                <StackPanel HorizontalAlignment="Center">
                    <TextBlock Text="Total Incentives" FontSize="12"
                               FontWeight="Bold" Foreground="#2E7D32"
                               HorizontalAlignment="Center"/>
                    <TextBlock x:Name="txtTotalIncentives"
                               FontSize="20" FontWeight="Bold"
                               Foreground="#1B5E20" HorizontalAlignment="Center"
                               Margin="0 4 0 0"/>
                </StackPanel>
            </Border>

            <Border Background="#E3F2FD" CornerRadius="8" Padding="12" Margin="3 0">
                <StackPanel HorizontalAlignment="Center">
                    <TextBlock Text="Cash Incentives" FontSize="12"
                               FontWeight="Bold" Foreground="#1565C0"
                               HorizontalAlignment="Center"/>
                    <TextBlock x:Name="txtCashIncentives"
                               FontSize="20" FontWeight="Bold"
                               Foreground="#0D47A1" HorizontalAlignment="Center"
                               Margin="0 4 0 0"/>
                </StackPanel>
            </Border>

            <Border Background="#FFF8E1" CornerRadius="8" Padding="12" Margin="3 0">
                <StackPanel HorizontalAlignment="Center">
                    <TextBlock Text="Vendor Cash Incentives" FontSize="12"
                               FontWeight="Bold" Foreground="#F57F17"
                               HorizontalAlignment="Center"/>
                    <TextBlock x:Name="txtVendorCashIncentives"
                               FontSize="20" FontWeight="Bold"
                               Foreground="#E65100" HorizontalAlignment="Center"
                               Margin="0 4 0 0"/>
                </StackPanel>
            </Border>

            <Border Background="#FCE4EC" CornerRadius="8" Padding="12" Margin="6 0 0 0">
                <StackPanel HorizontalAlignment="Center">
                    <TextBlock Text="Gifts (No Cash)" FontSize="12"
                               FontWeight="Bold" Foreground="#880E4F"
                               HorizontalAlignment="Center"/>
                    <TextBlock x:Name="txtGiftIncentives"
                               FontSize="20" FontWeight="Bold"
                               Foreground="#880E4F" HorizontalAlignment="Center"
                               Margin="0 4 0 0"/>
                </StackPanel>
            </Border>

        </UniformGrid>

        <!-- SEARCH BAR -->
        <Border Grid.Row="2" Background="White" CornerRadius="8"
                Padding="12" Margin="0 0 0 12">
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="Auto"/>
                    <ColumnDefinition Width="Auto"/>
                </Grid.ColumnDefinitions>

                <TextBox x:Name="txtSearch"
                         Grid.Column="0"
                         Height="34" FontSize="13"
                         VerticalContentAlignment="Center"
                         Padding="10 0"
                         TextChanged="TxtSearch_TextChanged"/>

                <!-- Placeholder -->
                <TextBlock IsHitTestVisible="False"
                           Text="Search by vendor name, incentive name, or remarks..."
                           VerticalAlignment="Center" Margin="14 0 0 0"
                           Foreground="#AAAAAA" FontSize="13">
                    <TextBlock.Style>
                        <Style TargetType="TextBlock">
                            <Setter Property="Visibility" Value="Collapsed"/>
                            <Style.Triggers>
                                <MultiDataTrigger>
                                    <MultiDataTrigger.Conditions>
                                        <Condition Binding="{Binding Text, ElementName=txtSearch}" Value=""/>
                                        <Condition Binding="{Binding IsKeyboardFocusWithin, ElementName=txtSearch}" Value="False"/>
                                    </MultiDataTrigger.Conditions>
                                    <Setter Property="Visibility" Value="Visible"/>
                                </MultiDataTrigger>
                            </Style.Triggers>
                        </Style>
                    </TextBlock.Style>
                </TextBlock>

                <Button Grid.Column="1" Content="Clear"
                        Width="80" Height="34" Margin="8 0 0 0"
                        Background="#616161" Foreground="White"
                        BorderThickness="0" Click="ClearSearch_Click"/>

                <TextBlock x:Name="txtResultHint"
                           Grid.Column="2"
                           VerticalAlignment="Center"
                           Margin="12 0 0 0"
                           FontStyle="Italic" Foreground="#666666"/>
            </Grid>
        </Border>

        <!-- GROUPED VENDOR INCENTIVES LIST -->
        <ScrollViewer Grid.Row="3" VerticalScrollBarVisibility="Auto">
            <ItemsControl x:Name="icVendorGroups">
                <ItemsControl.ItemTemplate>
                    <DataTemplate>
                        <!-- One vendor block -->
                        <Border Margin="0 0 0 16"
                                Background="White"
                                CornerRadius="8"
                                BorderBrush="#DDDDDD"
                                BorderThickness="1">
                            <StackPanel>

                                <!-- ── VENDOR HEADER ── -->
                                <Border Background="#1B4079"
                                        CornerRadius="8 8 0 0"
                                        Padding="14 10">
                                    <Grid>
                                        <Grid.ColumnDefinitions>
                                            <ColumnDefinition Width="Auto"/>
                                            <ColumnDefinition Width="*"/>
                                            <ColumnDefinition Width="Auto"/>
                                            <ColumnDefinition Width="Auto"/>
                                        </Grid.ColumnDefinitions>

                                        <!-- Vendor name -->
                                        <TextBlock Grid.Column="0"
                                                   Text="{Binding VendorName}"
                                                   FontSize="15" FontWeight="Bold"
                                                   Foreground="White"
                                                   VerticalAlignment="Center"/>

                                        <!-- Count badge -->
                                        <Border Grid.Column="2"
                                                Background="#FFFFFF30"
                                                CornerRadius="10"
                                                Padding="8 2"
                                                Margin="0 0 12 0"
                                                VerticalAlignment="Center">
                                            <TextBlock Text="{Binding CountLabel}"
                                                       FontSize="11"
                                                       Foreground="White"/>
                                        </Border>

                                        <!-- Total amount -->
                                        <Border Grid.Column="3"
                                                Background="#27AE60"
                                                CornerRadius="10"
                                                Padding="10 2"
                                                VerticalAlignment="Center">
                                            <TextBlock Text="{Binding TotalLabel}"
                                                       FontSize="12" FontWeight="Bold"
                                                       Foreground="White"/>
                                        </Border>
                                    </Grid>
                                </Border>

                                <!-- ── COLUMN HEADERS ── -->
                                <Border Background="#EEF2F7" Padding="0">
                                    <Grid Margin="12 6">
                                        <Grid.ColumnDefinitions>
                                            <ColumnDefinition Width="50"/>
                                            <ColumnDefinition Width="110"/>
                                            <ColumnDefinition Width="*"/>
                                            <ColumnDefinition Width="120"/>
                                            <ColumnDefinition Width="130"/>
                                            <ColumnDefinition Width="170"/>
                                            <ColumnDefinition Width="130"/>
                                        </Grid.ColumnDefinitions>
                                        <TextBlock Grid.Column="0" Text="#"         FontWeight="Bold" FontSize="12" Foreground="#555"/>
                                        <TextBlock Grid.Column="1" Text="Date"      FontWeight="Bold" FontSize="12" Foreground="#555"/>
                                        <TextBlock Grid.Column="2" Text="Incentive Name" FontWeight="Bold" FontSize="12" Foreground="#555"/>
                                        <TextBlock Grid.Column="3" Text="Amount (PKR)" FontWeight="Bold" FontSize="12" Foreground="#555" HorizontalAlignment="Right"/>
                                        <TextBlock Grid.Column="4" Text="Added To"  FontWeight="Bold" FontSize="12" Foreground="#555" Margin="10 0 0 0"/>
                                        <TextBlock Grid.Column="5" Text="Remarks"   FontWeight="Bold" FontSize="12" Foreground="#555" Margin="10 0 0 0"/>
                                        <TextBlock Grid.Column="6" Text="Actions"   FontWeight="Bold" FontSize="12" Foreground="#555" Margin="10 0 0 0"/>
                                    </Grid>
                                </Border>

                                <Rectangle Height="1" Fill="#DDDDDD"/>

                                <!-- ── INCENTIVE ROWS ── -->
                                <ItemsControl ItemsSource="{Binding Incentives}">
                                    <ItemsControl.ItemTemplate>
                                        <DataTemplate>
                                            <Border x:Name="RowBorder"
                                                    BorderBrush="#EEEEEE"
                                                    BorderThickness="0 0 0 1"
                                                    Padding="0">
                                                <Grid Margin="12 8">
                                                    <Grid.ColumnDefinitions>
                                                        <ColumnDefinition Width="50"/>
                                                        <ColumnDefinition Width="110"/>
                                                        <ColumnDefinition Width="*"/>
                                                        <ColumnDefinition Width="120"/>
                                                        <ColumnDefinition Width="130"/>
                                                        <ColumnDefinition Width="170"/>
                                                        <ColumnDefinition Width="130"/>
                                                    </Grid.ColumnDefinitions>

                                                    <TextBlock Grid.Column="0"
                                                               Text="{Binding Id}"
                                                               FontSize="12" Foreground="#888"
                                                               VerticalAlignment="Center"/>

                                                    <TextBlock Grid.Column="1"
                                                               Text="{Binding IncentiveDate, StringFormat={}{0:dd-MMM-yyyy}}"
                                                               FontSize="12" Foreground="#444"
                                                               VerticalAlignment="Center"/>

                                                    <TextBlock Grid.Column="2"
                                                               Text="{Binding IncentiveName}"
                                                               FontSize="13" FontWeight="SemiBold"
                                                               Foreground="#1B4079"
                                                               VerticalAlignment="Center"
                                                               TextTrimming="CharacterEllipsis"/>

                                                    <TextBlock Grid.Column="3"
                                                               Text="{Binding Amount, StringFormat=N2}"
                                                               FontSize="13" FontWeight="Bold"
                                                               Foreground="#1B8A3D"
                                                               HorizontalAlignment="Right"
                                                               VerticalAlignment="Center"/>

                                                    <!-- Destination badge -->
                                                    <Border Grid.Column="4"
                                                            CornerRadius="4"
                                                            Padding="6 2"
                                                            Margin="10 0 0 0"
                                                            VerticalAlignment="Center"
                                                            Background="{Binding DestinationColor}">
                                                        <TextBlock Text="{Binding DestinationDisplay}"
                                                                   FontSize="11" FontWeight="Bold"
                                                                   Foreground="White"/>
                                                    </Border>

                                                    <TextBlock Grid.Column="5"
                                                               Text="{Binding Remarks}"
                                                               FontSize="12" Foreground="#666"
                                                               VerticalAlignment="Center"
                                                               TextTrimming="CharacterEllipsis"
                                                               Margin="10 0 0 0"/>

                                                    <!-- Action buttons -->
                                                    <StackPanel Grid.Column="6"
                                                                Orientation="Horizontal"
                                                                Margin="10 0 0 0"
                                                                VerticalAlignment="Center">
                                                        <Button Content="Edit"
                                                                Width="55" Height="28"
                                                                Margin="0 0 5 0"
                                                                Background="#FF1E88E5"
                                                                Foreground="White"
                                                                BorderThickness="0"
                                                                Click="Edit_Click"/>
                                                        <Button Content="Delete"
                                                                Width="60" Height="28"
                                                                Background="#FFC62828"
                                                                Foreground="White"
                                                                BorderThickness="0"
                                                                Click="Delete_Click"/>
                                                    </StackPanel>
                                                </Grid>

                                                <!-- Alternate row shading trigger -->
                                                <Border.Style>
                                                    <Style TargetType="Border">
                                                        <Style.Triggers>
                                                            <Trigger Property="IsMouseOver" Value="True">
                                                                <Setter Property="Background" Value="#F0F7FF"/>
                                                            </Trigger>
                                                        </Style.Triggers>
                                                    </Style>
                                                </Border.Style>
                                            </Border>
                                        </DataTemplate>
                                    </ItemsControl.ItemTemplate>
                                </ItemsControl>

                                <!-- ── VENDOR TOTAL FOOTER ── -->
                                <Border Background="#F5F5F5"
                                        CornerRadius="0 0 8 8"
                                        Padding="12 8">
                                    <Grid>
                                        <Grid.ColumnDefinitions>
                                            <ColumnDefinition Width="*"/>
                                            <ColumnDefinition Width="Auto"/>
                                        </Grid.ColumnDefinitions>
                                        <TextBlock Grid.Column="0"
                                                   Text="{Binding FooterCountLabel}"
                                                   FontSize="12" Foreground="#666"
                                                   VerticalAlignment="Center"/>
                                        <StackPanel Grid.Column="1" Orientation="Horizontal">
                                            <TextBlock Text="Total: "
                                                       FontSize="13" FontWeight="Bold"
                                                       Foreground="#444"
                                                       VerticalAlignment="Center"/>
                                            <TextBlock Text="{Binding TotalLabel}"
                                                       FontSize="13" FontWeight="Bold"
                                                       Foreground="#1B8A3D"
                                                       VerticalAlignment="Center"/>
                                        </StackPanel>
                                    </Grid>
                                </Border>

                            </StackPanel>
                        </Border>
                    </DataTemplate>
                </ItemsControl.ItemTemplate>
            </ItemsControl>
        </ScrollViewer>

    </Grid>
</Page>
