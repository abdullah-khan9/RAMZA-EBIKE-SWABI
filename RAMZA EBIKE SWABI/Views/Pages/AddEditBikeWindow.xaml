<Window x:Class="Ramza_EBike_Swabi.Views.Pages.AddEditBikeWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Add/Edit Bike"
        Height="580"
        Width="920"
        WindowStartupLocation="CenterOwner">

    <Grid Margin="12">
        <Grid.ColumnDefinitions>
            <ColumnDefinition Width="237*"/>
            <ColumnDefinition Width="659*"/>
        </Grid.ColumnDefinitions>

        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <!-- Title -->
        <TextBlock x:Name="TitleText"
                   FontSize="20"
                   FontWeight="Bold"
                   Margin="6,6,6,6" Grid.ColumnSpan="2"/>

        <!-- Form Grid -->
        <Grid Grid.Row="1" Margin="6,6,6,6" Grid.ColumnSpan="2">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="*"/>
                <ColumnDefinition Width="*"/>
            </Grid.ColumnDefinitions>

            <!-- ===== LEFT COLUMN ===== -->
            <StackPanel Grid.Column="0"
                        VerticalAlignment="Top"
                        Margin="0,0,12,0">

                <TextBlock Text="Model"/>

                <!-- Model TextBox with Popup below it -->
                <TextBox x:Name="ModelBox"
                         Margin="0,4"
                         TextChanged="ModelBox_TextChanged"/>

                <Popup x:Name="ModelPopup"
                       PlacementTarget="{Binding ElementName=ModelBox}"
                       Placement="Bottom"
                       StaysOpen="False"
                       AllowsTransparency="True">
                    <Border Background="White"
                            BorderBrush="#AAAAAA"
                            BorderThickness="1"
                            MaxHeight="220"
                            MinWidth="280">
                        <ListBox x:Name="ModelSuggestionList"
                                 PreviewMouseDown="ModelSuggestionList_PreviewMouseDown"/>
                    </Border>
                </Popup>

                <TextBlock Text="Brand" Margin="0,8,0,0"/>
                <TextBox x:Name="BrandBox" Margin="0,4"/>

                <TextBlock Text="Motor Power" Margin="0,8,0,0"/>
                <TextBox x:Name="MotorBox" Margin="0,4"/>

                <TextBlock Text="Battery Capacity" Margin="0,8,0,0"/>
                <TextBox x:Name="BatteryBox" Margin="0,4"/>

                <TextBlock Text="Motor Number" Margin="0,8,0,0"/>
                <TextBox x:Name="MotorNumberBox" Margin="0,4"/>

                <TextBlock Text="Chassis Number" Margin="0,8,0,0"/>
                <TextBox x:Name="ChassisNumberBox" Margin="0,4"/>

            </StackPanel>

            <!-- ===== RIGHT COLUMN ===== -->
            <StackPanel Grid.Column="1" VerticalAlignment="Top">

                <TextBlock Text="Color"/>
                <TextBox x:Name="ColorBox" Margin="0,4"/>

                <TextBlock Text="Weight" Margin="0,8,0,0"/>
                <TextBox x:Name="WeightBox" Margin="0,4"/>

                <TextBlock Text="Warranty" Margin="0,8,0,0"/>
                <TextBox x:Name="WarrantyBox" Margin="0,4"/>

                <TextBlock Text="Price (PKR)" Margin="0,8,0,0"/>
                <TextBox x:Name="PriceBox" Margin="0,4"/>

                <TextBlock Text="Quantity" Margin="0,8,0,0"/>
                <TextBox x:Name="QuantityBox" Margin="0,4"/>

                <TextBlock Text="Vendor Name" Margin="0,8,0,0"/>
                <TextBox x:Name="VendorBox" Margin="0,4"/>

            </StackPanel>
        </Grid>

        <!-- Buttons -->
        <StackPanel Grid.Row="2"
                    Orientation="Horizontal"
                    HorizontalAlignment="Right"
                    Margin="0,12,0,0" Grid.Column="1">
            <Button Content="Save"
                    Width="120"
                    Margin="6"
                    Background="#28A745"
                    Foreground="White"
                    Click="Save_Click"/>
            <Button Content="Cancel"
                    Width="120"
                    Margin="6"
                    Click="Cancel_Click"/>
        </StackPanel>

    </Grid>
</Window>
