<Window x:Class="Ramza_EBike_Swabi.Views.Pages.PaymentHistoryWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Payment History"
        Width="820" Height="520"
        WindowStartupLocation="CenterOwner"
        ResizeMode="CanResize"
        Background="#F5F6FA">

    <Grid Margin="20">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
        </Grid.RowDefinitions>

        <!-- Header -->
        <StackPanel Grid.Row="0" Margin="0 0 0 14">
            <TextBlock x:Name="lblTitle"
                       FontSize="20" FontWeight="Bold"
                       Foreground="#2C3E50"/>
            <TextBlock x:Name="lblSubtitle"
                       FontSize="13" Foreground="#777"
                       Margin="0 4 0 0"/>
        </StackPanel>

        <!-- History Grid -->
        <DataGrid x:Name="dgHistory"
                  Grid.Row="1"
                  AutoGenerateColumns="False"
                  IsReadOnly="True"
                  CanUserAddRows="False"
                  RowHeight="40"
                  AlternatingRowBackground="#F9FAFB"
                  Background="White"
                  GridLinesVisibility="None"
                  HeadersVisibility="Column"
                  FontFamily="Segoe UI" FontSize="13">

            <DataGrid.Resources>
                <Style TargetType="DataGridColumnHeader">
                    <Setter Property="Background" Value="#E0E6ED"/>
                    <Setter Property="FontWeight" Value="SemiBold"/>
                    <Setter Property="Padding" Value="10,8"/>
                </Style>
                <Style TargetType="DataGridCell">
                    <Setter Property="Padding" Value="8 4"/>
                    <Setter Property="Template">
                        <Setter.Value>
                            <ControlTemplate TargetType="DataGridCell">
                                <ContentPresenter VerticalAlignment="Center"/>
                            </ControlTemplate>
                        </Setter.Value>
                    </Setter>
                </Style>
            </DataGrid.Resources>

            <DataGrid.Columns>
                <DataGridTextColumn Header="#"             Width="40"
                                    Binding="{Binding RowNumber}"/>
                <DataGridTextColumn Header="Date"          Width="130"
                                    Binding="{Binding PaymentDate, StringFormat='{}{0:dd MMM yyyy}'}"/>
                <DataGridTextColumn Header="Cash (₨)"      Width="100"
                                    Binding="{Binding AmountPaidCash, StringFormat=N0}"/>
                <DataGridTextColumn Header="Account (₨)"   Width="110"
                                    Binding="{Binding AmountPaidAccount, StringFormat=N0}"/>
                <DataGridTextColumn Header="Total (₨)"     Width="100"
                                    Binding="{Binding AmountPaid, StringFormat=N0}"/>
                <DataGridTextColumn Header="Remaining (₨)" Width="115"
                                    Binding="{Binding RemainingAfter, StringFormat=N0}"/>
                <DataGridTextColumn Header="Method"        Width="110"
                                    Binding="{Binding PaymentMethod}"/>
                <DataGridTextColumn Header="Received By"   Width="*"
                                    Binding="{Binding ReceivedBy}"/>

                <!-- ✅ Edit + Delete buttons -->
                <DataGridTemplateColumn Header="Actions" Width="130">
                    <DataGridTemplateColumn.CellTemplate>
                        <DataTemplate>
                            <StackPanel Orientation="Horizontal"
                                        HorizontalAlignment="Center"
                                        Margin="4 0">
                                <Button Content="✏ Edit"
                                        Padding="8 4" FontSize="11"
                                        Background="#3498DB" Foreground="White"
                                        BorderThickness="0" Cursor="Hand"
                                        Margin="0 0 6 0"
                                        Click="EditPayment_Click">
                                    <Button.Template>
                                        <ControlTemplate TargetType="Button">
                                            <Border Background="{TemplateBinding Background}"
                                                    CornerRadius="4" Padding="{TemplateBinding Padding}">
                                                <ContentPresenter HorizontalAlignment="Center"
                                                                  VerticalAlignment="Center"/>
                                            </Border>
                                        </ControlTemplate>
                                    </Button.Template>
                                </Button>
                                <Button Content="🗑 Del"
                                        Padding="8 4" FontSize="11"
                                        Background="#E74C3C" Foreground="White"
                                        BorderThickness="0" Cursor="Hand"
                                        Click="DeletePayment_Click">
                                    <Button.Template>
                                        <ControlTemplate TargetType="Button">
                                            <Border Background="{TemplateBinding Background}"
                                                    CornerRadius="4" Padding="{TemplateBinding Padding}">
                                                <ContentPresenter HorizontalAlignment="Center"
                                                                  VerticalAlignment="Center"/>
                                            </Border>
                                        </ControlTemplate>
                                    </Button.Template>
                                </Button>
                            </StackPanel>
                        </DataTemplate>
                    </DataGridTemplateColumn.CellTemplate>
                </DataGridTemplateColumn>
            </DataGrid.Columns>
        </DataGrid>
    </Grid>
</Window>
