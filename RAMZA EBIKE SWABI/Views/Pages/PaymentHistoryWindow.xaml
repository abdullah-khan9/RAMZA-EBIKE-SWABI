<Window x:Class="Ramza_EBike_Swabi.Views.Pages.PaymentHistoryWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Payment History"
        Width="680" Height="450"
        WindowStartupLocation="CenterOwner"
        ResizeMode="CanResize"
        Background="#F5F6FA">

    <Grid Margin="20">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
        </Grid.RowDefinitions>

        <!-- Header -->
        <StackPanel Grid.Row="0" Margin="0 0 0 14">
            <TextBlock x:Name="lblTitle"
                       FontSize="20" FontWeight="Bold"
                       Foreground="#2C3E50"/>
            <TextBlock x:Name="lblSubtitle"
                       FontSize="13" Foreground="#777"
                       Margin="0 4 0 0"/>
        </StackPanel>

        <!-- History Grid -->
        <DataGrid x:Name="dgHistory"
                  Grid.Row="1"
                  AutoGenerateColumns="False"
                  IsReadOnly="True"
                  CanUserAddRows="False"
                  RowHeight="38"
                  AlternatingRowBackground="#F9FAFB"
                  Background="White"
                  GridLinesVisibility="None"
                  HeadersVisibility="Column"
                  FontFamily="Segoe UI" FontSize="13">

            <DataGrid.Resources>
                <Style TargetType="DataGridColumnHeader">
                    <Setter Property="Background" Value="#E0E6ED"/>
                    <Setter Property="FontWeight" Value="SemiBold"/>
                    <Setter Property="Padding" Value="10,8"/>
                </Style>
            </DataGrid.Resources>

            <DataGrid.Columns>
                <DataGridTextColumn Header="#" Width="45"
                                    Binding="{Binding RowNumber}"/>
                <DataGridTextColumn Header="Date &amp; Time" Width="160"
                                    Binding="{Binding PaymentDate,
                                        StringFormat='{}{0:dd MMM yyyy  HH:mm}'}"/>
                <DataGridTextColumn Header="Amount Paid" Width="120"
                                    Binding="{Binding AmountPaid,
                                        StringFormat='₨ {0:N0}'}"/>
                <DataGridTextColumn Header="Remaining After" Width="130"
                                    Binding="{Binding RemainingAfter,
                                        StringFormat='₨ {0:N0}'}"/>
                <DataGridTextColumn Header="Method" Width="110"
                                    Binding="{Binding PaymentMethod}"/>
                <DataGridTextColumn Header="Received By" Width="*"
                                    Binding="{Binding ReceivedBy}"/>
            </DataGrid.Columns>
        </DataGrid>
    </Grid>
</Window>