<!-- GenerateInvoicePage.xaml -->
<Page x:Class="Ramza_EBike_Swabi.Views.Pages.GenerateInvoicePage"
      xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
      xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
      Background="#F4F6F9"
      Title="Generate Invoice">

    <ScrollViewer VerticalScrollBarVisibility="Auto">
        <Grid Margin="16">

            <Grid.RowDefinitions>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="Auto"/>
            </Grid.RowDefinitions>

            <!-- CUSTOMER DETAILS -->
            <Border Grid.Row="0"
                    Background="White" CornerRadius="10"
                    Padding="15" Margin="0 0 0 12">
                <StackPanel>
                    <TextBlock Text="Customer Details"
                               FontSize="16" FontWeight="Bold" Margin="0 0 0 10"/>
                    <UniformGrid Columns="5">
                        <StackPanel Margin="0 0 8 0">
                            <TextBlock Text="Name *"/>
                            <TextBox x:Name="txtName" TextChanged="MarkDirty"/>
                        </StackPanel>
                        <StackPanel Margin="0 0 8 0">
                            <TextBlock Text="Father Name"/>
                            <TextBox x:Name="txtFName" TextChanged="MarkDirty"/>
                        </StackPanel>
                        <StackPanel Margin="0 0 8 0">
                            <TextBlock Text="Contact *"/>
                            <TextBox x:Name="txtContact" TextChanged="MarkDirty"/>
                        </StackPanel>
                        <StackPanel Margin="0 0 8 0">
                            <TextBlock Text="CNIC"/>
                            <TextBox x:Name="txtCNIC" TextChanged="MarkDirty"/>
                        </StackPanel>
                        <StackPanel>
                            <TextBlock Text="Address"/>
                            <TextBox x:Name="txtAddress" TextChanged="MarkDirty"/>
                        </StackPanel>
                    </UniformGrid>
                </StackPanel>
            </Border>

            <!-- BIKE ITEMS TABLE -->
            <Border Grid.Row="1"
                    Background="White" CornerRadius="10"
                    Padding="15" Margin="0 0 0 12">
                <StackPanel>
                    <TextBlock Text="Bike Items"
                               FontSize="16" FontWeight="Bold" Margin="0 0 0 10"/>

                    <DataGrid x:Name="dgBillItems"
                              AutoGenerateColumns="False"
                              CanUserAddRows="False"
                              CanUserDeleteRows="False"
                              RowHeight="36"
                              CellEditEnding="DgBillItems_CellEditEnding"
                              ScrollViewer.HorizontalScrollBarVisibility="Auto">

                        <DataGrid.Columns>
                            <DataGridTemplateColumn Header="Motor No. *" Width="120">
                                <DataGridTemplateColumn.CellTemplate>
                                    <DataTemplate>
                                        <TextBlock Text="{Binding MotorNumber}" Padding="4 2"/>
                                    </DataTemplate>
                                </DataGridTemplateColumn.CellTemplate>
                                <DataGridTemplateColumn.CellEditingTemplate>
                                    <DataTemplate>
                                        <Grid>
                                            <TextBox x:Name="MotorBox"
                                                     Text="{Binding MotorNumber, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}"
                                                     TextChanged="MotorBox_TextChanged"
                                                     BorderThickness="0" Padding="2"/>
                                            <Popup x:Name="MotorPopup"
                                                   PlacementTarget="{Binding ElementName=MotorBox}"
                                                   Placement="Bottom" StaysOpen="False"
                                                   AllowsTransparency="True">
                                                <Border Background="White"
                                                        BorderBrush="#AAAAAA"
                                                        BorderThickness="1" MaxHeight="200">
                                                    <ListBox x:Name="MotorSuggestionList"
                                                             MinWidth="220"
                                                             PreviewMouseDown="MotorSuggestionList_PreviewMouseDown"/>
                                                </Border>
                                            </Popup>
                                        </Grid>
                                    </DataTemplate>
                                </DataGridTemplateColumn.CellEditingTemplate>
                            </DataGridTemplateColumn>

                            <DataGridTextColumn Header="Model"       Binding="{Binding Model}"         IsReadOnly="True" Width="120"/>
                            <DataGridTextColumn Header="Brand"       Binding="{Binding Brand}"         IsReadOnly="True" Width="90"/>
                            <DataGridTextColumn Header="Motor Power" Binding="{Binding MotorPower}"    IsReadOnly="True" Width="90"/>
                            <DataGridTextColumn Header="Chassis No." Binding="{Binding ChassisNumber}" IsReadOnly="True" Width="110"/>
                            <DataGridTextColumn Header="Color"       Binding="{Binding Color}"         IsReadOnly="True" Width="75"/>
                            <DataGridTextColumn Header="Warranty"    Binding="{Binding Warranty}"      IsReadOnly="True" Width="75"/>
                            <DataGridTextColumn Header="Price (PKR)"
                                                Binding="{Binding Price, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}"
                                                Width="100"/>
                            <DataGridTextColumn Header="Qty"
                                                Binding="{Binding Quantity, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}"
                                                Width="55"/>
                            <DataGridTextColumn Header="Total"
                                                Binding="{Binding TotalPrice, StringFormat=N2}"
                                                IsReadOnly="True" Width="110"/>

                            <DataGridTemplateColumn Header="Remove" Width="75">
                                <DataGridTemplateColumn.CellTemplate>
                                    <DataTemplate>
                                        <Button Content="X" Width="50" Height="26"
                                                Background="#DC3545" Foreground="White"
                                                BorderThickness="0"
                                                Click="RemoveBike_Click"/>
                                    </DataTemplate>
                                </DataGridTemplateColumn.CellTemplate>
                            </DataGridTemplateColumn>
                        </DataGrid.Columns>
                    </DataGrid>

                    <TextBlock Text="* Enter Motor Number in the last row to add a bike. A new row appears automatically."
                               FontStyle="Italic" Foreground="#888888"
                               Margin="0 6 0 0" FontSize="11"/>
                </StackPanel>
            </Border>

            <!-- REMARKS + PAYMENT -->
            <Border Grid.Row="2"
                    Background="White" CornerRadius="10"
                    Padding="15" Margin="0 0 0 12">
                <Grid>
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="300"/>
                    </Grid.ColumnDefinitions>

                    <StackPanel Grid.Column="0" Margin="0 0 20 0">
                        <TextBlock Text="Remarks" FontWeight="Bold" Margin="0 0 0 5"/>
                        <TextBox x:Name="txtRemarks" Height="70"
                                 AcceptsReturn="True" TextWrapping="Wrap"
                                 VerticalScrollBarVisibility="Auto"
                                 TextChanged="MarkDirty"/>
                    </StackPanel>

                    <StackPanel Grid.Column="1">
                        <TextBlock Text="Payment Method" FontWeight="Bold" Margin="0 0 0 8"/>
                        <StackPanel Orientation="Horizontal" Margin="0 0 0 8">
                            <RadioButton x:Name="rbCash" Content="Cash"
                                         GroupName="PaymentMethod" IsChecked="True"
                                         FontSize="14" Margin="0 0 20 0"
                                         Checked="PaymentMethod_Changed"/>
                            <RadioButton x:Name="rbAccount" Content="Account / Bank Transfer"
                                         GroupName="PaymentMethod" FontSize="14"
                                         Checked="PaymentMethod_Changed"/>
                        </StackPanel>
                        <StackPanel x:Name="pnlAccountDetail" Visibility="Collapsed">
                            <TextBlock Text="Account / Bank Detail" Margin="0 0 0 4"/>
                            <TextBox x:Name="txtAccountDetail" Height="32"
                                     VerticalContentAlignment="Center" Padding="4 0"
                                     TextChanged="MarkDirty"/>
                        </StackPanel>

                        <!-- ✅ NEW: Due Date -->
                        <Separator Margin="0 10"/>
                        <TextBlock Text="Due Date (optional)" FontWeight="Bold" Margin="0 0 0 5"
                                   ToolTip="Set a due date if the customer will pay remaining balance later"/>
                        <DatePicker x:Name="dpDueDate"
                                    Height="32"
                                    SelectedDateChanged="DpDueDate_Changed"/>
                        <TextBlock Text="Leave blank if no due date"
                                   FontSize="11" Foreground="#888" Margin="0 3 0 0"/>
                    </StackPanel>
                </Grid>
            </Border>

            <!-- TOTALS + BUTTONS -->
            <Border Grid.Row="3"
                    Background="White" CornerRadius="10"
                    Padding="15">
                <StackPanel>
                    <StackPanel Orientation="Horizontal" HorizontalAlignment="Right">
                        <StackPanel Margin="10">
                            <TextBlock Text="Total" FontWeight="Bold"/>
                            <TextBlock x:Name="txtTotal" FontSize="16" FontWeight="Bold"/>
                        </StackPanel>
                        <StackPanel Margin="10">
                            <TextBlock Text="Discount"/>
                            <TextBox x:Name="txtDiscount" Width="90" TextChanged="Recalculate"/>
                        </StackPanel>
                        <StackPanel Margin="10">
                            <TextBlock Text="Net Bill" FontWeight="Bold"/>
                            <TextBlock x:Name="txtNetBill" FontSize="16" FontWeight="Bold"/>
                        </StackPanel>
                        <StackPanel Margin="10">
                            <TextBlock Text="Paid (PKR)"/>
                            <TextBox x:Name="txtPaid" Width="110" TextChanged="Recalculate"/>
                        </StackPanel>
                        <StackPanel Margin="10">
                            <TextBlock Text="Remaining" FontWeight="Bold"/>
                            <TextBlock x:Name="txtRemaining" FontSize="16" FontWeight="Bold"
                                       Foreground="#DC3545"/>
                        </StackPanel>
                    </StackPanel>

                    <Separator Margin="0 12"/>

                    <Grid>
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="Auto"/>
                        </Grid.ColumnDefinitions>

                        <StackPanel Grid.Column="0" Orientation="Horizontal">
                            <CheckBox x:Name="chkWarrantyCard"
                                      Content="Warranty Card Given" Margin="0 0 20 0"/>
                            <CheckBox x:Name="chkVoucherCustomer"
                                      Content="Voucher Given to Customer" Margin="0 0 20 0"/>
                            <CheckBox x:Name="chkVoucherCompany"
                                      Content="Voucher Issued by Company"/>
                        </StackPanel>

                        <StackPanel Grid.Column="1" Orientation="Horizontal">
                            <Button Content="Save Invoice"
                                    Width="150" Height="40"
                                    Background="#28A745" Foreground="White"
                                    BorderThickness="0" FontWeight="Bold"
                                    Margin="0 0 10 0"
                                    Click="BtnSaveInvoice_Click"/>
                            <Button Content="Print Invoice"
                                    Width="150" Height="40"
                                    Background="#0D6EFD" Foreground="White"
                                    BorderThickness="0" FontWeight="Bold"
                                    Click="BtnPrintInvoice_Click"/>
                        </StackPanel>
                    </Grid>
                </StackPanel>
            </Border>

        </Grid>
    </ScrollViewer>
</Page>