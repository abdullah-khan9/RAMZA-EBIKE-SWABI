<Page x:Class="Ramza_EBike_Swabi.Views.Pages.VendorBillForm"
      xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
      xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml">

    <Grid Margin="20">

        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <!-- ================= TOP BAR ================= -->
        <StackPanel Orientation="Horizontal" Margin="0 0 0 20">
            <Button Content="← Back"
                    Width="100" Height="35"
                    Background="#FF2B579A" Foreground="White"
                    BorderThickness="0" Click="Back_Click"/>
            <TextBlock x:Name="FormTitle"
                       Text="Add New Vendor Bill"
                       FontSize="26" FontWeight="Bold" Margin="15 0"/>
            <!-- Draft indicator -->
            <Border x:Name="DraftBadge"
                    Visibility="Collapsed"
                    Background="#FFF57F17" CornerRadius="4"
                    Padding="8 4" VerticalAlignment="Center" Margin="10 0 0 0">
                <TextBlock Text="Draft Restored" FontSize="12"
                           Foreground="White" FontWeight="Bold"/>
            </Border>
        </StackPanel>

        <!-- ================= VENDOR INFO ================= -->
        <StackPanel Grid.Row="1" Orientation="Horizontal" Margin="0 0 0 20">
            <StackPanel Width="300">
                <TextBlock Text="Vendor:" FontWeight="Bold"/>
                <TextBlock x:Name="VendorName" FontSize="18"/>
            </StackPanel>
            <StackPanel Width="300" Margin="40 0 0 0">
                <TextBlock x:Name="PreviousBalanceLabel" Text="Previous Balance:" FontWeight="Bold"/>
                <TextBlock x:Name="PreviousBalance" FontSize="18" Foreground="#FFB00020"/>
            </StackPanel>
        </StackPanel>

        <!-- ================= DOCUMENT NUMBER + ADD ROW ================= -->
        <StackPanel Grid.Row="2" Orientation="Horizontal" Margin="0 0 0 10" VerticalAlignment="Center">
            <StackPanel Width="300">
                <TextBlock>
                    <Run Text="Document Number"/>
                    <Run Text=" *" Foreground="Red"/>
                </TextBlock>
                <TextBox x:Name="DocumentNumberBox" TextChanged="DocumentNumberBox_TextChanged"/>
            </StackPanel>
            <Button Content="+ Add Row"
                    Height="30" Padding="10 0" Margin="10 0 0 0"
                    Background="#FF2B579A" Foreground="White"
                    BorderThickness="0" Click="AddRow_Click"/>
        </StackPanel>

        <!-- ================= ITEMS GRID ================= -->
        <DataGrid x:Name="ItemsGrid"
                  Grid.Row="3"
                  AutoGenerateColumns="False"
                  CanUserAddRows="False"
                  CanUserDeleteRows="False"
                  HeadersVisibility="Column"
                  CellEditEnding="ItemsGrid_CellEditEnding"
                  ScrollViewer.HorizontalScrollBarVisibility="Auto"
                  ScrollViewer.VerticalScrollBarVisibility="Auto">

            <DataGrid.Columns>

                <!-- ===== MODEL — Autocomplete Template Column ===== -->
                <DataGridTemplateColumn Header="Model *" Width="160">
                    <DataGridTemplateColumn.CellTemplate>
                        <DataTemplate>
                            <TextBlock Text="{Binding Model}" Padding="4 2"/>
                        </DataTemplate>
                    </DataGridTemplateColumn.CellTemplate>
                    <DataGridTemplateColumn.CellEditingTemplate>
                        <DataTemplate>
                            <Grid x:Name="ModelEditGrid">
                                <TextBox x:Name="ModelAutoBox"
                                         Text="{Binding Model, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}"
                                         TextChanged="ModelAutoBox_TextChanged"
                                         LostFocus="ModelAutoBox_LostFocus"
                                         BorderThickness="0"
                                         Padding="2"/>
                                <Popup x:Name="ModelPopup"
                                       PlacementTarget="{Binding ElementName=ModelAutoBox}"
                                       Placement="Bottom"
                                       StaysOpen="False"
                                       AllowsTransparency="True">
                                    <Border Background="White"
                                            BorderBrush="#AAAAAA"
                                            BorderThickness="1"
                                            MaxHeight="220">
                                        <ListBox x:Name="ModelSuggestionList"
                                                 MinWidth="220"
                                                 PreviewMouseDown="ModelSuggestionList_PreviewMouseDown"/>
                                    </Border>
                                </Popup>
                            </Grid>
                        </DataTemplate>
                    </DataGridTemplateColumn.CellEditingTemplate>
                </DataGridTemplateColumn>

                <!-- ===== BIKE DETAIL COLUMNS ===== -->
                <DataGridTextColumn Header="Brand"
                                    Binding="{Binding Brand, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}"
                                    Width="110"/>
                <DataGridTextColumn Header="Motor Power"
                                    Binding="{Binding MotorPower, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}"
                                    Width="110"/>
                <DataGridTextColumn Header="Battery"
                                    Binding="{Binding BatteryCapacity, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}"
                                    Width="100"/>
                <DataGridTextColumn Header="Motor No."
                                    Binding="{Binding MotorNumber, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}"
                                    Width="110"/>
                <DataGridTextColumn Header="Chassis No."
                                    Binding="{Binding ChassisNumber, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}"
                                    Width="120"/>
                <DataGridTextColumn Header="Color"
                                    Binding="{Binding Color, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}"
                                    Width="90"/>
                <DataGridTextColumn Header="Warranty"
                                    Binding="{Binding Warranty, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}"
                                    Width="90"/>

                <!-- ===== FLAT PRICE CHECKBOX ===== -->
                <DataGridCheckBoxColumn Header="Flat Price?" 
                                        Binding="{Binding IsFlatPrice, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}"
                                        Width="85"/>
                
                <!-- ===== INCENTIVE BIKE CHECKBOX ===== -->
                <DataGridTemplateColumn Header="🎁 Incentive?" Width="90">
                    <DataGridTemplateColumn.CellTemplate>
                        <DataTemplate>
                            <CheckBox IsChecked="{Binding IsIncentiveBike, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}"
                      HorizontalAlignment="Center"
                      VerticalAlignment="Center"
                      Click="IncentiveCheckbox_Click"/>
                        </DataTemplate>
                    </DataGridTemplateColumn.CellTemplate>
                </DataGridTemplateColumn>

                <!-- ===== FINANCIAL COLUMNS ===== -->
                <DataGridTextColumn Header="Qty"
                                    Binding="{Binding Qty, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}"
                                    Width="55"/>

                <!-- Bill Rate = Retail Price in both modes -->
                <DataGridTextColumn Header="Retail Price"
                                    Binding="{Binding BillRate, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}"
                                    Width="95">
                    <DataGridTextColumn.ElementStyle>
                        <Style TargetType="TextBlock">
                            <Setter Property="Foreground" Value="#FF1B4079"/>
                            <Setter Property="FontWeight" Value="Bold"/>
                        </Style>
                    </DataGridTextColumn.ElementStyle>
                </DataGridTextColumn>

                <!-- Flat Purchase Price (only for flat mode) -->
                <DataGridTextColumn Header="Flat Purchase"
                                    Binding="{Binding FlatPurchasePrice, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}"
                                    Width="110">
                    <DataGridTextColumn.ElementStyle>
                        <Style TargetType="TextBlock">
                            <Setter Property="Foreground" Value="#FF6F42C1"/>
                            <Setter Property="FontWeight" Value="Bold"/>
                        </Style>
                    </DataGridTextColumn.ElementStyle>
                </DataGridTextColumn>

                <DataGridTextColumn Header="Comm %"
                                    Binding="{Binding CommissionPercent, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}"
                                    Width="70"/>
                <DataGridTextColumn Header="Tax %"
                                    Binding="{Binding TaxOnCommissionPercent, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}"
                                    Width="60"/>
                <DataGridTextColumn Header="Extra %"
                                    Binding="{Binding ExtraDiscountPercent, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}"
                                    Width="65"/>
                <DataGridTextColumn Header="Commission"
                                    Binding="{Binding CommissionAmount, StringFormat=N2}"
                                    IsReadOnly="True" Width="100"/>
                <DataGridTextColumn Header="Tax/Unit"
                                    Binding="{Binding TaxOnCommissionAmount, StringFormat=N2}"
                                    IsReadOnly="True" Width="85"/>
                <DataGridTextColumn Header="Extra/Unit"
                                    Binding="{Binding ExtraCommissionAmount, StringFormat=N2}"
                                    IsReadOnly="True" Width="90"/>
                <DataGridTextColumn Header="Total Comm."
                                    Binding="{Binding TotalCommissionAmount, StringFormat=N2}"
                                    IsReadOnly="True" Width="100"/>
                <DataGridTextColumn Header="Purchase Price"
                                    Binding="{Binding TotalWholesalePrice, StringFormat=N2}"
                                    IsReadOnly="True" Width="120">
                    <DataGridTextColumn.ElementStyle>
                        <Style TargetType="TextBlock">
                            <Setter Property="Foreground" Value="#FF2E7D32"/>
                            <Setter Property="FontWeight" Value="Bold"/>
                        </Style>
                    </DataGridTextColumn.ElementStyle>
                </DataGridTextColumn>

                <DataGridTemplateColumn Header="Action" Width="80">
                    <DataGridTemplateColumn.CellTemplate>
                        <DataTemplate>
                            <Button Content="Remove" Width="68" Height="24"
                                    Background="#FFB00020" Foreground="White"
                                    BorderThickness="0" Click="RemoveRow_Click"/>
                        </DataTemplate>
                    </DataGridTemplateColumn.CellTemplate>
                </DataGridTemplateColumn>

            </DataGrid.Columns>
        </DataGrid>

        <!-- ================= TOTALS + PAYMENT SOURCE + REMARKS ================= -->
        <Border Grid.Row="4" Margin="0 10" Padding="12"
                Background="#F8F8F8" BorderBrush="#DDD" BorderThickness="1">
            <StackPanel>

                <!-- Row 1: Amount Paid + Payment Source -->
                <StackPanel Orientation="Horizontal" Margin="0 0 0 10">

                    <!-- Amount Paid -->
                    <StackPanel Width="220">
                        <TextBlock Text="Amount Paid:" FontWeight="Bold"/>
                        <TextBox x:Name="AmountPaidBox"
                                 Height="30"
                                 TextChanged="AmountPaidBox_TextChanged"/>
                    </StackPanel>

                    <!-- Payment Source -->
                    <Border Margin="20 0 0 0" Padding="10 6"
                            Background="White" BorderBrush="#CCCCCC" BorderThickness="1"
                            CornerRadius="4">
                        <StackPanel>
                            <TextBlock Text="Pay From:" FontWeight="Bold" Margin="0 0 0 4"/>
                            <StackPanel Orientation="Horizontal">
                                <RadioButton x:Name="rbPayCash"
                                             Content="Cash Balance"
                                             GroupName="PaySource"
                                             IsChecked="True"
                                             VerticalContentAlignment="Center"
                                             Margin="0 0 16 0"/>
                                <RadioButton x:Name="rbPayAccount"
                                             Content="Account Balance"
                                             GroupName="PaySource"
                                             VerticalContentAlignment="Center"
                                             Margin="0 0 16 0"/>
                                <RadioButton x:Name="rbPayVendorCash"
                                             Content="Vendor Cash"
                                             GroupName="PaySource"
                                             VerticalContentAlignment="Center"
                                             Margin="0 0 16 0"/>
                                <RadioButton x:Name="rbPayNone"
                                             Content="Not Paid Now"
                                             GroupName="PaySource"
                                             VerticalContentAlignment="Center"/>
                            </StackPanel>
                            <!-- Available balance hint -->
                            <TextBlock x:Name="txtPaySourceHint"
                                       Margin="0 4 0 0"
                                       Foreground="#FF1B4079"
                                       FontSize="12"/>
                            <!-- After-payment preview -->
                            <TextBlock x:Name="txtPayAfterPreview"
                                       Margin="0 2 0 0"
                                       Foreground="#FF555555"
                                       FontSize="12"/>
                        </StackPanel>
                    </Border>

                    <!-- Remarks -->
                    <StackPanel Margin="20 0 0 0" Width="300">
                        <TextBlock Text="Remarks (shown on bill):" FontWeight="Bold"/>
                        <TextBox x:Name="RemarksBox"
                                 Height="54"
                                 AcceptsReturn="True"
                                 TextWrapping="Wrap"
                                 VerticalScrollBarVisibility="Auto"
                                 Padding="6 4"
                                 TextChanged="RemarksBox_TextChanged"/>
                    </StackPanel>

                </StackPanel>

                <!-- Row 2: Bill totals -->
                <StackPanel Orientation="Horizontal">
                    <StackPanel Width="250">
                        <TextBlock Text="Total Purchase Amount:" FontWeight="Bold"/>
                        <TextBlock x:Name="TotalAmountText" FontSize="18" FontWeight="Bold" Foreground="#FF2E7D32"/>
                    </StackPanel>
                    <StackPanel Width="220" Margin="20 0 0 0">
                        <TextBlock Text="Total Commission Granted:" FontWeight="Bold"/>
                        <TextBlock x:Name="TotalCommissionText" FontSize="18" FontWeight="Bold"/>
                    </StackPanel>
                    <StackPanel Width="220" Margin="20 0 0 0">
                        <TextBlock Text="Total Tax Paid:" FontWeight="Bold"/>
                        <TextBlock x:Name="TotalTaxText" FontSize="18" FontWeight="Bold"/>
                    </StackPanel>
                    <StackPanel Width="220" Margin="20 0 0 0">
                        <TextBlock Text="Remaining After Payment:" FontWeight="Bold"/>
                        <TextBlock x:Name="txtRemainingPreview" FontSize="18" FontWeight="Bold"
                                   Foreground="#FFB00020"/>
                    </StackPanel>
                </StackPanel>

            </StackPanel>
        </Border>   

        <!-- ================= BUTTONS ================= -->
        <StackPanel Grid.Row="5" Orientation="Horizontal"
                    HorizontalAlignment="Center" Margin="0 20 0 0">
            <Button Content="Save Bill"
                    Width="200" Height="45"
                    Background="#FF1B4079" Foreground="White"
                    BorderThickness="0" FontSize="18" FontWeight="Bold"
                    Click="Save_Click" Margin="0 0 10 0"/>
            <Button Content="Calculate Bill"
                    Width="200" Height="45"
                    Background="#FF2B579A" Foreground="White"
                    BorderThickness="0" FontSize="18" FontWeight="Bold"
                    Click="Calculate_Click" Margin="0 0 10 0"/>
            <Button Content="Clear Draft"
                    Width="160" Height="45"
                    Background="#FF616161" Foreground="White"
                    BorderThickness="0" FontSize="16" FontWeight="Bold"
                    Click="ClearDraft_Click"/>
        </StackPanel>

    </Grid>
</Page>