<Page x:Class="Ramza_EBike_Swabi.Views.Pages.VendorCashPage"
      xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
      xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
      Background="#F4F6F9">

    <Page.Resources>

        <!-- Vendor Summary Card Style -->
        <Style x:Key="VendorCardBorder" TargetType="Border">
            <Setter Property="Background" Value="White"/>
            <Setter Property="CornerRadius" Value="10"/>
            <Setter Property="Padding" Value="14 10"/>
            <Setter Property="Margin" Value="0 0 0 8"/>
            <Setter Property="BorderBrush" Value="#E8ECF0"/>
            <Setter Property="BorderThickness" Value="1"/>
        </Style>

        <Style x:Key="LedgerRowStyle" TargetType="DataGridRow">
            <Setter Property="Background" Value="White"/>
            <Setter Property="Foreground" Value="#1F2937"/>
            <Style.Triggers>
                <DataTrigger Binding="{Binding TypeDisplay}" Value="Cash Added">
                    <Setter Property="Background" Value="#F0FFF4"/>
                </DataTrigger>
                <DataTrigger Binding="{Binding TypeDisplay}" Value="Applied to Bill Balance">
                    <Setter Property="Background" Value="#FFF7ED"/>
                </DataTrigger>
                <Trigger Property="IsSelected" Value="True">
                    <Setter Property="Background" Value="#DBEAFE"/>
                    <Setter Property="Foreground" Value="#1E3A5F"/>
                </Trigger>
            </Style.Triggers>
        </Style>

    </Page.Resources>

    <Grid Margin="20">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <!-- Top bar -->
            <RowDefinition Height="Auto"/>
            <!-- Summary cards -->
            <RowDefinition Height="Auto"/>
            <!-- Filter bar -->
            <RowDefinition Height="*"/>
            <!-- Content split -->
        </Grid.RowDefinitions>

        <!-- ══════════════════════════════════════════════════════ -->
        <!-- TOP BAR -->
        <!-- ══════════════════════════════════════════════════════ -->
        <Grid Grid.Row="0" Margin="0 0 0 16">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="Auto"/>
                <ColumnDefinition Width="*"/>
                <ColumnDefinition Width="Auto"/>
            </Grid.ColumnDefinitions>

            <Button Grid.Column="0" Content="← Back" Width="110" Height="36"
                    FontWeight="Bold" FontSize="13"
                    Background="#FF2B579A" Foreground="White"
                    BorderThickness="0" Cursor="Hand" Click="Back_Click"/>

            <TextBlock Grid.Column="1"
                       Text="Vendor Cash Management"
                       FontSize="24" FontWeight="Bold"
                       Foreground="#1B2A4A"
                       HorizontalAlignment="Center"
                       VerticalAlignment="Center"/>

            <Button Grid.Column="2"
                    Content="➕ Add Cash to Vendor"
                    Width="180" Height="36"
                    Background="#FF1B8A3D" Foreground="White"
                    FontWeight="Bold" FontSize="13"
                    BorderThickness="0" Cursor="Hand"
                    Click="AddCash_Click"/>
        </Grid>

        <!-- ══════════════════════════════════════════════════════ -->
        <!-- VENDOR SUMMARY CARDS ROW -->
        <!-- ══════════════════════════════════════════════════════ -->
        <Border Grid.Row="1" Background="White" CornerRadius="10"
                Padding="16 12" Margin="0 0 0 14"
                BorderBrush="#E2E8F0" BorderThickness="1">
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="*"/>
                </Grid.ColumnDefinitions>

                <!-- Total Vendor Cash -->
                <StackPanel Grid.Column="0" HorizontalAlignment="Center">
                    <TextBlock Text="💰 Total Vendor Cash" FontSize="12"
                               Foreground="#666" FontWeight="Bold" HorizontalAlignment="Center"/>
                    <TextBlock x:Name="txtTotalVendorCash"
                               FontSize="22" FontWeight="Bold"
                               Foreground="#1B8A3D" HorizontalAlignment="Center"
                               Margin="0 4 0 0"/>
                </StackPanel>

                <!-- Total Remaining (bill balance across all vendors) -->
                <StackPanel Grid.Column="1" HorizontalAlignment="Center">
                    <TextBlock Text="📋 Total Remaining Bills" FontSize="12"
                               Foreground="#666" FontWeight="Bold" HorizontalAlignment="Center"/>
                    <TextBlock x:Name="txtTotalRemaining"
                               FontSize="22" FontWeight="Bold"
                               Foreground="#C0392B" HorizontalAlignment="Center"
                               Margin="0 4 0 0"/>
                </StackPanel>

                <!-- Total Transactions Today -->
                <StackPanel Grid.Column="2" HorizontalAlignment="Center">
                    <TextBlock Text="📅 Added Today" FontSize="12"
                               Foreground="#666" FontWeight="Bold" HorizontalAlignment="Center"/>
                    <TextBlock x:Name="txtAddedToday"
                               FontSize="22" FontWeight="Bold"
                               Foreground="#1B4079" HorizontalAlignment="Center"
                               Margin="0 4 0 0"/>
                </StackPanel>

                <!-- Vendors with Cash -->
                <StackPanel Grid.Column="3" HorizontalAlignment="Center">
                    <TextBlock Text="🏪 Vendors with Cash" FontSize="12"
                               Foreground="#666" FontWeight="Bold" HorizontalAlignment="Center"/>
                    <TextBlock x:Name="txtVendorsWithCash"
                               FontSize="22" FontWeight="Bold"
                               Foreground="#6A1B9A" HorizontalAlignment="Center"
                               Margin="0 4 0 0"/>
                </StackPanel>
            </Grid>
        </Border>

        <!-- ══════════════════════════════════════════════════════ -->
        <!-- FILTER / SEARCH BAR -->
        <!-- ══════════════════════════════════════════════════════ -->
        <Border Grid.Row="2" Background="White" CornerRadius="8"
                Padding="12 8" Margin="0 0 0 10"
                BorderBrush="#E2E8F0" BorderThickness="1">
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="Auto"/>
                </Grid.ColumnDefinitions>

                <StackPanel Grid.Column="0" Orientation="Horizontal" VerticalAlignment="Center">
                    <TextBlock Text="Filter Vendor:" VerticalAlignment="Center"
                               FontWeight="Bold" Margin="0 0 8 0" FontSize="13"/>
                    <ComboBox x:Name="cmbFilterVendor"
                              Width="200" Height="32" FontSize="13"
                              SelectionChanged="FilterVendor_Changed">
                        <ComboBoxItem Content="All Vendors" IsSelected="True"/>
                    </ComboBox>

                    <TextBlock Text="  Type:" VerticalAlignment="Center"
                               FontWeight="Bold" Margin="12 0 8 0" FontSize="13"/>
                    <ComboBox x:Name="cmbFilterType"
                              Width="180" Height="32" FontSize="13"
                              SelectionChanged="FilterType_Changed">
                        <ComboBoxItem Content="All Types" IsSelected="True"/>
                        <ComboBoxItem Content="Cash Added"/>
                        <ComboBoxItem Content="Applied to Bill"/>
                    </ComboBox>

                    <TextBlock Text="  From:" VerticalAlignment="Center"
                               FontWeight="Bold" Margin="12 0 8 0"/>
                    <DatePicker x:Name="dpFrom" Width="130" Height="32"/>

                    <TextBlock Text="To:" VerticalAlignment="Center"
                               FontWeight="Bold" Margin="10 0 8 0"/>
                    <DatePicker x:Name="dpTo" Width="130" Height="32"/>

                    <Button Content="Filter" Width="75" Height="32" Margin="8 0 0 0"
                            Background="#1B4079" Foreground="White"
                            BorderThickness="0" Cursor="Hand" Click="Filter_Click"/>
                    <Button Content="Reset" Width="70" Height="32" Margin="6 0 0 0"
                            Background="#616161" Foreground="White"
                            BorderThickness="0" Cursor="Hand" Click="Reset_Click"/>

                    <TextBlock x:Name="txtRecordCount"
                               VerticalAlignment="Center"
                               Margin="16 0 0 0" FontStyle="Italic"
                               Foreground="#666" FontSize="12"/>
                </StackPanel>

                <!-- Clear History Button -->
                <Button Grid.Column="1"
                        Content="Clear History"
                        Width="130" Height="32"
                        Background="#FFC62828" Foreground="White"
                        FontWeight="Bold" BorderThickness="0"
                        Cursor="Hand" Click="ClearHistory_Click"
                        ToolTip="Clear transaction history (balances remain unchanged)"/>
            </Grid>
        </Border>

        <!-- ══════════════════════════════════════════════════════ -->
        <!-- MAIN CONTENT: Left = Vendor List, Right = Ledger -->
        <!-- ══════════════════════════════════════════════════════ -->
        <Grid Grid.Row="3">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="300"/>
                <ColumnDefinition Width="12"/>
                <ColumnDefinition Width="*"/>
            </Grid.ColumnDefinitions>

            <!-- ─── LEFT: Vendor List ─── -->
            <Border Grid.Column="0" Background="White" CornerRadius="10"
                    BorderBrush="#E2E8F0" BorderThickness="1">
                <Grid>
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="*"/>
                    </Grid.RowDefinitions>

                    <!-- Vendor list header -->
                    <Border Grid.Row="0" Background="#1B4079" CornerRadius="10 10 0 0"
                            Padding="14 10">
                        <TextBlock Text="Vendors" FontSize="15" FontWeight="Bold"
                                   Foreground="White"/>
                    </Border>

                    <!-- Vendor items scroll -->
                    <ScrollViewer Grid.Row="1" VerticalScrollBarVisibility="Auto">
                        <StackPanel x:Name="VendorListPanel" Margin="8"/>
                    </ScrollViewer>
                </Grid>
            </Border>

            <!-- ─── RIGHT: Transaction Ledger ─── -->
            <Border Grid.Column="2" Background="White" CornerRadius="10"
                    BorderBrush="#E2E8F0" BorderThickness="1">
                <Grid>
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="*"/>
                    </Grid.RowDefinitions>

                    <!-- Ledger header -->
                    <Border Grid.Row="0" Background="#1B4079" CornerRadius="10 10 0 0"
                            Padding="14 10">
                        <Grid>
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*"/>
                                <ColumnDefinition Width="Auto"/>
                            </Grid.ColumnDefinitions>
                            <TextBlock x:Name="txtLedgerTitle"
                                       Text="All Transaction History"
                                       FontSize="15" FontWeight="Bold"
                                       Foreground="White" VerticalAlignment="Center"/>
                            <StackPanel Grid.Column="1" Orientation="Horizontal">
                                <TextBlock x:Name="txtLedgerVendorBalance"
                                           FontSize="13" Foreground="#BBDEFB"
                                           VerticalAlignment="Center" Margin="0 0 16 0"/>
                            </StackPanel>
                        </Grid>
                    </Border>

                    <!-- Ledger DataGrid -->
                    <DataGrid x:Name="LedgerGrid" Grid.Row="1"
                              AutoGenerateColumns="False"
                              IsReadOnly="True"
                              CanUserAddRows="False"
                              HeadersVisibility="Column"
                              AlternatingRowBackground="#F8FAFF"
                              RowHeight="36"
                              RowStyle="{StaticResource LedgerRowStyle}"
                              GridLinesVisibility="Horizontal"
                              HorizontalGridLinesBrush="#EEF0F4">
                        <DataGrid.Columns>

                            <DataGridTextColumn Header="#"
                                                Binding="{Binding Id}"
                                                Width="50"/>

                            <DataGridTextColumn Header="Date"
                                                Binding="{Binding TransactionDate, StringFormat={}{0:dd-MMM-yyyy}}"
                                                Width="100"/>

                            <DataGridTextColumn Header="Time"
                                                Binding="{Binding TransactionDate, StringFormat={}{0:hh:mm tt}}"
                                                Width="85"/>

                            <DataGridTextColumn Header="Vendor"
                                                Binding="{Binding VendorName}"
                                                Width="120"/>

                            <DataGridTextColumn Header="Type"
                                                Binding="{Binding TypeDisplay}"
                                                Width="160"/>

                            <DataGridTextColumn Header="By Whom"
                                                Binding="{Binding ByWhom}"
                                                Width="110"/>

                            <DataGridTextColumn Header="Amount (PKR)"
                                                Binding="{Binding Amount, StringFormat=N2}"
                                                Width="115"
                                                FontWeight="Bold"/>

                            <DataGridTextColumn Header="Source"
                                                Binding="{Binding Source}"
                                                Width="75"/>

                            <DataGridTextColumn Header="Cash After"
                                                Binding="{Binding VendorCashBalanceAfter, StringFormat=N2}"
                                                Width="110"/>

                            <DataGridTextColumn Header="Remarks"
                                                Binding="{Binding Remarks}"
                                                Width="*"/>

                            <!-- Actions column -->
                            <DataGridTemplateColumn Header="Actions" Width="120">
                                <DataGridTemplateColumn.CellTemplate>
                                    <DataTemplate>
                                        <StackPanel Orientation="Horizontal"
                                                    HorizontalAlignment="Center"
                                                    VerticalAlignment="Center">
                                            <Button Content="✏️"
                                                    Width="42" Height="28" Margin="0 0 4 0"
                                                    Background="#FF1E88E5" Foreground="White"
                                                    FontSize="13" BorderThickness="0"
                                                    Cursor="Hand"
                                                    ToolTip="Edit this transaction"
                                                    Click="EditLedger_Click"/>
                                            <Button Content="🗑️"
                                                    Width="42" Height="28"
                                                    Background="#FFC62828" Foreground="White"
                                                    FontSize="13" BorderThickness="0"
                                                    Cursor="Hand"
                                                    ToolTip="Delete this transaction"
                                                    Click="DeleteLedger_Click"/>
                                        </StackPanel>
                                    </DataTemplate>
                                </DataGridTemplateColumn.CellTemplate>
                            </DataGridTemplateColumn>

                        </DataGrid.Columns>
                    </DataGrid>
                </Grid>
            </Border>
        </Grid>
    </Grid>
</Page>
