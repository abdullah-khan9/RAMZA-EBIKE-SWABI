<Page x:Class="Ramza_EBike_Swabi.Views.Pages.VendorLedgerPage"
      xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
      xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml">

    <Page.Resources>
        <Style x:Key="ColHeader" TargetType="DataGridColumnHeader">
            <Setter Property="Background" Value="#FF1B4079"/>
            <Setter Property="Foreground" Value="White"/>
            <Setter Property="FontWeight" Value="Bold"/>
            <Setter Property="Padding" Value="8 5"/>
            <Setter Property="BorderThickness" Value="0 0 1 0"/>
            <Setter Property="BorderBrush" Value="#FF2B5299"/>
        </Style>
        <Style x:Key="BillRowStyle" TargetType="DataGridRow">
            <Setter Property="Background" Value="White"/>
            <Style.Triggers>
                <DataTrigger Binding="{Binding RowColor}" Value="Red">
                    <Setter Property="Background" Value="#FFFFF3F3"/>
                </DataTrigger>
                <DataTrigger Binding="{Binding RowColor}" Value="Blue">
                    <Setter Property="Background" Value="#FFE3F2FD"/>
                </DataTrigger>
                <Trigger Property="IsSelected" Value="True">
                    <Setter Property="Background" Value="#FF1565C0"/>
                    <Setter Property="Foreground" Value="White"/>
                </Trigger>
            </Style.Triggers>
        </Style>
        <Style x:Key="CashRowStyle" TargetType="DataGridRow">
            <Setter Property="Background" Value="White"/>
            <Style.Triggers>
                <DataTrigger Binding="{Binding RowColor}" Value="Green">
                    <Setter Property="Background" Value="#FFE8F5E9"/>
                </DataTrigger>
                <DataTrigger Binding="{Binding RowColor}" Value="Orange">
                    <Setter Property="Background" Value="#FFFFF8E1"/>
                </DataTrigger>
                <Trigger Property="IsSelected" Value="True">
                    <Setter Property="Background" Value="#FF1565C0"/>
                    <Setter Property="Foreground" Value="White"/>
                </Trigger>
            </Style.Triggers>
        </Style>
        <Style x:Key="TabStyle" TargetType="TabItem">
            <Setter Property="FontWeight" Value="Bold"/>
            <Setter Property="FontSize" Value="13"/>
            <Setter Property="Padding" Value="16 8"/>
        </Style>
    </Page.Resources>

    <Grid Margin="20">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
        </Grid.RowDefinitions>

        <!-- TOP BAR -->
        <Grid Grid.Row="0" Margin="0 0 0 14">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="Auto"/>
                <ColumnDefinition Width="*"/>
                <ColumnDefinition Width="Auto"/>
            </Grid.ColumnDefinitions>
            <StackPanel Grid.Column="0" Orientation="Horizontal">
                <Button Content="← Back" Width="100" Height="35" FontWeight="Bold"
                        Background="#FF2B579A" Foreground="White"
                        BorderThickness="0" Cursor="Hand" Click="Back_Click"/>
                <TextBlock x:Name="PageTitle" Text="Vendor Ledger"
                           FontSize="24" FontWeight="Bold" Margin="15 0"
                           VerticalAlignment="Center"/>
            </StackPanel>
            <StackPanel Grid.Column="2" Orientation="Horizontal">
                <Button Content="🗑 Clear History" Width="130" Height="35"
                        FontWeight="Bold" Background="#FFB71C1C" Foreground="White"
                        BorderThickness="0" Cursor="Hand" Margin="0 0 8 0"
                        Click="ClearHistory_Click"
                        ToolTip="Is vendor ki ledger history delete karein"/>
                <Button Content="⬇ Download PDF" Width="140" Height="35"
                        FontWeight="Bold" Background="#FF2E7D32" Foreground="White"
                        BorderThickness="0" Cursor="Hand"
                        Click="DownloadPdf_Click"
                        ToolTip="Active tab ki ledger PDF mein download karein"/>
            </StackPanel>
        </Grid>

        <!-- SUMMARY CARD -->
        <Border Grid.Row="1" Padding="14" Background="#FFF3F3F3"
                CornerRadius="8" Margin="0 0 0 14">
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="155"/>
                    <ColumnDefinition Width="155"/>
                    <ColumnDefinition Width="155"/>
                    <ColumnDefinition Width="155"/>
                </Grid.ColumnDefinitions>
                <StackPanel Grid.Column="0">
                    <TextBlock x:Name="VendorNameText" FontSize="19" FontWeight="Bold"/>
                    <TextBlock x:Name="VendorIdText" FontSize="12" Foreground="#666" Margin="0 2 0 0"/>
                </StackPanel>
                <StackPanel Grid.Column="1" Margin="8 0 0 0">
                    <TextBlock Text="Total Bills" FontSize="11" Foreground="#666"/>
                    <TextBlock x:Name="TotalBillsText" FontSize="16" FontWeight="Bold" Foreground="#1B4079"/>
                </StackPanel>
                <StackPanel Grid.Column="2" Margin="8 0 0 0">
                    <TextBlock Text="Total Paid" FontSize="11" Foreground="#666"/>
                    <TextBlock x:Name="TotalPaidText" FontSize="16" FontWeight="Bold" Foreground="#1B8A3D"/>
                </StackPanel>
                <StackPanel Grid.Column="3" Margin="8 0 0 0">
                    <TextBlock Text="Vendor Cash" FontSize="11" Foreground="#666"/>
                    <TextBlock x:Name="VendorCashText" FontSize="16" FontWeight="Bold" Foreground="#6A1B9A"/>
                </StackPanel>
                <StackPanel Grid.Column="4" Margin="8 0 0 0">
                    <TextBlock Text="Outstanding" FontSize="11" Foreground="#666"/>
                    <TextBlock x:Name="OutstandingText" FontSize="16" FontWeight="Bold" Foreground="#B00020"/>
                </StackPanel>
            </Grid>
        </Border>

        <!-- FILTER BAR -->
        <Border Grid.Row="2" Padding="10" Background="#FAFAFA"
                BorderBrush="#DDD" BorderThickness="1"
                CornerRadius="6" Margin="0 0 0 10">
            <StackPanel Orientation="Horizontal" VerticalAlignment="Center">
                <TextBlock Text="From:" VerticalAlignment="Center" FontWeight="Bold" Margin="0 0 5 0"/>
                <DatePicker x:Name="FromDate" Width="125" Height="30" SelectedDateChanged="Filter_Changed"/>
                <TextBlock Text="To:" VerticalAlignment="Center" FontWeight="Bold" Margin="14 0 5 0"/>
                <DatePicker x:Name="ToDate" Width="125" Height="30" SelectedDateChanged="Filter_Changed"/>
                <Button Content="Clear Filter" Width="85" Height="30" Margin="14 0 0 0"
                        Background="#FF616161" Foreground="White"
                        BorderThickness="0" Cursor="Hand" Click="ClearFilters_Click"/>
                <TextBlock x:Name="RowCountText" VerticalAlignment="Center"
                           Margin="14 0 0 0" FontStyle="Italic" Foreground="#666" FontSize="12"/>
            </StackPanel>
        </Border>

        <!-- TABS -->
        <TabControl Grid.Row="3" x:Name="MainTabs" SelectionChanged="MainTabs_SelectionChanged">

            <!-- TAB 1: BILLS -->
            <TabItem Header="📄 Bills &amp; Payments" Style="{StaticResource TabStyle}">
                <Grid>
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="*"/>
                    </Grid.RowDefinitions>
                    <StackPanel Grid.Row="0" Orientation="Horizontal" Margin="4 8 0 6">
                        <Border Width="12" Height="12" Background="#FFFFF3F3" BorderBrush="#CCC" BorderThickness="1" Margin="0 0 4 0"/>
                        <TextBlock Text="Bill Created" VerticalAlignment="Center" FontSize="11" Margin="0 0 14 0"/>
                        <Border Width="12" Height="12" Background="#FFE3F2FD" BorderBrush="#CCC" BorderThickness="1" Margin="0 0 4 0"/>
                        <TextBlock Text="Payment Made" VerticalAlignment="Center" FontSize="11"/>
                    </StackPanel>
                    <DataGrid x:Name="BillsGrid" Grid.Row="1"
                              AutoGenerateColumns="False" HeadersVisibility="Column"
                              SelectionMode="Single" CanUserAddRows="False"
                              IsReadOnly="True" GridLinesVisibility="Horizontal"
                              HorizontalGridLinesBrush="#EEEEEE"
                              RowStyle="{StaticResource BillRowStyle}"
                              ColumnHeaderStyle="{StaticResource ColHeader}">
                        <DataGrid.Columns>
                            <DataGridTextColumn Header="Date" Binding="{Binding Date}" Width="105"/>
                            <DataGridTextColumn Header="Type" Binding="{Binding Type}" Width="160" FontWeight="SemiBold"/>
                            <DataGridTextColumn Header="Description" Binding="{Binding Description}" Width="*"/>
                            <DataGridTextColumn Header="Bill Amount" Binding="{Binding Debit}" Width="120">
                                <DataGridTextColumn.ElementStyle>
                                    <Style TargetType="TextBlock">
                                        <Setter Property="HorizontalAlignment" Value="Right"/>
                                        <Setter Property="Foreground" Value="#B00020"/>
                                        <Setter Property="Padding" Value="0 0 6 0"/>
                                    </Style>
                                </DataGridTextColumn.ElementStyle>
                            </DataGridTextColumn>
                            <DataGridTextColumn Header="Payment (Cash/Acc)" Binding="{Binding Credit}" Width="145">
                                <DataGridTextColumn.ElementStyle>
                                    <Style TargetType="TextBlock">
                                        <Setter Property="HorizontalAlignment" Value="Right"/>
                                        <Setter Property="Foreground" Value="#1B8A3D"/>
                                        <Setter Property="Padding" Value="0 0 6 0"/>
                                    </Style>
                                </DataGridTextColumn.ElementStyle>
                            </DataGridTextColumn>
                            <DataGridTextColumn Header="V.Cash Used" Binding="{Binding VendorCashUsed}" Width="115">
                                <DataGridTextColumn.ElementStyle>
                                    <Style TargetType="TextBlock">
                                        <Setter Property="HorizontalAlignment" Value="Right"/>
                                        <Setter Property="Foreground" Value="#6A1B9A"/>
                                        <Setter Property="Padding" Value="0 0 6 0"/>
                                    </Style>
                                </DataGridTextColumn.ElementStyle>
                            </DataGridTextColumn>
                            <DataGridTextColumn Header="Remaining" Binding="{Binding Remaining}" Width="125" FontWeight="Bold">
                                <DataGridTextColumn.ElementStyle>
                                    <Style TargetType="TextBlock">
                                        <Setter Property="HorizontalAlignment" Value="Right"/>
                                        <Setter Property="Padding" Value="0 0 6 0"/>
                                    </Style>
                                </DataGridTextColumn.ElementStyle>
                            </DataGridTextColumn>
                            <DataGridTextColumn Header="V.Cash Bal." Binding="{Binding VendorCashBalance}" Width="115">
                                <DataGridTextColumn.ElementStyle>
                                    <Style TargetType="TextBlock">
                                        <Setter Property="HorizontalAlignment" Value="Right"/>
                                        <Setter Property="Foreground" Value="#6A1B9A"/>
                                        <Setter Property="Padding" Value="0 0 6 0"/>
                                    </Style>
                                </DataGridTextColumn.ElementStyle>
                            </DataGridTextColumn>
                            <DataGridTextColumn Header="Remarks" Binding="{Binding Remarks}" Width="180"/>
                        </DataGrid.Columns>
                    </DataGrid>
                </Grid>
            </TabItem>

            <!-- TAB 2: VENDOR CASH -->
            <TabItem Header="💰 Vendor Cash" Style="{StaticResource TabStyle}">
                <Grid>
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="*"/>
                    </Grid.RowDefinitions>
                    <StackPanel Grid.Row="0" Orientation="Horizontal" Margin="4 8 0 6">
                        <Border Width="12" Height="12" Background="#FFE8F5E9" BorderBrush="#CCC" BorderThickness="1" Margin="0 0 4 0"/>
                        <TextBlock Text="Cash Added" VerticalAlignment="Center" FontSize="11" Margin="0 0 14 0"/>
                        <Border Width="12" Height="12" Background="#FFFFF8E1" BorderBrush="#CCC" BorderThickness="1" Margin="0 0 4 0"/>
                        <TextBlock Text="Cash Applied / Refunded" VerticalAlignment="Center" FontSize="11"/>
                    </StackPanel>
                    <DataGrid x:Name="CashGrid" Grid.Row="1"
                              AutoGenerateColumns="False" HeadersVisibility="Column"
                              SelectionMode="Single" CanUserAddRows="False"
                              IsReadOnly="True" GridLinesVisibility="Horizontal"
                              HorizontalGridLinesBrush="#EEEEEE"
                              RowStyle="{StaticResource CashRowStyle}"
                              ColumnHeaderStyle="{StaticResource ColHeader}">
                        <DataGrid.Columns>
                            <DataGridTextColumn Header="Date" Binding="{Binding Date}" Width="105"/>
                            <DataGridTextColumn Header="Type" Binding="{Binding Type}" Width="190" FontWeight="SemiBold"/>
                            <DataGridTextColumn Header="Description" Binding="{Binding Description}" Width="*"/>
                            <DataGridTextColumn Header="Amount" Binding="{Binding Amount}" Width="130">
                                <DataGridTextColumn.ElementStyle>
                                    <Style TargetType="TextBlock">
                                        <Setter Property="HorizontalAlignment" Value="Right"/>
                                        <Setter Property="Padding" Value="0 0 6 0"/>
                                    </Style>
                                </DataGridTextColumn.ElementStyle>
                            </DataGridTextColumn>
                            <DataGridTextColumn Header="Remaining V.Cash" Binding="{Binding RemainingVendorCash}" Width="150" FontWeight="Bold">
                                <DataGridTextColumn.ElementStyle>
                                    <Style TargetType="TextBlock">
                                        <Setter Property="HorizontalAlignment" Value="Right"/>
                                        <Setter Property="Foreground" Value="#6A1B9A"/>
                                        <Setter Property="Padding" Value="0 0 6 0"/>
                                    </Style>
                                </DataGridTextColumn.ElementStyle>
                            </DataGridTextColumn>
                            <DataGridTextColumn Header="Remarks" Binding="{Binding Remarks}" Width="250"/>
                        </DataGrid.Columns>
                    </DataGrid>
                </Grid>
            </TabItem>

        </TabControl>
    </Grid>
</Page>