<Window x:Class="Ramza_EBike_Swabi.Views.Pages.AddVendorCashWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Add Cash to Vendor"
        Height="640" Width="560"
        WindowStartupLocation="CenterOwner"
        ResizeMode="NoResize"
        Background="#F4F6F9">

    <ScrollViewer VerticalScrollBarVisibility="Auto">
        <StackPanel Margin="28 24 28 28">

            <TextBlock Text="Add Cash to Vendor"
                       FontSize="20" FontWeight="Bold"
                       Foreground="#1B4079" Margin="0 0 0 20"/>

            <!-- Vendor Selection -->
            <TextBlock Text="Select Vendor *" FontWeight="Bold" FontSize="13" Margin="0 0 0 5"/>
            <ComboBox x:Name="cmbVendor"
                      Height="34" FontSize="13"
                      DisplayMemberPath="VendorName"
                      Margin="0 0 0 14"
                      SelectionChanged="CmbVendor_SelectionChanged"/>

            <!-- Vendor Info Panel -->
            <Border x:Name="pnlVendorInfo"
                    Visibility="Collapsed"
                    Background="#E3F2FD"
                    CornerRadius="6" Padding="12 8"
                    Margin="0 0 0 14">
                <Grid>
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="*"/>
                    </Grid.ColumnDefinitions>
                    <StackPanel Grid.Column="0">
                        <TextBlock Text="Remaining Bill Balance" FontSize="11" Foreground="#555"/>
                        <TextBlock x:Name="txtVendorRemaining"
                                   FontSize="16" FontWeight="Bold" Foreground="#C0392B"/>
                    </StackPanel>
                    <StackPanel Grid.Column="1">
                        <TextBlock Text="Vendor Cash Balance" FontSize="11" Foreground="#555"/>
                        <TextBlock x:Name="txtVendorCash"
                                   FontSize="16" FontWeight="Bold" Foreground="#1B8A3D"/>
                    </StackPanel>
                    <StackPanel Grid.Column="2">
                        <TextBlock Text="After This Payment" FontSize="11" Foreground="#555"/>
                        <TextBlock x:Name="txtAfterPayment"
                                   FontSize="16" FontWeight="Bold" Foreground="#1B4079"/>
                    </StackPanel>
                </Grid>
            </Border>

            <!-- By Whom -->
            <TextBlock Text="By Whom *" FontWeight="Bold" FontSize="13" Margin="0 0 0 5"/>
            <TextBox x:Name="txtByWhom" Height="34"
                     VerticalContentAlignment="Center" Padding="8 0"
                     FontSize="13" Margin="0 0 0 14"/>

            <!-- Amount -->
            <TextBlock Text="Amount (PKR) *" FontWeight="Bold" FontSize="13" Margin="0 0 0 5"/>
            <TextBox x:Name="txtAmount" Height="34"
                     VerticalContentAlignment="Center" Padding="8 0"
                     FontSize="13" Margin="0 0 0 4"
                     TextChanged="TxtAmount_TextChanged"/>
            <TextBlock x:Name="txtAmountHint"
                       FontSize="11" Foreground="#666" FontStyle="Italic"
                       Margin="0 0 0 14"/>

            <!-- Source -->
            <TextBlock Text="Pay From *" FontWeight="Bold" FontSize="13" Margin="0 0 0 8"/>
            <StackPanel Orientation="Horizontal" Margin="0 0 0 14">
                <RadioButton x:Name="rbCash" Content="Cash Balance"
                             GroupName="Source" IsChecked="True"
                             FontSize="13" Margin="0 0 24 0"
                             />
                <RadioButton x:Name="rbAccount" Content="Account Balance"
                             GroupName="Source" FontSize="13"
                             Checked="Source_Changed"/>
            </StackPanel>

            <!-- Available balance hint -->
            <TextBlock x:Name="txtAvailableHint"
                       FontSize="12" Foreground="#1B4079"
                       FontWeight="Bold" Margin="0 0 0 14"/>

            <!-- Date & Time -->
            <TextBlock Text="Date and Time" FontWeight="Bold" FontSize="13" Margin="0 0 0 5"/>
            <StackPanel Orientation="Horizontal" Margin="0 0 0 14">
                <DatePicker x:Name="dpDate" Width="160" Height="34"/>
                <TextBox x:Name="txtTime" Width="90" Height="34"
                         Margin="10 0 0 0" VerticalContentAlignment="Center"
                         Padding="8 0" FontSize="13"/>
                <TextBlock Text="(HH:mm)" VerticalAlignment="Center"
                           Foreground="#888" Margin="8 0 0 0"/>
            </StackPanel>

            <!-- Remarks -->
            <TextBlock Text="Remarks" FontWeight="Bold" FontSize="13" Margin="0 0 0 5"/>
            <TextBox x:Name="txtRemarks" Height="60"
                     AcceptsReturn="True" TextWrapping="Wrap"
                     VerticalScrollBarVisibility="Auto"
                     Padding="8 6" FontSize="13" Margin="0 0 0 24"/>

            <!-- Buttons -->
            <StackPanel Orientation="Horizontal" HorizontalAlignment="Right">
                <Button Content="Cancel" Width="110" Height="40"
                        FontSize="13" Margin="0 0 10 0"
                        Click="Cancel_Click"/>
                <Button Content="Add Cash"
                        Width="140" Height="40"
                        Background="#FF1B4079" Foreground="White"
                        FontWeight="Bold" FontSize="13"
                        BorderThickness="0" Click="Save_Click"/>
            </StackPanel>

        </StackPanel>
    </ScrollViewer>
</Window>
