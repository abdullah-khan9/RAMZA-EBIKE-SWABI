    <Page x:Class="Ramza_EBike_Swabi.Views.Pages.VendorPurchasePage"
          xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
          xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml">

        <Page.Resources>
            <Style x:Key="BillRowStyle" TargetType="DataGridRow">
                <Setter Property="Background" Value="White"/>
                <Setter Property="Foreground" Value="Black"/>
                <Style.Triggers>
                    <DataTrigger Binding="{Binding IsMatch}" Value="True">
                        <Setter Property="Background" Value="#FFFFF176"/>
                        <Setter Property="FontWeight" Value="SemiBold"/>
                    </DataTrigger>
                    <Trigger Property="IsSelected" Value="True">
                        <Setter Property="Background" Value="#FF1E88E5"/>
                        <Setter Property="Foreground" Value="White"/>
                    </Trigger>
                </Style.Triggers>
            </Style>
        </Page.Resources>

        <Grid Margin="20">
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="*"/>
            </Grid.RowDefinitions>

            <!-- TOP BAR -->
            <StackPanel Grid.Row="0" Orientation="Horizontal"
                        VerticalAlignment="Center" Margin="0 0 0 15">
                <Button Content="Back" Width="100" Height="35" FontWeight="Bold"
                        Background="#FF2B579A" Foreground="White"
                        BorderThickness="0" Cursor="Hand" Click="Back_Click"/>
                <TextBlock Text="Vendor Purchases"
                           FontSize="26" FontWeight="Bold" Margin="15 0"/>
            </StackPanel>

            <!-- VENDOR INFO -->
            <Border Grid.Row="1" Padding="15" Background="#FFF3F3F3"
                    CornerRadius="8" Margin="0 0 0 15">
                <Grid>
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="200"/>
                        <ColumnDefinition Width="200"/>
                        <ColumnDefinition Width="Auto"/>
                        <ColumnDefinition Width="Auto"/>
                        <ColumnDefinition Width="Auto"/>
                        <ColumnDefinition Width="Auto"/>
                    </Grid.ColumnDefinitions>

                    <StackPanel Grid.Column="0">
                        <TextBlock x:Name="VendorName" FontSize="20" FontWeight="Bold"/>
                        <TextBlock x:Name="VendorId" FontSize="14" Margin="0 4 0 0"/>
                    </StackPanel>

                    <StackPanel Grid.Column="1" Margin="10 0 0 0">
                        <TextBlock Text="Remaining Bill Balance:" FontSize="12" Foreground="#666"/>
                        <TextBlock x:Name="VendorRemainingBalance"
                                   FontSize="18" FontWeight="Bold" Foreground="#FFB00020"/>
                    </StackPanel>

                    <StackPanel Grid.Column="2" Margin="10 0 0 0">
                        <TextBlock Text="Vendor Cash Balance:" FontSize="12" Foreground="#666"/>
                        <TextBlock x:Name="VendorCashBalanceText"
                                   FontSize="18" FontWeight="Bold" Foreground="#1B8A3D"/>
                    </StackPanel>

                    <Button Grid.Column="3" x:Name="PayRemainingBtn"
                            Content="💳 Pay Remaining"
                            Width="145" Height="40" Margin="0 0 8 0"
                            Background="#FF1B8A3D" Foreground="White"
                            FontWeight="Bold" BorderThickness="0"
                            Cursor="Hand" Click="PayRemaining_Click"
                            ToolTip="Make a payment towards this vendor's outstanding bill balance"/>

                    <Button Grid.Column="4"
                            Content="📋 Pay History"
                            Width="135" Height="40" Margin="0 0 8 0"
                            Background="#FF6A1B9A" Foreground="White"
                            FontWeight="Bold" BorderThickness="0"
                            Cursor="Hand" Click="PaymentHistory_Click"
                            ToolTip="View all payments made to this vendor"/>

                    <Button Grid.Column="5" Content="Close All Bills"
                            Width="140" Height="40" Margin="0 0 8 0"
                            Background="#FFB71C1C" Foreground="White"
                            FontWeight="Bold" BorderThickness="0"
                            Cursor="Hand" Click="CloseBills_Click"
                            ToolTip="Delete all bill records and reset this vendor's balance to zero"/>

                    <Button Grid.Column="6" Content="Add New Bill"
                            Width="155" Height="40"
                            Background="#FF1B4079" Foreground="White"
                            FontWeight="Bold" BorderThickness="0"
                            Cursor="Hand" Click="AddBill_Click"/>
                </Grid>
            </Border>

            <!-- SEARCH BAR -->
            <Border Grid.Row="2" Padding="12" Background="#FAFAFA"
                    BorderBrush="#DDDDDD" BorderThickness="1"
                    CornerRadius="6" Margin="0 0 0 12">
                <StackPanel Orientation="Horizontal" VerticalAlignment="Center">
                    <TextBlock Text="Search By:" VerticalAlignment="Center"
                               FontWeight="Bold" Margin="0 0 8 0"/>
                    <ComboBox x:Name="SearchTypeCombo" Width="165" Height="32"
                              SelectedIndex="0"
                              SelectionChanged="SearchTypeCombo_SelectionChanged">
                        <ComboBoxItem Content="Document Number"/>
                        <ComboBoxItem Content="Model"/>
                        <ComboBoxItem Content="Chassis Number"/>
                        <ComboBoxItem Content="Motor Number"/>
                    </ComboBox>
                    <TextBox x:Name="SearchBox" Width="270" Height="32"
                             Margin="10 0 0 0" VerticalContentAlignment="Center"
                             Padding="6 0" TextChanged="SearchBox_TextChanged"/>
                    <Button Content="Clear" Width="72" Height="32" Margin="8 0 0 0"
                            Background="#FF616161" Foreground="White"
                            BorderThickness="0" Click="ClearSearch_Click"/>
                    <TextBlock x:Name="SearchResultHint" VerticalAlignment="Center"
                               Margin="16 0 0 0" FontStyle="Italic" Foreground="#666666"/>
                </StackPanel>
            </Border>

            <!-- BILLS GRID
                 Column formula reminder:
                   Previous Balance  = RemainingBalance of the bill before this one
                   Total Amount      = sum of all item wholesale prices on THIS bill
                   Amount Paid       = paid against THIS bill at time of entry
                   Net Bill          = Previous Balance + Total Amount − Amount Paid
                                       (same as RemainingBalance for that bill row)
                   Remaining Balance = running total owed after this bill
            -->
            <DataGrid x:Name="BillsGrid" Grid.Row="3"
                      AutoGenerateColumns="False" HeadersVisibility="Column"
                      SelectionMode="Single" CanUserAddRows="False"
                      IsReadOnly="True" RowStyle="{StaticResource BillRowStyle}">
                <DataGrid.Columns>

                    <!-- Identity & Date -->
                    <DataGridTextColumn Header="Bill ID"
                                        Binding="{Binding Bill.Id}"
                                        Width="65"/>
                    <DataGridTextColumn Header="Bill Date"
                                        Binding="{Binding Bill.BillDate, StringFormat={}{0:dd-MMM-yyyy}}"
                                        Width="115"/>
                    <DataGridTextColumn Header="Document #"
                                        Binding="{Binding FirstDocNumber}"
                                        Width="115"/>

                    <!-- ✅ Previous Balance — balance carried forward FROM the bill before this one -->
                    <DataGridTextColumn Header="Prev. Balance"
                                        Binding="{Binding Bill.PreviousBalance, StringFormat=N2}"
                                        Width="115"/>

                    <!-- ✅ Total Amount — this bill's items total only (no previous) -->
                    <DataGridTextColumn Header="Bill Amount"
                                        Binding="{Binding Bill.TotalAmount, StringFormat=N2}"
                                        Width="110"/>

                    <!-- Amount paid at the time of this bill entry -->
                    <DataGridTextColumn Header="Paid (this bill)"
                                        Binding="{Binding Bill.AmountPaid, StringFormat=N2}"
                                        Width="115"/>

                    <DataGridTextColumn Header="Pay Source"
                                        Binding="{Binding Bill.PaymentSource}"
                                        Width="95"/>

                    <!-- ✅ Net Bill = Prev.Balance + Bill Amount − Paid
                             This is the DB computed column. Shown in bold. -->
                    <DataGridTextColumn Header="Net Bill"
                                        Binding="{Binding Bill.NetBill, StringFormat=N2}"
                                        Width="110"
                                        FontWeight="Bold"/>

                    <!-- ✅ Remaining Balance = running owed after this bill
                             After all payments this is what the vendor is still owed. -->
                    <DataGridTextColumn Header="Remaining Balance"
                                        Binding="{Binding Bill.RemainingBalance, StringFormat=N2}"
                                        Width="145"
                                        FontWeight="Bold"/>

                    <!-- Commission & Tax info -->
                    <DataGridTextColumn Header="Commission"
                                        Binding="{Binding Bill.TotalCommission, StringFormat=N2}"
                                        Width="110"/>
                    <DataGridTextColumn Header="Tax Paid"
                                        Binding="{Binding Bill.TotalTaxPaid, StringFormat=N2}"
                                        Width="95"/>

                    <!-- Actions -->
                    <DataGridTemplateColumn Header="Actions" Width="270">
                        <DataGridTemplateColumn.CellTemplate>
                            <DataTemplate>
                                <StackPanel Orientation="Horizontal" HorizontalAlignment="Center">
                                    <Button Content="View"
                                            Width="58" Margin="0 0 4 0"
                                            Background="#FF00695C" Foreground="White"
                                            BorderThickness="0" Click="ViewBill_Click"/>
                                    <Button Content="Print"
                                            Width="58" Margin="0 0 4 0"
                                            Background="#FF6A1B9A" Foreground="White"
                                            BorderThickness="0" Click="PrintBill_Click"/>
                                    <Button Content="Edit"
                                            Width="58" Margin="0 0 4 0"
                                            Background="#FF1E88E5" Foreground="White"
                                            BorderThickness="0" Click="EditBill_Click"/>
                                    <Button Content="Delete"
                                            Width="58"
                                            Background="#FFC62828" Foreground="White"
                                            BorderThickness="0" Click="DeleteBill_Click"/>
                                </StackPanel>
                            </DataTemplate>
                        </DataGridTemplateColumn.CellTemplate>
                    </DataGridTemplateColumn>

                </DataGrid.Columns>
            </DataGrid>
        </Grid>
    </Page>
