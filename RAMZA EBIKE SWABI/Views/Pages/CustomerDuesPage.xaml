<Page x:Class="Ramza_EBike_Swabi.Views.Pages.CustomerDuesPage"
      xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
      xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
      Background="#F5F6FA"
      Title="Customer Dues">

	<Page.Resources>
		<BooleanToVisibilityConverter x:Key="BoolToVis"/>
	</Page.Resources>

	<Grid Margin="20">
		<Grid.RowDefinitions>
			<RowDefinition Height="Auto"/>
			<!-- 0: Header + Back         -->
			<RowDefinition Height="Auto"/>
			<!-- 1: Due-Today Banner       -->
			<RowDefinition Height="Auto"/>
			<!-- 2: Search + Download      -->
			<RowDefinition Height="Auto"/>
			<!-- 3: Date Range Filter  NEW -->
			<RowDefinition Height="*"/>
			<!-- 4: DataGrid               -->
		</Grid.RowDefinitions>

		<!-- ── Row 0: Header + Back ─────────────────────────────────────────── -->
		<Grid Grid.Row="0" Margin="0 0 0 15" VerticalAlignment="Center">
			<Grid.ColumnDefinitions>
				<ColumnDefinition Width="Auto"/>
				<ColumnDefinition Width="*"/>
				<ColumnDefinition Width="Auto"/>
			</Grid.ColumnDefinitions>

			<Button Grid.Column="0"
                    Content="← Back"
                    Width="100" Height="35"
                    FontWeight="Bold"
                    Background="#FF2B579A" Foreground="White"
                    BorderThickness="0" Cursor="Hand"
                    Click="Back_Click"/>

			<TextBlock Grid.Column="1"
                       Text="Customer Dues"
                       FontSize="26" FontWeight="Bold"
                       HorizontalAlignment="Center"
                       VerticalAlignment="Center"/>
		</Grid>

		<!-- ── Row 1: Due-Today Notification Banner ─────────────────────────── -->
		<Border x:Name="pnlDueNotification"
                Grid.Row="1"
                Background="#FFF3CD"
                BorderBrush="#FFEAA7"
                BorderThickness="1"
                CornerRadius="8"
                Padding="14 10"
                Margin="0 0 0 12"
                Visibility="Collapsed">
			<Grid>
				<Grid.ColumnDefinitions>
					<ColumnDefinition Width="Auto"/>
					<ColumnDefinition Width="*"/>
					<ColumnDefinition Width="Auto"/>
					<ColumnDefinition Width="Auto"/>
				</Grid.ColumnDefinitions>

				<TextBlock Grid.Column="0"
                           Text="🔔"
                           FontSize="22"
                           VerticalAlignment="Center"
                           Margin="0 0 12 0"/>

				<StackPanel Grid.Column="1" VerticalAlignment="Center">
					<TextBlock x:Name="lblDueNotificationTitle"
                               FontWeight="Bold" FontSize="14"
                               Foreground="#856404"/>
					<ItemsControl x:Name="lstDueToday" Margin="0 4 0 0">
						<ItemsControl.ItemTemplate>
							<DataTemplate>
								<TextBlock FontSize="13" Foreground="#664D03" Margin="0 1">
									<Run Text="• INV-"/>
									<Run Text="{Binding CustomerInvoiceId, StringFormat=D4}"/>
									<Run Text=" — "/>
									<Run Text="{Binding Customer.Name}"/>
									<Run Text="  |  Remaining: ₨ "/>
									<Run Text="{Binding RemainingBalance, StringFormat=N0}"/>
									<Run Text="  |  Contact: "/>
									<Run Text="{Binding Customer.Contact}"/>
								</TextBlock>
							</DataTemplate>
						</ItemsControl.ItemTemplate>
					</ItemsControl>
				</StackPanel>

				<!-- Send All WhatsApp button -->
				<Button Grid.Column="2"
                        Content="📲 WhatsApp All"
                        Padding="10 6"
                        Margin="8 0"
                        Background="#25D366" Foreground="White"
                        BorderThickness="0" Cursor="Hand"
                        FontSize="13" FontWeight="Bold"
                        VerticalAlignment="Center"
                        Click="NotifyAll_Click">
					<Button.Style>
						<Style TargetType="Button">
							<Setter Property="Template">
								<Setter.Value>
									<ControlTemplate TargetType="Button">
										<Border Background="{TemplateBinding Background}"
                                                CornerRadius="6"
                                                Padding="{TemplateBinding Padding}">
											<ContentPresenter HorizontalAlignment="Center"
                                                              VerticalAlignment="Center"/>
										</Border>
									</ControlTemplate>
								</Setter.Value>
							</Setter>
							<Style.Triggers>
								<Trigger Property="IsMouseOver" Value="True">
									<Setter Property="Background" Value="#1DA851"/>
								</Trigger>
							</Style.Triggers>
						</Style>
					</Button.Style>
				</Button>

				<!-- Dismiss -->
				<Button Grid.Column="3"
                        Content="✕"
                        Width="28" Height="28"
                        Background="Transparent"
                        BorderThickness="0"
                        FontSize="14"
                        Foreground="#856404"
                        VerticalAlignment="Top"
                        Cursor="Hand"
                        Click="DismissNotification_Click"/>
			</Grid>
		</Border>

		<!-- ── Row 2: Search Bar + Download ─────────────────────────────────── -->
		<Grid Grid.Row="2" Margin="0 0 0 8">
			<Grid.ColumnDefinitions>
				<ColumnDefinition Width="*"/>
				<ColumnDefinition Width="Auto"/>
				<ColumnDefinition Width="Auto"/>
			</Grid.ColumnDefinitions>

			<TextBox x:Name="SearchBox"
                     Grid.Column="0"
                     Height="35"
                     Padding="10 0"
                     VerticalContentAlignment="Center"
                     FontSize="14"
                     BorderBrush="#CCCCCC"
                     BorderThickness="1"
                     TextChanged="SearchBox_TextChanged">
				<TextBox.Style>
					<Style TargetType="TextBox">
						<Setter Property="Template">
							<Setter.Value>
								<ControlTemplate TargetType="TextBox">
									<Border Background="White"
                                            BorderBrush="{TemplateBinding BorderBrush}"
                                            BorderThickness="{TemplateBinding BorderThickness}"
                                            CornerRadius="6">
										<Grid>
											<TextBlock x:Name="Placeholder"
                                                       Text="Search by customer name or CNIC..."
                                                       Foreground="#AAAAAA"
                                                       Padding="10 0"
                                                       VerticalAlignment="Center"
                                                       FontSize="13"
                                                       IsHitTestVisible="False"
                                                       Visibility="Collapsed"/>
											<ScrollViewer x:Name="PART_ContentHost"
                                                          Margin="0"
                                                          VerticalAlignment="Center"/>
										</Grid>
									</Border>
									<ControlTemplate.Triggers>
										<Trigger Property="Text" Value="">
											<Setter TargetName="Placeholder"
                                                    Property="Visibility" Value="Visible"/>
										</Trigger>
									</ControlTemplate.Triggers>
								</ControlTemplate>
							</Setter.Value>
						</Setter>
					</Style>
				</TextBox.Style>
			</TextBox>

			<Button Grid.Column="1"
                    Content="🔍 Search"
                    Width="110" Height="35"
                    Margin="8 0 0 0"
                    Background="#2B579A" Foreground="White"
                    BorderThickness="0" FontSize="13"
                    Cursor="Hand" Click="Search_Click">
				<Button.Style>
					<Style TargetType="Button">
						<Setter Property="Template">
							<Setter.Value>
								<ControlTemplate TargetType="Button">
									<Border Background="{TemplateBinding Background}"
                                            CornerRadius="6"
                                            Padding="{TemplateBinding Padding}">
										<ContentPresenter HorizontalAlignment="Center"
                                                          VerticalAlignment="Center"/>
									</Border>
								</ControlTemplate>
							</Setter.Value>
						</Setter>
						<Style.Triggers>
							<Trigger Property="IsMouseOver" Value="True">
								<Setter Property="Background" Value="#1E4080"/>
							</Trigger>
						</Style.Triggers>
					</Style>
				</Button.Style>
			</Button>

			<Button Grid.Column="2"
                    Content="⬇ Download List"
                    Width="140" Height="35"
                    Margin="8 0 0 0"
                    Background="#27AE60" Foreground="White"
                    BorderThickness="0" FontSize="13"
                    Cursor="Hand" Click="Download_Click">
				<Button.Style>
					<Style TargetType="Button">
						<Setter Property="Template">
							<Setter.Value>
								<ControlTemplate TargetType="Button">
									<Border Background="{TemplateBinding Background}"
                                            CornerRadius="6"
                                            Padding="{TemplateBinding Padding}">
										<ContentPresenter HorizontalAlignment="Center"
                                                          VerticalAlignment="Center"/>
									</Border>
								</ControlTemplate>
							</Setter.Value>
						</Setter>
						<Style.Triggers>
							<Trigger Property="IsMouseOver" Value="True">
								<Setter Property="Background" Value="#219150"/>
							</Trigger>
						</Style.Triggers>
					</Style>
				</Button.Style>
			</Button>
		</Grid>

		<!-- ── Row 3: Date Range Filter (NEW) ───────────────────────────────── -->
		<Border Grid.Row="3"
                Background="White"
                BorderBrush="#DDDDDD"
                BorderThickness="1"
                CornerRadius="8"
                Padding="12 8"
                Margin="0 0 0 12">
			<StackPanel Orientation="Horizontal" VerticalAlignment="Center">

				<!-- Label -->
				<TextBlock Text="📅  Filter by Invoice Date:"
                           FontSize="13" FontWeight="SemiBold"
                           Foreground="#444444"
                           VerticalAlignment="Center"
                           Margin="0 0 12 0"/>

				<!-- From label -->
				<TextBlock Text="From"
                           FontSize="13" Foreground="#666666"
                           VerticalAlignment="Center"
                           Margin="0 0 6 0"/>

				<!-- From DatePicker -->
				<DatePicker x:Name="dpFrom"
                            Width="130" Height="32"
                            FontSize="13"
                            SelectedDateChanged="DateFilter_Changed"
                            VerticalContentAlignment="Center"/>

				<!-- To label -->
				<TextBlock Text="To"
                           FontSize="13" Foreground="#666666"
                           VerticalAlignment="Center"
                           Margin="14 0 6 0"/>

				<!-- To DatePicker -->
				<DatePicker x:Name="dpTo"
                            Width="130" Height="32"
                            FontSize="13"
                            SelectedDateChanged="DateFilter_Changed"
                            VerticalContentAlignment="Center"/>

				<!-- Clear button -->
				<Button Content="✕ Clear"
                        Width="70" Height="30"
                        Margin="14 0 0 0"
                        Background="#E74C3C" Foreground="White"
                        BorderThickness="0" FontSize="12"
                        Cursor="Hand"
                        Click="ClearDates_Click">
					<Button.Style>
						<Style TargetType="Button">
							<Setter Property="Template">
								<Setter.Value>
									<ControlTemplate TargetType="Button">
										<Border Background="{TemplateBinding Background}"
                                                CornerRadius="5"
                                                Padding="{TemplateBinding Padding}">
											<ContentPresenter HorizontalAlignment="Center"
                                                              VerticalAlignment="Center"/>
										</Border>
									</ControlTemplate>
								</Setter.Value>
							</Setter>
							<Style.Triggers>
								<Trigger Property="IsMouseOver" Value="True">
									<Setter Property="Background" Value="#C0392B"/>
								</Trigger>
							</Style.Triggers>
						</Style>
					</Button.Style>
				</Button>

				<!-- Live result count -->
				<TextBlock x:Name="lblFilterCount"
                           FontSize="12" Foreground="#888888"
                           VerticalAlignment="Center"
                           Margin="18 0 0 0"/>

			</StackPanel>
		</Border>

		<!-- ── Row 4: DataGrid ──────────────────────────────────────────────── -->
		<DataGrid x:Name="dgDues"
                  Grid.Row="4"
                  AutoGenerateColumns="False"
                  IsReadOnly="True"
                  CanUserAddRows="False"
                  CanUserDeleteRows="False"
                  RowHeight="42"
                  HeadersVisibility="Column"
                  BorderBrush="#DDDDDD"
                  BorderThickness="1"
                  AlternatingRowBackground="#F9FAFB"
                  Background="White"
                  RowBackground="White"
                  GridLinesVisibility="None"
                  FontFamily="Segoe UI"
                  FontSize="14">

			<DataGrid.Resources>
				<Style TargetType="DataGridColumnHeader">
					<Setter Property="Background" Value="#E0E6ED"/>
					<Setter Property="FontWeight" Value="SemiBold"/>
					<Setter Property="Padding" Value="10,8"/>
					<Setter Property="BorderBrush" Value="#CCCCCC"/>
					<Setter Property="BorderThickness" Value="0,0,1,1"/>
				</Style>
				<Style TargetType="DataGridCell">
					<Setter Property="Padding" Value="10,5"/>
					<Setter Property="Template">
						<Setter.Value>
							<ControlTemplate TargetType="DataGridCell">
								<ContentPresenter VerticalAlignment="Center"/>
							</ControlTemplate>
						</Setter.Value>
					</Setter>
				</Style>

				<!-- Row highlight: yellow = due today, red bg = overdue -->
				<Style TargetType="DataGridRow">
					<Style.Triggers>
						<DataTrigger Binding="{Binding IsDueToday}" Value="True">
							<Setter Property="Background" Value="#FFF8E1"/>
							<Setter Property="FontWeight" Value="SemiBold"/>
						</DataTrigger>
						<DataTrigger Binding="{Binding IsOverdue}" Value="True">
							<Setter Property="Background" Value="#FFEBEE"/>
						</DataTrigger>
					</Style.Triggers>
				</Style>
			</DataGrid.Resources>

			<DataGrid.Columns>

				<DataGridTextColumn Header="Invoice #"
                                    Binding="{Binding CustomerInvoiceId}"
                                    Width="0.6*"/>

				<DataGridTextColumn Header="Customer"
                                    Binding="{Binding Customer.Name}"
                                    Width="1.4*"/>

				<DataGridTextColumn Header="CNIC"
                                    Binding="{Binding Customer.CNIC}"
                                    Width="1.2*"/>

				<DataGridTextColumn Header="Contact"
                                    Binding="{Binding Customer.Contact}"
                                    Width="1*"/>

				<DataGridTextColumn Header="Net Bill"
                                    Binding="{Binding NetBill, StringFormat='₨ {0:N0}'}"
                                    Width="0.8*"/>

				<DataGridTextColumn Header="Paid"
                                    Binding="{Binding AmountPaid, StringFormat='₨ {0:N0}'}"
                                    Width="0.8*"/>

				<DataGridTextColumn Header="Remaining"
                                    Binding="{Binding RemainingBalance, StringFormat='₨ {0:N0}'}"
                                    Width="0.8*"/>

				<!-- Due Date column -->
				<DataGridTemplateColumn Header="Due Date" Width="115">
					<DataGridTemplateColumn.CellTemplate>
						<DataTemplate>
							<TextBlock Text="{Binding DueDateDisplay}"
                                       Foreground="{Binding DueDateColor}"
                                       FontWeight="{Binding DueDateFontWeight}"
                                       VerticalAlignment="Center"
                                       Padding="6 0"/>
						</DataTemplate>
					</DataGridTemplateColumn.CellTemplate>
				</DataGridTemplateColumn>

				<!-- Actions column -->
				<DataGridTemplateColumn Header="Actions" Width="280">
					<DataGridTemplateColumn.CellTemplate>
						<DataTemplate>
							<StackPanel Orientation="Horizontal"
                                        HorizontalAlignment="Center"
                                        Margin="4,0">

								<!-- Edit -->
								<Button Content="Edit"
                                        Margin="0,0,4,0" Padding="8,4" FontSize="12"
                                        Background="#3498DB" Foreground="White"
                                        BorderThickness="0" Cursor="Hand"
                                        Click="Edit_Click">
									<Button.Style>
										<Style TargetType="Button">
											<Setter Property="Template">
												<Setter.Value>
													<ControlTemplate TargetType="Button">
														<Border Background="{TemplateBinding Background}"
                                                                CornerRadius="4"
                                                                Padding="{TemplateBinding Padding}">
															<ContentPresenter HorizontalAlignment="Center"
                                                                              VerticalAlignment="Center"/>
														</Border>
													</ControlTemplate>
												</Setter.Value>
											</Setter>
											<Style.Triggers>
												<Trigger Property="IsMouseOver" Value="True">
													<Setter Property="Background" Value="#2980B9"/>
												</Trigger>
											</Style.Triggers>
										</Style>
									</Button.Style>
								</Button>

								<!-- Pay -->
								<Button Content="Pay"
                                        Margin="0,0,4,0" Padding="8,4" FontSize="12"
                                        Background="#E67E22" Foreground="White"
                                        BorderThickness="0" Cursor="Hand"
                                        Click="Pay_Click">
									<Button.Style>
										<Style TargetType="Button">
											<Setter Property="Template">
												<Setter.Value>
													<ControlTemplate TargetType="Button">
														<Border Background="{TemplateBinding Background}"
                                                                CornerRadius="4"
                                                                Padding="{TemplateBinding Padding}">
															<ContentPresenter HorizontalAlignment="Center"
                                                                              VerticalAlignment="Center"/>
														</Border>
													</ControlTemplate>
												</Setter.Value>
											</Setter>
											<Style.Triggers>
												<Trigger Property="IsMouseOver" Value="True">
													<Setter Property="Background" Value="#CA6F1E"/>
												</Trigger>
											</Style.Triggers>
										</Style>
									</Button.Style>
								</Button>

								<!-- History -->
								<Button Content="History"
                                        Margin="0,0,4,0" Padding="8,4" FontSize="12"
                                        Background="#8E44AD" Foreground="White"
                                        BorderThickness="0" Cursor="Hand"
                                        Click="History_Click">
									<Button.Style>
										<Style TargetType="Button">
											<Setter Property="Template">
												<Setter.Value>
													<ControlTemplate TargetType="Button">
														<Border Background="{TemplateBinding Background}"
                                                                CornerRadius="4"
                                                                Padding="{TemplateBinding Padding}">
															<ContentPresenter HorizontalAlignment="Center"
                                                                              VerticalAlignment="Center"/>
														</Border>
													</ControlTemplate>
												</Setter.Value>
											</Setter>
											<Style.Triggers>
												<Trigger Property="IsMouseOver" Value="True">
													<Setter Property="Background" Value="#7D3C98"/>
												</Trigger>
											</Style.Triggers>
										</Style>
									</Button.Style>
								</Button>

								<!-- PDF -->
								<Button Content="PDF"
                                        Margin="0,0,4,0" Padding="8,4" FontSize="12"
                                        Background="#2ECC71" Foreground="White"
                                        BorderThickness="0" Cursor="Hand"
                                        Click="Pdf_Click">
									<Button.Style>
										<Style TargetType="Button">
											<Setter Property="Template">
												<Setter.Value>
													<ControlTemplate TargetType="Button">
														<Border Background="{TemplateBinding Background}"
                                                                CornerRadius="4"
                                                                Padding="{TemplateBinding Padding}">
															<ContentPresenter HorizontalAlignment="Center"
                                                                              VerticalAlignment="Center"/>
														</Border>
													</ControlTemplate>
												</Setter.Value>
											</Setter>
											<Style.Triggers>
												<Trigger Property="IsMouseOver" Value="True">
													<Setter Property="Background" Value="#27AE60"/>
												</Trigger>
											</Style.Triggers>
										</Style>
									</Button.Style>
								</Button>

								<!-- WhatsApp Notify button -->
								<Button Content="📲"
                                        Padding="8,4" FontSize="12"
                                        Background="#25D366" Foreground="White"
                                        BorderThickness="0" Cursor="Hand"
                                        Visibility="{Binding HasDueDate,
                                                     Converter={StaticResource BoolToVis}}"
                                        ToolTip="Send WhatsApp payment reminder"
                                        Click="Notify_Click">
									<Button.Style>
										<Style TargetType="Button">
											<Setter Property="Template">
												<Setter.Value>
													<ControlTemplate TargetType="Button">
														<Border Background="{TemplateBinding Background}"
                                                                CornerRadius="4"
                                                                Padding="{TemplateBinding Padding}">
															<ContentPresenter HorizontalAlignment="Center"
                                                                              VerticalAlignment="Center"/>
														</Border>
													</ControlTemplate>
												</Setter.Value>
											</Setter>
											<Style.Triggers>
												<Trigger Property="IsMouseOver" Value="True">
													<Setter Property="Background" Value="#1DA851"/>
												</Trigger>
											</Style.Triggers>
										</Style>
									</Button.Style>
								</Button>

							</StackPanel>
						</DataTemplate>
					</DataGridTemplateColumn.CellTemplate>
				</DataGridTemplateColumn>

			</DataGrid.Columns>
		</DataGrid>
	</Grid>
</Page>
