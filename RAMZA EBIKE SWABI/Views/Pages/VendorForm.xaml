<Page x:Class="Ramza_EBike_Swabi.Views.Pages.VendorForm"
      xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
      xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
      Background="#80000000">
    <Grid VerticalAlignment="Center" HorizontalAlignment="Center">
        <Border Width="440" Padding="20" Background="White" CornerRadius="12" Effect="{DynamicResource CardShadow}">
            <Grid>
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="12"/>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="8"/>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="8"/>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="16"/>
                    <RowDefinition Height="Auto"/>
                </Grid.RowDefinitions>

                <TextBlock Grid.Row="0" Text="Vendor Form" FontSize="20" FontWeight="Bold" HorizontalAlignment="Center"/>
                <TextBlock Grid.Row="2" Text="Vendor Name" FontWeight="SemiBold" Margin="0,4,0,2"/>
                <Border Grid.Row="3" Background="#FFF2F2F2" CornerRadius="6" Padding="6">
                    <TextBox x:Name="VendorNameBox" Background="Transparent" BorderThickness="0" Height="30" VerticalContentAlignment="Center"/>
                </Border>

                <TextBlock Grid.Row="5" Text="Phone" FontWeight="SemiBold" Margin="0,4,0,2"/>
                <Border Grid.Row="6" Background="#FFF2F2F2" CornerRadius="6" Padding="6">
                    <TextBox x:Name="PhoneBox" Background="Transparent" BorderThickness="0" Height="30" VerticalContentAlignment="Center"/>
                </Border>

                <TextBlock Grid.Row="8" Text="Address" FontWeight="SemiBold" Margin="0,4,0,2"/>
                <Border Grid.Row="9" Background="#FFF2F2F2" CornerRadius="6" Padding="6">
                    <TextBox x:Name="AddressBox" Background="Transparent" BorderThickness="0" Height="80" TextWrapping="Wrap" AcceptsReturn="True" VerticalScrollBarVisibility="Auto"/>
                </Border>

                <StackPanel Grid.Row="11" Orientation="Horizontal" HorizontalAlignment="Right">
                    <Button x:Name="CancelButton" Content="Cancel" Width="100" Height="34" Margin="0,0,8,0" Background="#FF9E9E9E" Foreground="White" BorderBrush="Transparent" Click="Cancel_Click"/>
                    <Button x:Name="SaveButton" Content="Save" Width="120" Height="34" Background="#FF2B579A" Foreground="White" BorderBrush="Transparent" FontWeight="Bold" Click="Save_Click"/>
                </StackPanel>
            </Grid>
        </Border>
    </Grid>
</Page>
