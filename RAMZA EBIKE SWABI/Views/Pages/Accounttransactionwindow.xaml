<Window x:Class="Ramza_EBike_Swabi.Views.Pages.AccountTransactionWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Add / Convert Balance"
        Height="700" Width="560"
        WindowStartupLocation="CenterOwner"
        ResizeMode="NoResize"
        Background="#F4F6F9">

    <ScrollViewer VerticalScrollBarVisibility="Auto"
                  HorizontalScrollBarVisibility="Disabled">
        <StackPanel Margin="28 24 28 28">

            <!-- TITLE -->
            <TextBlock Text="Add / Convert Balance"
                       FontSize="22"
                       FontWeight="Bold"
                       Foreground="#1B4079"
                       Margin="0 0 0 20"/>

            <!-- TRANSACTION TYPE -->
            <TextBlock Text="Select Transaction Type"
                       FontWeight="Bold"
                       FontSize="13"
                       Margin="0 0 0 10"/>

            <!-- Option 1 -->
            <Border x:Name="BorderConvert"
                    BorderThickness="2"
                    CornerRadius="8"
                    Background="White"
                    Padding="14 12"
                    Margin="0 0 0 8">
                <RadioButton x:Name="rbConvertCashToAccount"
                             GroupName="TxnType"
                             IsChecked="True"
                             Checked="Option_Checked">
                    <StackPanel Margin="8 0 0 0">
                        <TextBlock Text="Convert Cash to Account"
                                   FontWeight="Bold"
                                   FontSize="13"/>
                        <TextBlock Text="Move money from Cash Balance into Account Balance"
                                   Foreground="#666666"
                                   FontSize="11"
                                   Margin="0 3 0 0"/>
                    </StackPanel>
                </RadioButton>
            </Border>

            <!-- Option 2 -->
            <Border x:Name="BorderDepositCash"
                    BorderThickness="2"
                    CornerRadius="8"
                    Background="White"
                    Padding="14 12"
                    Margin="0 0 0 8">
                <RadioButton x:Name="rbDepositCash"
                             GroupName="TxnType"
                             Checked="Option_Checked">
                    <StackPanel Margin="8 0 0 0">
                        <TextBlock Text="Deposit Cash  (Add to Cash Balance)"
                                   FontWeight="Bold"
                                   FontSize="13"/>
                        <TextBlock Text="External cash received - increases Cash Balance"
                                   Foreground="#666666"
                                   FontSize="11"
                                   Margin="0 3 0 0"/>
                    </StackPanel>
                </RadioButton>
            </Border>

            <!-- Option 3 -->
            <Border x:Name="BorderDepositAccount"
                    BorderThickness="2"
                    CornerRadius="8"
                    Background="White"
                    Padding="14 12"
                    Margin="0 0 0 8">
                <RadioButton x:Name="rbDepositAccount"
                             GroupName="TxnType"
                             Checked="Option_Checked">
                    <StackPanel Margin="8 0 0 0">
                        <TextBlock Text="Deposit to Account Balance"
                                   FontWeight="Bold"
                                   FontSize="13"/>
                        <TextBlock Text="External bank transfer received - increases Account Balance"
                                   Foreground="#666666"
                                   FontSize="11"
                                   Margin="0 3 0 0"/>
                    </StackPanel>
                </RadioButton>
            </Border>

            <!-- Option 4 -->
            <Border x:Name="BorderWithdrawAccount"
                    BorderThickness="2"
                    CornerRadius="8"
                    Background="White"
                    Padding="14 12"
                    Margin="0 0 0 8">
                <RadioButton x:Name="rbWithdrawAccount"
                             GroupName="TxnType"
                             Checked="Option_Checked">
                    <StackPanel Margin="8 0 0 0">
                        <TextBlock Text="Withdraw from Account to Cash"
                                   FontWeight="Bold"
                                   FontSize="13"/>
                        <TextBlock Text="Take cash out of Account Balance - moves to Cash Balance"
                                   Foreground="#666666"
                                   FontSize="11"
                                   Margin="0 3 0 0"/>
                    </StackPanel>
                </RadioButton>
            </Border>

            <!-- Option 5 -->
            <Border x:Name="BorderWithdrawCash"
                    BorderThickness="2"
                    CornerRadius="8"
                    Background="White"
                    Padding="14 12"
                    Margin="0 0 0 20">
                <RadioButton x:Name="rbWithdrawCash"
                             GroupName="TxnType"
                             Checked="Option_Checked">
                    <StackPanel Margin="8 0 0 0">
                        <TextBlock Text="Withdraw / Spend from Cash Balance"
                                   FontWeight="Bold"
                                   FontSize="13"/>
                        <TextBlock Text="Cash spent or removed - decreases Cash Balance"
                                   Foreground="#666666"
                                   FontSize="11"
                                   Margin="0 3 0 0"/>
                    </StackPanel>
                </RadioButton>
            </Border>

            <!-- BY WHOM -->
            <TextBlock Text="By Whom *"
                       FontWeight="Bold"
                       FontSize="13"
                       Margin="0 0 0 5"/>
            <TextBox x:Name="txtByWhom"
                     Height="34"
                     VerticalContentAlignment="Center"
                     Padding="8 0"
                     FontSize="13"
                     Margin="0 0 0 14"/>

            <!-- AMOUNT -->
            <TextBlock Text="Amount (PKR) *"
                       FontWeight="Bold"
                       FontSize="13"
                       Margin="0 0 0 5"/>
            <TextBox x:Name="txtAmount"
                     Height="34"
                     VerticalContentAlignment="Center"
                     Padding="8 0"
                     FontSize="13"
                     Margin="0 0 0 14"/>

            <!-- DATE + TIME -->
            <TextBlock Text="Date and Time"
                       FontWeight="Bold"
                       FontSize="13"
                       Margin="0 0 0 5"/>
            <StackPanel Orientation="Horizontal" Margin="0 0 0 14">
                <DatePicker x:Name="dpDate"
                            Width="160"
                            Height="34"/>
                <TextBox x:Name="txtTime"
                         Width="90"
                         Height="34"
                         Margin="10 0 0 0"
                         VerticalContentAlignment="Center"
                         Padding="8 0"
                         FontSize="13"/>
                <TextBlock Text="(HH:mm)"
                           VerticalAlignment="Center"
                           Foreground="#888888"
                           Margin="8 0 0 0"/>
            </StackPanel>

            <!-- REMARKS -->
            <TextBlock Text="Remarks"
                       FontWeight="Bold"
                       FontSize="13"
                       Margin="0 0 0 5"/>
            <TextBox x:Name="txtRemarks"
                     Height="70"
                     AcceptsReturn="True"
                     TextWrapping="Wrap"
                     VerticalScrollBarVisibility="Auto"
                     Padding="8 6"
                     FontSize="13"
                     Margin="0 0 0 24"/>

            <!-- BUTTONS -->
            <StackPanel Orientation="Horizontal"
                        HorizontalAlignment="Right">
                <Button Content="Cancel"
                        Width="110"
                        Height="40"
                        FontSize="13"
                        Margin="0 0 10 0"
                        Click="Cancel_Click"/>
                <Button Content="Save Transaction"
                        Width="160"
                        Height="40"
                        Background="#FF1B4079"
                        Foreground="White"
                        FontWeight="Bold"
                        FontSize="13"
                        BorderThickness="0"
                        Click="Save_Click"/>
            </StackPanel>

        </StackPanel>
    </ScrollViewer>
</Window>
