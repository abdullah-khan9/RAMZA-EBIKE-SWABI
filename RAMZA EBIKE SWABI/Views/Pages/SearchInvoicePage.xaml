<Page x:Class="Ramza_EBike_Swabi.Views.Pages.SearchInvoicePage"
      xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
      xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
      Background="#F5F6FA"
      Title="Search Invoice">

    <Grid Margin="20">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
        </Grid.RowDefinitions>

        <!-- Header + Back -->
        <Grid Margin="0 0 0 15" VerticalAlignment="Center">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="Auto"/>
                <ColumnDefinition Width="*"/>
                <ColumnDefinition Width="Auto"/>
            </Grid.ColumnDefinitions>

            <!-- Back Button (Left) -->
            <Button Grid.Column="0"
                    Content="← Back"
                    Width="100"
                    Height="35"
                    FontWeight="Bold"
                    Background="#FF2B579A"
                    Foreground="White"
                    BorderThickness="0"
                    Cursor="Hand"
                    Click="Back_Click"/>

            <!-- Centered Title -->
            <TextBlock Grid.Column="1"
                       Text="Search Customer Invoices"
                       FontSize="26"
                       FontWeight="Bold"
                       HorizontalAlignment="Center"
                       VerticalAlignment="Center"/>
        </Grid>

        <!-- Search Box -->
        <Grid Grid.Row="1" Margin="0,0,0,10">
            <TextBox x:Name="txtSearch"
                     Height="40"
                     Padding="12,8"
                     FontSize="14"
                     BorderBrush="#BDC3C7"
                     BorderThickness="1"
                     Background="White"
                     VerticalContentAlignment="Center"/>
            <TextBlock IsHitTestVisible="False"
                       Text="Enter invoice number, customer name, or CNIC..."
                       VerticalAlignment="Center"
                       HorizontalAlignment="Left"
                       Margin="15,0,0,0"
                       Foreground="#95A5A6"
                       FontSize="14">
                <TextBlock.Style>
                    <Style TargetType="TextBlock">
                        <Setter Property="Visibility" Value="Collapsed"/>
                        <Style.Triggers>
                            <MultiDataTrigger>
                                <MultiDataTrigger.Conditions>
                                    <Condition Binding="{Binding Text, ElementName=txtSearch}" Value=""/>
                                    <Condition Binding="{Binding IsKeyboardFocusWithin, ElementName=txtSearch}" Value="False"/>
                                </MultiDataTrigger.Conditions>
                                <Setter Property="Visibility" Value="Visible"/>
                            </MultiDataTrigger>
                        </Style.Triggers>
                    </Style>
                </TextBlock.Style>
            </TextBlock>
        </Grid>

        <!-- Filters + Buttons aligned right -->
        <StackPanel Grid.Row="2" Orientation="Horizontal" HorizontalAlignment="Right" Margin="0,0,0,15" VerticalAlignment="Center">

            <TextBlock Text="From:" VerticalAlignment="Center" Margin="0,0,5,0"/>
            <DatePicker x:Name="dpFrom" Width="140" Margin="0,0,15,0"/>

            <TextBlock Text="To:" VerticalAlignment="Center" Margin="0,0,5,0"/>
            <DatePicker x:Name="dpTo" Width="140" Margin="0,0,20,0"/>

            <Button Content="Search"
                    Height="40"
                    Width="100"
                    Margin="0,0,10,0"
                    Background="#3498DB"
                    Foreground="White"
                    BorderThickness="0"
                    Cursor="Hand"
                    Click="Search_Click"/>

            <Button Content="Clear"
                    Height="40"
                    Width="100"
                    Margin="0,0,10,0"
                    Background="#95A5A6"
                    Foreground="White"
                    BorderThickness="0"
                    Cursor="Hand"
                    Click="Clear_Click"/>

            <Button Content="Download List"
                    Height="40"
                    Width="140"
                    Background="#27AE60"
                    Foreground="White"
                    BorderThickness="0"
                    Cursor="Hand"
                    Click="Download_Click"/>
        </StackPanel>

        <!-- Results DataGrid -->
        <DataGrid x:Name="dgInvoices"
                  Grid.Row="3"
                  AutoGenerateColumns="False"
                  IsReadOnly="True"
                  CanUserAddRows="False"
                  CanUserDeleteRows="False"
                  RowHeight="40"
                  HeadersVisibility="Column"
                  BorderBrush="#DDDDDD"
                  BorderThickness="1"
                  AlternatingRowBackground="#F9FAFB"
                  Background="White"
                  RowBackground="White"
                  GridLinesVisibility="None"
                  FontFamily="Segoe UI"
                  FontSize="14">

            <DataGrid.Resources>
                <Style TargetType="DataGridColumnHeader">
                    <Setter Property="Background" Value="#E0E6ED"/>
                    <Setter Property="FontWeight" Value="SemiBold"/>
                    <Setter Property="Padding" Value="10,8"/>
                    <Setter Property="BorderBrush" Value="#CCCCCC"/>
                    <Setter Property="BorderThickness" Value="0,0,1,1"/>
                </Style>
                <Style TargetType="DataGridCell">
                    <Setter Property="Padding" Value="10,5"/>
                    <Setter Property="Template">
                        <Setter.Value>
                            <ControlTemplate TargetType="DataGridCell">
                                <ContentPresenter VerticalAlignment="Center"/>
                            </ControlTemplate>
                        </Setter.Value>
                    </Setter>
                </Style>
            </DataGrid.Resources>

            <DataGrid.Columns>
                <DataGridTextColumn Header="Invoice #"
                        Binding="{Binding CustomerInvoiceId}"
                        Width="0.6*"/>

                <DataGridTextColumn Header="Customer"
                        Binding="{Binding Customer.Name}"
                        Width="1.4*"/>

                <DataGridTextColumn Header="CNIC"
                        Binding="{Binding Customer.CNIC}"
                        Width="1.2*"/>

                <DataGridTextColumn Header="Contact"
                        Binding="{Binding Customer.Contact}"
                        Width="1*"/>

                <DataGridTextColumn Header="Net Bill"
                        Binding="{Binding NetBill, StringFormat='₨ {0:N0}'}"
                        Width="0.8*"/>

                <DataGridTextColumn Header="Paid Amount"
                        Binding="{Binding AmountPaid, StringFormat='₨ {0:N0}'}"
                        Width="0.8*"/>

                <DataGridTextColumn Header="Remaining"
                        Binding="{Binding RemainingBalance, StringFormat='₨ {0:N0}'}"
                        Width="0.8*"/>

                <DataGridTextColumn Header="Status"
                        Binding="{Binding Status}"
                        Width="0.7*"/>

                <DataGridTemplateColumn Header="Actions" Width="185">
                    <DataGridTemplateColumn.CellTemplate>
                        <DataTemplate>
                            <StackPanel Orientation="Horizontal"
                            HorizontalAlignment="Center"
                            Margin="4,0">

                                <Button Content="Edit"
                            Margin="0,0,4,0"
                            Padding="8,4"
                            FontSize="12"
                            Background="#3498DB"
                            Foreground="White"
                            BorderThickness="0"
                            Cursor="Hand"
                            Click="Edit_Click"/>

                                <Button Content="History"
                            Margin="0,0,4,0"
                            Padding="8,4"
                            FontSize="12"
                            Background="#8E44AD"
                            Foreground="White"
                            BorderThickness="0"
                            Cursor="Hand"
                            Click="History_Click"/>

                                <Button Content="PDF"
                            Padding="8,4"
                            FontSize="12"
                            Background="#2ECC71"
                            Foreground="White"
                            BorderThickness="0"
                            Cursor="Hand"
                            Click="Pdf_Click"/>

                            </StackPanel>
                        </DataTemplate>
                    </DataGridTemplateColumn.CellTemplate>
                </DataGridTemplateColumn>
            </DataGrid.Columns>
        </DataGrid>
    </Grid>
</Page>
